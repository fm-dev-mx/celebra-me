---
export const prerender = false;

import { resolvePublicSiteOrigin } from '@/lib/invitation/social-metadata';
import { resolveShortIdRequest } from '@/lib/invitation/short-id-resolver';
import InvitationOGShell from '@/lib/invitation/InvitationOGShell.astro';

const SITE_ORIGIN = resolvePublicSiteOrigin();
const { shortId } = Astro.params;

const resolution = await resolveShortIdRequest(
  shortId,
  Astro.request.headers.get('user-agent') || '',
  SITE_ORIGIN,
);

if (resolution.kind === 'error') {
  return Astro.redirect('/404');
}

if (resolution.kind === 'redirect') {
  return Astro.redirect(resolution.redirectTarget);
}
---

<InvitationOGShell
  ogTitle={resolution.ogData.ogTitle}
  ogDescription={resolution.ogData.ogDescription}
  ogImage={resolution.ogData.ogImage}
  canonicalUrl={resolution.canonicalUrl}
/>
