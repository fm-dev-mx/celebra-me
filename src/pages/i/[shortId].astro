---
export const prerender = false;

import { resolvePublicSiteOrigin } from '@/lib/invitation/social-metadata';
import { resolveShortIdPage } from '@/lib/invitation/short-id-resolver';
import InvitationOGShell from '@/lib/invitation/InvitationOGShell.astro';

const SITE_ORIGIN = resolvePublicSiteOrigin();
const { shortId } = Astro.params;

Astro.response.headers.set('Cache-Control', 'no-store');
Astro.response.headers.set('Vary', 'User-Agent');

const result = await resolveShortIdPage(shortId, Astro.request, SITE_ORIGIN);

if (result.kind === 'error') {
  return new Response(null, { status: 404 });
}

if (result.kind === 'redirect') {
  return Astro.redirect(result.target);
}
---

<InvitationOGShell
  ogTitle={result.ogData.ogTitle}
  ogDescription={result.ogData.ogDescription}
  ogImage={result.ogData.ogImage}
  canonicalUrl={result.canonicalUrl}
  redirectTarget={result.redirectTarget}
/>
