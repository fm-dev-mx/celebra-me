---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { requireAdminSession } from '@/lib/rsvp/auth/authorization';
import { prepareDashboardAdminPageData } from '@/lib/dashboard/admin-page-data';

await requireAdminSession(Astro.request);

const pageData = await prepareDashboardAdminPageData();
---

<DashboardLayout
	title="Panel de Administración"
>
	<section class="dashboard-card">
		<h2>Administración global</h2>
		<p>
			Usa la navegación lateral para gestionar códigos de acceso, eventos y usuarios.
		</p>
	</section>

	<div class="dashboard-stats-grid">
		<div class="dashboard-stat-card">
			<h3>Eventos</h3>
			<p class="dashboard-stat-number">{pageData.stats.events}</p>
			<a href="/dashboard/eventos" class="dashboard-stat-link">Ver eventos →</a>
		</div>
		<div class="dashboard-stat-card">
			<h3>Usuarios</h3>
			<p class="dashboard-stat-number">{pageData.stats.users}</p>
			<a href="/dashboard/usuarios" class="dashboard-stat-link">Ver usuarios →</a>
		</div>
		<div class="dashboard-stat-card">
			<h3>Códigos de acceso</h3>
			<p class="dashboard-stat-number">{pageData.stats.claimCodes}</p>
			<p class="dashboard-stat-subtext">{pageData.stats.activeClaimCodes} activos</p>
			<a href="/dashboard/claimcodes" class="dashboard-stat-link">Gestionar →</a>
		</div>
	</div>

	<style lang="scss">
		.dashboard-stats-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
			gap: 1.5rem;
			margin-top: 2rem;
		}
		.dashboard-stat-card {
			background:
				linear-gradient(
					180deg,
					var(--dashboard-surface-card-strong),
					var(--dashboard-surface-card-soft)
				),
				var(--dashboard-surface-panel);
			border: 1px solid var(--dashboard-border-premium);
			border-radius: 1rem;
			padding: 1.5rem;
			transition: transform 0.2s ease;
			box-shadow: var(--shadow-subtle);
		}
		.dashboard-stat-card:hover {
			transform: translateY(-2px);
			box-shadow: var(--shadow-emphasis);
		}
		.dashboard-stat-card h3 {
			margin: 0 0 0.5rem;
			font-size: 1rem;
			color: var(--dashboard-text-secondary);
			font-weight: 500;
		}
		.dashboard-stat-number {
			font-size: 2.5rem;
			font-weight: 700;
			margin: 0.5rem 0;
			color: var(--dashboard-brand-primary);
		}
		.dashboard-stat-subtext {
			font-size: 0.875rem;
			color: var(--dashboard-text-muted);
			margin: 0.25rem 0 1rem;
		}
		.dashboard-stat-link {
			display: inline-block;
			color: var(--dashboard-text-brand);
			text-decoration: none;
			font-weight: 500;
			font-size: 0.875rem;
		}
		.dashboard-stat-link:hover {
			text-decoration: underline;
		}
	</style>
</DashboardLayout>
