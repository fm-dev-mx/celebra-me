---
import Layout from '@/layouts/Layout.astro';
import Logo from '@/components/ui/Logo.astro';
import '@styles/auth/_login.scss';

// Read the session directly from the server-side cookie
const sessionToken = Astro.cookies.get('sb-access-token')?.value || '';
---

<Layout
	title="Configurar Seguridad MFA"
	description="Protege tu cuenta de administrador con autenticación de dos factores"
	hideHeader={true}
	className="theme-preset--auth-dark"
>
	<section class="auth-shell" data-variant="dark">
		<header class="auth-local-header">
			<a class="auth-brand" href="/" aria-label="Volver al inicio">
				<Logo variant="white" class="auth-brand__logo" altText="Celebra.me" />
				<span class="auth-brand__caption">Seguridad Admin</span>
			</a>
		</header>

		<article class="auth-card" style="max-width: 500px;">
			<div class="auth-copy">
				<p class="auth-kicker">Paso obligatorio de seguridad</p>
				<h1>Configura MFA</h1>
				<p>Como Superadmin, tu cuenta requiere autenticación de dos factores para proteger la plataforma.</p>
			</div>

			<!-- Pass the token via data-attribute -->
			<div
				id="mfa-app"
				class="auth-panel"
				data-token={sessionToken}
				data-url={import.meta.env.PUBLIC_SUPABASE_URL}
				data-key={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
			>
				<div class="mfa-setup-steps">
					<div id="qr-container" class="qr-placeholder">
						<div class="loader"></div>
						<p>Generando código seguro...</p>
					</div>

					<div class="auth-form">
						<div class="auth-field">
							<label for="mfa-code">Código de verificación</label>
							<input
								id="mfa-code"
								type="text"
								inputmode="numeric"
								pattern="[0-9]*"
								placeholder="000000"
								maxlength="6"
							/>
							<p class="auth-hint">Introduce el código de 6 dígitos de tu app de autenticación.</p>
						</div>

						<button id="verify-mfa" class="auth-submit">Verificar y Activar</button>
						<p id="mfa-status" class="auth-status" role="status"></p>
					</div>
				</div>
			</div>
		</article>
	</section>

	<style>
		.qr-placeholder {
			background: white;
			padding: 2rem;
			border-radius: 1rem;
			margin: 1.5rem 0;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			min-height: 250px;
			color: #080808;
			text-align: center;
		}

		.qr-placeholder img {
			max-width: 200px;
			height: auto;
		}

		.loader {
			border: 3px solid #f3f3f3;
			border-top: 3px solid #d4af37;
			border-radius: 50%;
			width: 30px;
			height: 30px;
			animation: spin 1s linear infinite;
			margin-bottom: 1rem;
		}

		@keyframes spin {
			0% { transform: rotate(0deg); }
			100% { transform: rotate(360deg); }
		}
	</style>

	<script>
		import { createClient } from '@supabase/supabase-js';

		const appEl = document.getElementById('mfa-app');
		const qrContainer = document.getElementById('qr-container');
		const verifyBtn = document.getElementById('verify-mfa') as HTMLButtonElement | null;
		const codeInput = document.getElementById('mfa-code') as HTMLInputElement | null;
		const statusEl = document.getElementById('mfa-status');

		const token = appEl?.dataset.token;
		const url = appEl?.dataset.url;
		const key = appEl?.dataset.key;

		let enrollmentId = '';
		let supabase: any = null;

		function getCookie(name: string) {
			const value = `; ${document.cookie}`;
			const parts = value.split(`; ${name}=`);
			if (parts.length === 2) return parts.pop()?.split(';').shift();
			return null;
		}

		async function init() {
			console.log('[MFA] Iniciando configuración...');

			const finalToken = token || getCookie('sb-access-token') || getCookie('sb-mfa-session') || sessionStorage.getItem('temp-sb-access-token');
			const refreshToken = getCookie('sb-refresh-token') || sessionStorage.getItem('temp-sb-refresh-token') || '';

			console.log('[MFA] Session check:', {
				hasAttrToken: !!token,
				hasAccessTokenCookie: !!getCookie('sb-access-token'),
				hasRefreshTokenCookie: !!getCookie('sb-refresh-token'),
				hasMfaSessionCookie: !!getCookie('sb-mfa-session'),
				tokenLength: finalToken?.length
			});

			if (!url || !key || !finalToken) {
				console.error('[MFA] Error de configuración:', { url: !!url, key: !!key, token: !!finalToken });
				if (statusEl) {
					statusEl.textContent = 'Faltan datos de sesión para configurar seguridad. Por favor, intenta iniciar sesión de nuevo.';
					statusEl.dataset.tone = 'error';
				}
				return;
			}

			try {
				supabase = createClient(url, key);
				console.log('[MFA] Supabase client created');

				// SYNC SESSION
				const { data: sessionData, error: sessionError } = await supabase.auth.setSession({
					access_token: finalToken,
					refresh_token: refreshToken,
				});

				if (sessionError) {
					console.error('[MFA] setSession Error:', sessionError);
					if (statusEl) statusEl.textContent = 'Error al sincronizar sesión de seguridad. Reintenta el acceso.';
					return;
				}

				console.log('[MFA] Session synced successfully:', { user: sessionData?.user?.email });

				// CHECK EXISTING FACTORS
				const { data: factors, error: factorsError } = await supabase.auth.mfa.listFactors();
				if (factorsError) {
					console.warn('[MFA] Could not list factors, proceeding with enrollment anyway:', factorsError);
				}

				const verifiedFactor = factors?.all?.find((f: any) => f.status === 'verified' && f.factor_type === 'totp');

				if (verifiedFactor) {
					console.log('[MFA] Found verified factor, switching to Challenge Mode:', verifiedFactor.id);
					enrollmentId = verifiedFactor.id;

					if (qrContainer) {
						qrContainer.innerHTML = '';
						const icon = document.createElement('div');
						// Gold icon for success/locked state
						icon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" ><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>`;
						icon.style.marginBottom = '1rem';
						qrContainer.appendChild(icon);

						const p = document.createElement('p');
						p.style.color = '#080808';
						p.style.fontWeight = '500';
						p.textContent = 'MFA ya está configurado. Ingresa el código de tu aplicación para continuar.';
						qrContainer.appendChild(p);
					}
					// Return early to skip enrollment, but ensure we set enrollmentId so verify works
					return;
				}

				// IF NO VERIFIED FACTOR, CLEANUP UNVERIFIED ONES
				if (factors && factors.all && factors.all.length > 0) {
					console.log('[MFA] Found unverified factors, cleaning up...', factors.all.length);
					const unverifiedFactors = factors.all.filter((f: any) => f.status === 'unverified');

					for (const factor of unverifiedFactors) {
						const { error: unenrollError } = await supabase.auth.mfa.unenroll({ factorId: factor.id });
						if (unenrollError) {
							console.error('[MFA] Failed to unenroll factor:', factor.id, unenrollError);
						} else {
							console.log('[MFA] Unenrolled factor:', factor.id);
						}
					}
				}

				// ENROLL NEW FACTOR
				const { data, error: enrollError } = await supabase.auth.mfa.enroll({
					factorType: 'totp'
				});

				if (enrollError) throw enrollError;

				enrollmentId = data.id;

				if (qrContainer && data.totp.qr_code) {
					qrContainer.innerHTML = '';
					const img = document.createElement('img');
					img.src = data.totp.qr_code;
					img.alt = 'Scan this QR Code';
					qrContainer.appendChild(img);

					const p = document.createElement('p');
					p.style.marginTop = '1.5rem';
					p.style.color = '#000';
					p.style.fontWeight = '600';
					p.style.fontSize = '0.9rem';
					p.textContent = 'Escanea este código con tu App Authenticator';
					qrContainer.appendChild(p);
				}
			} catch (err: any) {
				console.error('[MFA] Init/Enrollment Error:', err);
				if (statusEl) {
					statusEl.textContent = `Error: ${err.message || 'No se pudo generar el QR'}. Reintenta el login.`;
					statusEl.dataset.tone = 'error';
				}
			}
		}

		async function handleVerify() {
			const code = codeInput?.value;
			if (!code || code.length !== 6 || !verifyBtn || !statusEl) return;

			verifyBtn.disabled = true;
			statusEl.textContent = 'Verificando código...';

			try {
				const { error } = await supabase.auth.mfa.challengeAndVerify({
					factorId: enrollmentId,
					code: code
				});

				if (error) throw error;

				statusEl.textContent = '¡Verificado! Redirigiendo...';
				statusEl.dataset.tone = 'success';

				setTimeout(() => {
					window.location.href = '/dashboard/invitados';
				}, 1000);

			} catch (err: any) {
				console.error('[MFA] Verify Error:', err);
				statusEl.textContent = 'Código incorrecto. Intenta de nuevo.';
				statusEl.dataset.tone = 'error';
				verifyBtn.disabled = false;
			}
		}

		verifyBtn?.addEventListener('click', handleVerify);
		init();
	</script>
</Layout>
