---
import Layout from '@/layouts/Layout.astro';
import Logo from '@/components/ui/Logo.astro';
import '@styles/auth/_login.scss';
import MfaSetupBehavior from '@/components/behavior/MfaSetupBehavior';
---

<Layout
	title="Configurar Seguridad MFA"
	description="Protege tu cuenta de administrador con autenticación de dos factores"
	hideHeader={true}
	className="theme-preset--auth-dark"
>
	<section class="auth-shell" data-variant="dark">
		<header class="auth-local-header">
			<a class="auth-brand" href="/" aria-label="Volver al inicio">
				<Logo variant="white" class="auth-brand__logo" altText="Celebra.me" />
				<span class="auth-brand__caption">Seguridad Admin</span>
			</a>
		</header>

		<article class="auth-card auth-card--narrow">
			<div class="auth-copy">
				<p class="auth-kicker">Paso obligatorio de seguridad</p>
				<h1 id="mfa-title">Configura tu verificación en dos pasos</h1>
				<p id="mfa-description">Como Superadmin, tu cuenta requiere autenticación de dos factores para proteger la plataforma.</p>
			</div>

			<div
				id="mfa-app"
				class="auth-panel"
				data-url={import.meta.env.PUBLIC_SUPABASE_URL}
				data-key={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
			>
				<div class="mfa-setup-steps">
					<div id="qr-container" class="qr-placeholder">
						<div class="loader"></div>
						<p>Preparando verificación segura...</p>
					</div>

					<div class="auth-form">
						<div class="auth-field">
							<label for="mfa-code">Código de verificación</label>
							<input
								id="mfa-code"
								type="text"
								inputmode="numeric"
								pattern="[0-9]*"
								placeholder="000000"
								maxlength="6"
							/>
							<p id="mfa-hint" class="auth-hint">Introduce el código de 6 dígitos de tu app de autenticación.</p>
						</div>

						<button id="verify-mfa" class="auth-submit">Verificar y Activar</button>
						<p id="mfa-status" class="auth-status" role="status"></p>
					</div>
				</div>
			</div>
		</article>
	</section>

	<style>
		.qr-placeholder {
			background: white;
			padding: 2rem;
			border-radius: 1rem;
			margin: 1.5rem 0;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			min-height: 250px;
			color: var(--color-surface-dark);
			text-align: center;
		}

		.loader {
			border-top: 3px solid var(--color-action-accent);
			border-radius: 50%;
			width: 30px;
			height: 30px;
			animation: spin 1s linear infinite;
			margin-bottom: 1rem;
		}

		@keyframes spin {
			0% { transform: rotate(0deg); }
			100% { transform: rotate(360deg); }
		}
	</style>

	<MfaSetupBehavior client:only="react" />
</Layout>
