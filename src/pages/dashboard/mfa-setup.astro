---
import Layout from '@/layouts/Layout.astro';
import Logo from '@/components/ui/Logo.astro';
import '@styles/auth/_login.scss';
---

<Layout
	title="Configurar Seguridad MFA"
	description="Protege tu cuenta de administrador con autenticación de dos factores"
	hideHeader={true}
	className="theme-preset--auth-dark"
>
	<section class="auth-shell" data-variant="dark">
		<header class="auth-local-header">
			<a class="auth-brand" href="/" aria-label="Volver al inicio">
				<Logo variant="white" class="auth-brand__logo" altText="Celebra.me" />
				<span class="auth-brand__caption">Seguridad Admin</span>
			</a>
		</header>

		<article class="auth-card auth-card--narrow">
			<div class="auth-copy">
				<p class="auth-kicker">Paso obligatorio de seguridad</p>
				<h1 id="mfa-title">Configura tu verificación en dos pasos</h1>
				<p id="mfa-description">Como Superadmin, tu cuenta requiere autenticación de dos factores para proteger la plataforma.</p>
			</div>

			<div
				id="mfa-app"
				class="auth-panel"
				data-url={import.meta.env.PUBLIC_SUPABASE_URL}
				data-key={import.meta.env.PUBLIC_SUPABASE_ANON_KEY}
			>
				<div class="mfa-setup-steps">
					<div id="qr-container" class="qr-placeholder">
						<div class="loader"></div>
						<p>Preparando verificación segura...</p>
					</div>

					<div class="auth-form">
						<div class="auth-field">
							<label for="mfa-code">Código de verificación</label>
							<input
								id="mfa-code"
								type="text"
								inputmode="numeric"
								pattern="[0-9]*"
								placeholder="000000"
								maxlength="6"
							/>
							<p id="mfa-hint" class="auth-hint">Introduce el código de 6 dígitos de tu app de autenticación.</p>
						</div>

						<button id="verify-mfa" class="auth-submit">Verificar y Activar</button>
						<p id="mfa-status" class="auth-status" role="status"></p>
					</div>
				</div>
			</div>
		</article>
	</section>

	<style>
		.qr-placeholder {
			background: white;
			padding: 2rem;
			border-radius: 1rem;
			margin: 1.5rem 0;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			min-height: 250px;
			color: #080808;
			text-align: center;
		}

		.qr-placeholder--continue {
			background: #f8f6ef;
			border: 1px solid rgba(212, 175, 55, 0.45);
			min-height: 200px;
		}

		.loader {
			border: 3px solid #f3f3f3;
			border-top: 3px solid #d4af37;
			border-radius: 50%;
			width: 30px;
			height: 30px;
			animation: spin 1s linear infinite;
			margin-bottom: 1rem;
		}

		@keyframes spin {
			0% { transform: rotate(0deg); }
			100% { transform: rotate(360deg); }
		}
	</style>

	<script>
		import { createClient } from '@supabase/supabase-js';
		import { classifyMfaError, pickLatestVerifiedTotpFactor } from '@/lib/rsvp/mfa-setup';

		const appEl = document.getElementById('mfa-app');
		const qrContainer = document.getElementById('qr-container');
		const verifyBtn = document.getElementById('verify-mfa') as HTMLButtonElement | null;
		const codeInput = document.getElementById('mfa-code') as HTMLInputElement | null;
		const statusEl = document.getElementById('mfa-status');
		const titleEl = document.getElementById('mfa-title');
		const descriptionEl = document.getElementById('mfa-description');
		const hintEl = document.getElementById('mfa-hint');

		const url = appEl?.dataset.url;
		const key = appEl?.dataset.key;

		let supabase: ReturnType<typeof createClient> | null = null;
		let factorId = '';

		function getCookie(name: string) {
			const value = `; ${document.cookie}`;
			const parts = value.split(`; ${name}=`);
			if (parts.length === 2) return parts.pop()?.split(';').shift();
			return null;
		}

		function setStatus(message: string, tone: 'info' | 'error' | 'success' = 'info') {
			if (!statusEl) return;
			statusEl.textContent = message;
			statusEl.dataset.tone = tone;
		}

		function renderVerifyExistingUI() {
			if (titleEl) titleEl.textContent = 'Verifica tu acceso';
			if (descriptionEl) {
				descriptionEl.textContent =
					'Tu cuenta está protegida con verificación en dos pasos. Ingresa el código de tu app para continuar.';
			}
			if (hintEl) hintEl.textContent = 'Abre tu app Authenticator y escribe el código actual de 6 dígitos.';
			if (verifyBtn) verifyBtn.textContent = 'Continuar';

			if (qrContainer) {
				qrContainer.classList.add('qr-placeholder--continue');
				qrContainer.innerHTML = '';

				const icon = document.createElement('div');
				icon.innerHTML =
					'<svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#d4af37" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>';
				icon.style.marginBottom = '1rem';
				qrContainer.appendChild(icon);

				const text = document.createElement('p');
				text.style.color = '#080808';
				text.style.fontWeight = '500';
				text.textContent = 'Verificación en dos pasos activa. Ingresa tu código para continuar.';
				qrContainer.appendChild(text);
			}
		}

		function renderEnrollUI(qrCode: string) {
			if (titleEl) titleEl.textContent = 'Configura tu verificación en dos pasos';
			if (descriptionEl) {
				descriptionEl.textContent =
					'Como Superadmin, tu cuenta requiere autenticación de dos factores para proteger la plataforma.';
			}
			if (hintEl) hintEl.textContent = 'Introduce el código de 6 dígitos de tu app de autenticación.';
			if (verifyBtn) verifyBtn.textContent = 'Verificar y Activar';

			if (qrContainer) {
				qrContainer.classList.remove('qr-placeholder--continue');
				qrContainer.innerHTML = '';

				const img = document.createElement('img');
				img.src = qrCode;
				img.alt = 'Escanea este código QR con tu app de autenticación';
				qrContainer.appendChild(img);

				const text = document.createElement('p');
				text.style.marginTop = '1.5rem';
				text.style.color = '#000';
				text.style.fontWeight = '600';
				text.style.fontSize = '0.9rem';
				text.textContent = 'Escanea este código con tu App Authenticator';
				qrContainer.appendChild(text);
			}
		}

		async function initSessionFromCookies() {
			const accessToken = getCookie('sb-mfa-session') || '';
			const refreshToken = getCookie('sb-mfa-refresh') || '';

			if (!url || !key || !accessToken) {
				setStatus('Tu sesión de seguridad expiró. Inicia sesión de nuevo.', 'error');
				setTimeout(() => {
					window.location.href = '/login';
				}, 1200);
				return false;
			}

			supabase = createClient(url, key);
			const { error } = await supabase.auth.setSession({
				access_token: accessToken,
				refresh_token: refreshToken,
			});

			if (error) {
				setStatus('No fue posible recuperar la sesión de seguridad. Inicia sesión de nuevo.', 'error');
				setTimeout(() => {
					window.location.href = '/login';
				}, 1200);
				return false;
			}

			return true;
		}

		async function resolveMfaMode() {
			if (!supabase) return;
			const { data: factors, error: factorsError } = await supabase.auth.mfa.listFactors();
			if (factorsError) throw factorsError;
			const allFactors = factors?.all || [];

			const verifiedFactor = pickLatestVerifiedTotpFactor(allFactors as any[]);
			if (verifiedFactor?.id) {
				factorId = verifiedFactor.id;
				renderVerifyExistingUI();
				return;
			}

			const unverifiedFactors = allFactors.filter((item) => item.status === 'unverified');
			for (const factor of unverifiedFactors) {
				await supabase.auth.mfa.unenroll({ factorId: factor.id });
			}

			const { data: enrollData, error: enrollError } = await supabase.auth.mfa.enroll({ factorType: 'totp' });
			if (enrollError) throw enrollError;
			if (!enrollData?.id || !enrollData?.totp?.qr_code) {
				throw new Error('No se pudo preparar el factor MFA.');
			}

			factorId = enrollData.id;
			renderEnrollUI(enrollData.totp.qr_code);
		}

		async function verifyCode() {
			const code = codeInput?.value?.trim() || '';
			if (!verifyBtn || !codeInput || !factorId) return;
			if (!/^\d{6}$/.test(code)) {
				setStatus('Ingresa un código válido de 6 dígitos.', 'error');
				return;
			}

			if (!supabase) return;
			verifyBtn.disabled = true;
			verifyBtn.textContent = 'Verificando...';
			verifyBtn.style.opacity = '0.7';
			setStatus('Verificando código...', 'info');

			try {
				const { error: verifyError } = await supabase.auth.mfa.challengeAndVerify({
					factorId,
					code,
				});
				if (verifyError) throw verifyError;

				const {
					data: { session: elevatedSession },
				} = await supabase.auth.getSession();
				if (!elevatedSession?.access_token) {
					throw new Error('No se obtuvo sesión MFA elevada.');
				}

				const syncResponse = await fetch('/api/auth/sync-session', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({
						accessToken: elevatedSession.access_token,
						refreshToken: elevatedSession.refresh_token,
					}),
				});
				if (!syncResponse.ok) {
					throw new Error('No se pudo sincronizar la sesión segura.');
				}

				setStatus('Verificación completada. Redirigiendo...', 'success');
				setTimeout(() => {
					window.location.replace('/dashboard/admin');
				}, 250);
			} catch (error) {
				const errorType = classifyMfaError(error);
				if (errorType === 'session_expired') {
					setStatus('Tu sesión de verificación expiró. Inicia sesión de nuevo.', 'error');
					setTimeout(() => {
						window.location.href = '/login';
					}, 1200);
					return;
				}
			if (errorType === 'sync_failed') {
					setStatus(
						'Verificamos tu código, pero no pudimos activar la sesión. Intenta de nuevo.',
						'error',
					);
					verifyBtn.disabled = false;
					verifyBtn.textContent = 'Verificar y Activar';
					verifyBtn.style.opacity = '1';
					return;
				}
				if (errorType === 'invalid_code') {
					setStatus('El código no coincide. Verifica tu app e inténtalo de nuevo.', 'error');
				} else {
					setStatus('No pudimos validar tu código. Intenta de nuevo.', 'error');
				}
				verifyBtn.disabled = false;
				verifyBtn.textContent = 'Verificar y Activar';
				verifyBtn.style.opacity = '1';
			}
		}

		verifyBtn?.addEventListener('click', () => {
			void verifyCode();
		});

		codeInput?.addEventListener('keydown', (event) => {
			if (event.key === 'Enter') {
				event.preventDefault();
				void verifyCode();
			}
		});

		(async () => {
			const sessionOk = await initSessionFromCookies();
			if (!sessionOk) return;
			try {
				await resolveMfaMode();
			} catch {
				setStatus('No fue posible preparar la verificación MFA. Inicia sesión nuevamente.', 'error');
			}
		})();
	</script>
</Layout>
