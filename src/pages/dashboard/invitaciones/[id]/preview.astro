---
export const prerender = false;

import { getCollection } from 'astro:content';
import { findDraftByInvitationId } from '@/lib/intake/repositories/invitation-content-draft.repository';
import { findInvitationById } from '@/lib/intake/repositories/invitation.repository';
import { findPublishedByInvitationId } from '@/lib/intake/repositories/published-invitation-content.repository';
import { getContentEntrySlug } from '@/lib/content/events';
import { buildDraftPreviewPageContext } from '@/lib/invitation/draft-preview-helper';
import type { InvitationPageContext } from '@/lib/invitation/page-data';

import DashboardLayout from '@/layouts/DashboardLayout.astro';
import Layout from '@/layouts/Layout.astro';
import InvitationSections from '@/components/invitation/InvitationSections.astro';
import Footer from '@/components/invitation/Footer.astro';
import Hero from '@/components/invitation/Hero.astro';
import MusicPlayer from '@/components/invitation/MusicPlayer.astro';
import EventHeader from '@/components/invitation/EventHeader.astro';
import EnvelopeReveal from '@/components/invitation/EnvelopeReveal.astro';
import '@/styles/invitation.scss';

const { id } = Astro.params;

let errorMessage: string | null = null;
let previewSource: string | null = null;
let hasNoContent = false;

if (!id) {
	return Astro.redirect('/dashboard/invitaciones');
}

const invitation = await findInvitationById(id);
if (!invitation) {
	errorMessage = 'Invitación no encontrada.';
}

let content: Record<string, unknown> | null = null;

// Draft takes priority
const draft = await findDraftByInvitationId(id);
if (draft) {
	content = draft.content;
	previewSource = 'Borrador';
} else if (!errorMessage) {
	// Fall back to published content
	const published = await findPublishedByInvitationId(id);
	if (published) {
		content = published.content;
		previewSource = 'Versión pública';
	}
}

if (!content && !errorMessage) {
	hasNoContent = true;
}

let pageCtx: InvitationPageContext | undefined;

if (!errorMessage && invitation && content) {
	const snapshot = invitation.snapshot;
	if (!snapshot || !snapshot.previewSlug) {
		errorMessage = 'La plantilla base de esta invitación no está soportada.';
	} else {
		const entries = await getCollection('event-demos');
		const demoEntry = entries.find(
			(e: { id: string }) => getContentEntrySlug(e.id) === snapshot.previewSlug,
		);
		const demoContent = (demoEntry?.data as Record<string, unknown>) ?? {};

		if (Object.keys(demoContent).length === 0) {
			errorMessage = 'No se encontró el contenido de la plantilla base.';
		} else {
			const result = buildDraftPreviewPageContext(invitation, content, demoContent);

			if (result.ok) {
				pageCtx = result.pageContext;
			} else {
				errorMessage = result.error.message;
			}
		}
	}
}

if (!errorMessage && !pageCtx) {
	errorMessage = 'Error inesperado al generar la vista previa.';
}

const editUrl = `/dashboard/invitaciones/${id}/editar`;
---

{
	hasNoContent ? (
		<DashboardLayout title="Vista previa">
			<main class="preview-empty">
				<p class="preview-empty__text">
					Aún no hay contenido para esta invitación.
				</p>
				<p class="preview-empty__hint">
					Crea un borrador para comenzar a editar.
				</p>
				<a href={editUrl} class="preview-empty__action">
					Ir al editor
				</a>
			</main>
		</DashboardLayout>
	) : errorMessage ? (
		<DashboardLayout title="Vista previa no disponible">
			<main class="preview-error">
				<h2>Vista previa no disponible</h2>
				<p>{errorMessage}</p>
				<a href={editUrl} class="preview-error__back">
					&larr; Volver al editor
				</a>
			</main>
		</DashboardLayout>
	) : pageCtx ? (
		<Layout
			title={`Vista previa — ${pageCtx.viewModel.title ?? ''}`}
			description={pageCtx.layout.description}
			image={pageCtx.layout.image}
			hideHeader={true}
			className={pageCtx.layout.className}
			isDemo={false}
			themeMode="dark"
		>
			<div class="preview-banner" role="banner">
				<span class="preview-banner__text">
					Vista previa interna — {previewSource}
				</span>
				<a href={editUrl} class="preview-banner__back">&larr; Volver al editor</a>
			</div>

			<style is:inline lang="scss" set:html={pageCtx.wrapper.scopedStyles} />
			<main class={pageCtx.wrapper.className} {...pageCtx.wrapper.dataAttributes}>
				{
					pageCtx.envelope && (
						<EnvelopeReveal
							name={pageCtx.envelope.name}
							sealStyle={pageCtx.envelope.sealStyle}
							sealIcon={pageCtx.envelope.sealIcon}
							sealInitials={pageCtx.envelope.sealInitials}
							microcopy={pageCtx.envelope.microcopy}
							documentLabel={pageCtx.envelope.documentLabel}
							stampText={pageCtx.envelope.stampText}
							stampYear={pageCtx.envelope.stampYear}
							tooltipText={pageCtx.envelope.tooltipText}
							eventSlug={pageCtx.envelope.eventSlug}
							variant={pageCtx.envelope.variant}
							card={pageCtx.envelope.card}
						/>
					)
				}

				<EventHeader
					links={pageCtx.viewModel.navigation ?? []}
					variant={pageCtx.viewModel.theme.preset}
					initials={pageCtx.viewModel.envelope?.data?.sealInitials}
					eventName={pageCtx.viewModel.hero?.name}
					eventSubtitle={pageCtx.viewModel.hero?.label}
					isDemo={false}
				/>

				<Hero
					{...pageCtx.viewModel.hero}
					time={pageCtx.heroTime}
					venueName={pageCtx.heroVenueName}
					guestName={pageCtx.guestName}
				/>

				<InvitationSections pageContext={pageCtx} />

				<Footer
					eventSlug={pageCtx.viewModel.id}
					showEnvelope={pageCtx.wrapper.showEnvelope}
					variant={pageCtx.footerVariant}
					closingPhrase="Con cariño"
					showFooterBranding={pageCtx.viewModel.brandingVisibility.showFooterBranding}
					showContactCta={pageCtx.viewModel.brandingVisibility.showContactCta}
				/>

				{pageCtx.viewModel.music && (
					<MusicPlayer
						url={pageCtx.viewModel.music.url}
						autoPlay={pageCtx.viewModel.music.autoPlay}
						title={pageCtx.viewModel.music.title}
						revealMode={pageCtx.viewModel.music.revealMode}
						variant={pageCtx.viewModel.theme.preset}
					/>
				)}
			</main>
		</Layout>
	) : null
}

<style>
	.preview-banner {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 99999;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		flex-wrap: wrap;
		padding: 8px 16px;
		background: color-mix(in srgb, var(--color-surface-primary) 92%, transparent);
		backdrop-filter: blur(12px);
		color: var(--color-text-primary);
		font-family: system-ui, sans-serif;
		font-size: 13px;
		font-weight: 600;
		letter-spacing: 0.3px;
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.preview-banner__back {
		color: var(--color-action-accent);
		text-decoration: none;
		font-size: 12px;

		&:hover {
			text-decoration: underline;
		}
	}

	.preview-empty {
		padding: 60px 24px;
		text-align: center;
		font-family: system-ui, sans-serif;
	}

	.preview-empty__text {
		font-size: 1.125rem;
		color: var(--color-text-primary);
		margin: 0 0 0.5rem;
	}

	.preview-empty__hint {
		font-size: 0.875rem;
		color: var(--color-text-muted);
		margin: 0 0 1.5rem;
	}

	.preview-empty__action {
		display: inline-block;
		padding: 0.625rem 1.25rem;
		border: 1px solid var(--color-action-accent);
		border-radius: 8px;
		background: var(--color-action-accent);
		color: var(--color-text-inverse);
		font-weight: 600;
		font-size: 0.875rem;
		text-decoration: none;
	}

	.preview-error {
		padding: 40px 24px;
		text-align: center;
		font-family: system-ui, sans-serif;
	}

	.preview-error h2 {
		font-size: 24px;
		margin-bottom: 16px;
		color: var(--color-state-error-text);
	}

	.preview-error p {
		font-size: 16px;
		color: var(--color-text-secondary);
		margin-bottom: 24px;
	}

	.preview-error__back {
		display: inline-block;
		padding: 10px 20px;
		background: var(--color-action-accent);
		color: var(--color-text-inverse);
		border-radius: 6px;
		text-decoration: none;
	}

	.preview-error__back:hover {
		opacity: 90%;
	}
</style>
