---
export const prerender = false;

import { getCollection } from 'astro:content';
import { findDraftByInvitationId } from '@/lib/intake/repositories/invitation-content-draft.repository';
import { findInvitationById } from '@/lib/intake/repositories/invitation.repository';
import { findPublishedByInvitationId } from '@/lib/intake/repositories/published-invitation-content.repository';
import { getContentEntrySlug } from '@/lib/content/events';
import { buildDraftPreviewPageContext } from '@/lib/invitation/draft-preview-helper';
import { computeEffectiveContent } from '@/lib/intake/services/merge-content.service';
import { getAssetSlugFromContent } from '@/lib/assets/asset-slug';
import type { InvitationPageContext } from '@/lib/invitation/page-data';
import { DEMO_PRESET_CATALOG } from '@/lib/intake/demo-preset-catalog';
import type { DemoPreset } from '@/lib/intake/types';

import DashboardLayout from '@/layouts/DashboardLayout.astro';
import Layout from '@/layouts/Layout.astro';
import InvitationSections from '@/components/invitation/InvitationSections.astro';
import Footer from '@/components/invitation/Footer.astro';
import Hero from '@/components/invitation/Hero.astro';
import MusicPlayer from '@/components/invitation/MusicPlayer.astro';
import EventHeader from '@/components/invitation/EventHeader.astro';
import EnvelopeReveal from '@/components/invitation/EnvelopeReveal.astro';
import '@/styles/invitation.scss';

const { id } = Astro.params;

let errorMessage: string | null = null;
let previewSource: string | null = null;
let previewWarning: string | null = null;
let pageCtx: InvitationPageContext | null = null;

if (!id) {
	return Astro.redirect('/dashboard/invitaciones');
}

const invitationRecord = await findInvitationById(id);
const resolvedSnapshot: DemoPreset | undefined = invitationRecord?.snapshot
	?? DEMO_PRESET_CATALOG.find((p) => p.id === invitationRecord?.baseDemoId);

if (!invitationRecord || !resolvedSnapshot) {
	errorMessage = 'Invitación no encontrada.';
}

const invitation = invitationRecord && resolvedSnapshot
	? { ...invitationRecord, snapshot: resolvedSnapshot }
	: null;

const entries = !errorMessage ? await getCollection('event-demos') : [];
const demoEntryForSlug = (slug: string) =>
	entries.find(
		(e: { id: string }) => getContentEntrySlug(e.id) === slug,
	);

async function tryBuildContext(
	content: Record<string, unknown>,
	label: string,
	assetLookupSlug?: string,
): Promise<InvitationPageContext | null> {
	if (!invitation) return null;

	// Resolve demo content defensively — only look up when previewSlug exists
	const demoContent: Record<string, unknown> =
		invitation.snapshot.previewSlug
			? (demoEntryForSlug(invitation.snapshot.previewSlug)?.data as Record<string, unknown>) ?? {}
			: {};

	const result = await buildDraftPreviewPageContext(invitation, content, demoContent, {
		assetLookupSlug,
	});
	if (!result.ok) return null;

	previewSource = label;
	return result.pageContext;
}

const [draft, published] = await Promise.all([
	!errorMessage ? findDraftByInvitationId(id) : null,
	!errorMessage ? findPublishedByInvitationId(id) : null,
]);

const effectiveContent = computeEffectiveContent(draft?.content, published?.content);
const hasAnyContent = Object.keys(effectiveContent).length > 0;
const publishedAssetLookupSlug = getAssetSlugFromContent(published?.content);
const previewLabel = draft?.content ? 'Borrador + publicado' : published?.content ? 'Versión pública' : 'Vacío';

if (hasAnyContent && invitation) {
	pageCtx = await tryBuildContext(effectiveContent as unknown as Record<string, unknown>, previewLabel, publishedAssetLookupSlug);
	if (!pageCtx && published?.content) {
		pageCtx = await tryBuildContext(published.content, 'Versión pública', publishedAssetLookupSlug);
		if (pageCtx) {
			previewWarning = 'El borrador actual tiene errores. Mostrando la versión pública.';
		}
	}
	if (!pageCtx) {
		previewWarning = 'El contenido combinado tiene errores.';
	}
}

if (!pageCtx && !errorMessage && invitation) {
	pageCtx = await tryBuildContext({}, 'Vacío');
	if (!pageCtx) {
		errorMessage = 'No se pudo generar la vista previa con el contenido disponible. Revisa los datos en el editor.';
	}
}

const editUrl = `/dashboard/invitaciones/${id}/editar`;
const embeddedPreview = Astro.url.searchParams.get('embed') === '1';

const wrapperDataAttributes = pageCtx
	? {
			...pageCtx.wrapper.dataAttributes,
			...(embeddedPreview ? { 'data-reveal-state': 'revealed' } : {}),
		}
	: undefined;
---

{
	errorMessage ? (
		<DashboardLayout title="Vista previa no disponible">
			<main class="preview-error">
				<h2>Vista previa no disponible</h2>
				<p>{errorMessage}</p>
				<a href={editUrl} class="preview-error__back">
					&larr; Volver al editor
				</a>
			</main>
		</DashboardLayout>
	) : pageCtx ? (
		<Layout
			title={`Vista previa — ${pageCtx.viewModel.title ?? ''}`}
			description={pageCtx.layout.description}
			image={pageCtx.layout.image}
			hideHeader={true}
			className={pageCtx.layout.className}
			isDemo={false}
			themeMode="dark"
		>
			<div class:list={['preview-banner', embeddedPreview && 'preview-banner--embedded']} role="banner">
				<span class="preview-banner__text">
					Vista previa interna — {previewSource}
				</span>
				{previewWarning && <span class="preview-banner__warning">{previewWarning}</span>}
				{previewSource === 'Vacío' && (
					<span class="preview-banner__hint">
						Aún no hay contenido guardado. Edita la invitación para agregarlo.
					</span>
				)}
			{!embeddedPreview && <a href={editUrl} class="preview-banner__back">&larr; Volver al editor</a>}
			</div>

<style is:inline lang="scss" set:html={pageCtx.wrapper.scopedStyles} />
			<main
				class={pageCtx.wrapper.className}
				{...wrapperDataAttributes}
			>
				{
					!embeddedPreview && pageCtx.envelope && (
						<EnvelopeReveal
							name={pageCtx.envelope.name}
							sealStyle={pageCtx.envelope.sealStyle}
							sealIcon={pageCtx.envelope.sealIcon}
							sealInitials={pageCtx.envelope.sealInitials}
							sealVariant={pageCtx.envelope.sealVariant}
							sealImage={pageCtx.envelope.sealImage}
							microcopy={pageCtx.envelope.microcopy}
							documentLabel={pageCtx.envelope.documentLabel}
							stampText={pageCtx.envelope.stampText}
							stampYear={pageCtx.envelope.stampYear}
							tooltipText={pageCtx.envelope.tooltipText}
							eventSlug={pageCtx.envelope.eventSlug}
							variant={pageCtx.envelope.variant}
							card={pageCtx.envelope.card}
						/>
					)
				}

				<EventHeader
					links={pageCtx.viewModel.navigation ?? []}
					variant={pageCtx.viewModel.theme.preset}
					initials={pageCtx.viewModel.envelope?.data?.sealInitials}
					eventName={pageCtx.viewModel.hero?.name}
					eventSubtitle={pageCtx.viewModel.hero?.label}
					isDemo={false}
				/>

				<Hero
					{...pageCtx.viewModel.hero}
					time={pageCtx.heroTime}
					venueName={pageCtx.heroVenueName}
					guestName={pageCtx.guestName}
				/>

				<InvitationSections pageContext={pageCtx} />

				<Footer
					eventSlug={pageCtx.viewModel.id}
					showEnvelope={pageCtx.wrapper.showEnvelope}
					variant={pageCtx.footerVariant}
					closingPhrase="Con cariño"
					showFooterBranding={pageCtx.viewModel.brandingVisibility.showFooterBranding}
					showContactCta={pageCtx.viewModel.brandingVisibility.showContactCta}
				/>

				{pageCtx.viewModel.music && (
					<MusicPlayer
						url={pageCtx.viewModel.music.url}
						autoPlay={pageCtx.viewModel.music.autoPlay}
						title={pageCtx.viewModel.music.title}
						revealMode={pageCtx.viewModel.music.revealMode}
						variant={pageCtx.viewModel.theme.preset}
					/>
				)}
			</main>
		</Layout>
	) : null
}

<style is:inline>
	:root {
		--preview-banner-height: {embeddedPreview ? '2.5rem' : '3rem'};
	}

	.preview-banner {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 99999;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		flex-wrap: wrap;
		padding: 8px 16px;
		background: color-mix(in srgb, var(--color-surface-primary) 92%, transparent);
		backdrop-filter: blur(12px);
		color: var(--color-text-primary);
		font-family: system-ui, sans-serif;
		font-size: 13px;
		font-weight: 600;
		letter-spacing: 0.3px;
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.preview-banner__back {
		color: var(--color-action-accent);
		text-decoration: none;
		font-size: 12px;

		&:hover {
			text-decoration: underline;
		}
	}

	.preview-banner__warning {
		color: var(--color-state-warning-text, #b8860b);
		font-size: 12px;
		font-weight: 400;
	}

	.preview-banner__hint {
		color: var(--color-text-muted);
		font-size: 12px;
		font-weight: 400;
	}

	.preview-banner--embedded {
		gap: 0.5rem;
		padding: 6px 10px;
		font-size: 12px;
	}

	.preview-error {
		padding: 40px 24px;
		text-align: center;
		font-family: system-ui, sans-serif;
	}

	.preview-error h2 {
		font-size: 24px;
		margin-bottom: 16px;
		color: var(--color-state-error-text);
	}

	.preview-error p {
		font-size: 16px;
		color: var(--color-text-secondary);
		margin-bottom: 24px;
	}

	.preview-error__back {
		display: inline-block;
		padding: 10px 20px;
		background: var(--color-action-accent);
		color: var(--color-text-inverse);
		border-radius: 6px;
		text-decoration: none;
	}

	.preview-error__back:hover {
		opacity: 90%;
	}
</style>
