---
import '@/styles/intake.scss';
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import InvitationEditor from '@/components/dashboard/intake/editor/InvitationEditor';
import { getInvitationEditorContext } from '@/lib/intake/services/invitation-editor.service';
import { toErrorMessage } from '@/lib/rsvp/core/errors';

const rawId = Astro.params.id;

if (!rawId) {
	return Astro.redirect('/dashboard/invitaciones');
}

let editorContext: Awaited<ReturnType<typeof getInvitationEditorContext>> | null = null;
let loadError: string | null = null;

try {
	editorContext = await getInvitationEditorContext(rawId);
} catch (error) {
	loadError = toErrorMessage(error, 'No se pudo cargar la invitación.');
}
---

<DashboardLayout title={loadError ? 'Error' : `Editar invitación - ${editorContext!.invitation.title}`}>
	<div class="intake-page-body">
		{
			loadError || !editorContext ? (
				<div class="intake-page-error">
					<p>{loadError}</p>
					<a href="/dashboard/invitaciones">Volver a invitaciones</a>
				</div>
			) : (
				<InvitationEditor client:load initialContext={editorContext} />
			)
		}
	</div>
</DashboardLayout>
