---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import InvitationDetail from '@/components/dashboard/intake/InvitationDetail';

const { id } = Astro.params;

if (!id) {
	return Astro.redirect('/dashboard/invitaciones');
}
---

<DashboardLayout title="Dashboard Invitacion">
	<InvitationDetail client:load invitationId={id} />
</DashboardLayout>
