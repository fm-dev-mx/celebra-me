---
import Layout from '@/layouts/Layout.astro';
import Logo from '@/components/ui/Logo.astro';
import { resolveNextPath } from '@/lib/rsvp/login';
import '@styles/auth/_login.scss';

const next = resolveNextPath(Astro.url.searchParams.get('next'), '/dashboard/invitados');
---

<Layout
	title="Acceso de anfitrion"
	description="Inicia sesion para administrar invitados RSVP"
	hideHeader={true}
	className="theme-preset--auth-dark"
>
	<section class="auth-shell" data-next={next} data-variant="dark">
		<header class="auth-local-header">
			<a class="auth-brand" href="/" aria-label="Volver al inicio de Celebra.me">
				<Logo variant="white" class="auth-brand__logo" altText="Celebra.me" />
				<span class="auth-brand__caption">Panel de anfitrion</span>
			</a>
			<a class="auth-back-link" href="/">Volver al inicio</a>
		</header>

		<article class="auth-card" aria-labelledby="auth-title">
			<div class="auth-copy">
				<p class="auth-kicker">Acceso seguro para anfitriones</p>
				<h1 id="auth-title">Accede a tu panel</h1>
				<p>Gestiona tu evento en un solo lugar.</p>
			</div>

			<div class="auth-tabs" role="tablist" aria-label="Opciones de autenticacion">
				<button
					id="tab-login"
					class="is-active"
					type="button"
					role="tab"
					aria-selected="true"
					aria-controls="panel-login"
				>
					Ya tengo cuenta
				</button>
				<button
					id="tab-register"
					type="button"
					role="tab"
					aria-selected="false"
					aria-controls="panel-register"
				>
					Soy cliente nuevo
				</button>
			</div>

			<section id="panel-login" class="auth-panel" role="tabpanel" aria-labelledby="tab-login">
				<form id="login-form" class="auth-form" novalidate>
					<div class="auth-field">
						<label for="login-method">Como quieres entrar</label>
						<select id="login-method" name="method">
							<option value="password">Email + contrasena</option>
							<option value="magic_link">Magic Link</option>
						</select>
						<p id="login-method-help" class="auth-hint" aria-live="polite"></p>
					</div>

					<div class="auth-field">
						<label for="login-email">Correo electronico</label>
						<input
							id="login-email"
							name="email"
							type="email"
							autocomplete="email"
							placeholder="tu-correo@ejemplo.com"
						/>
						<p id="login-email-error" class="field-error" aria-live="polite"></p>
					</div>

					<div id="login-password-wrap" class="auth-field">
						<label for="login-password">Contrasena</label>
						<input
							id="login-password"
							name="password"
							type="password"
							autocomplete="current-password"
						/>
						<p id="login-password-error" class="field-error" aria-live="polite"></p>
					</div>

					<button id="login-submit" type="submit" class="auth-submit">Continuar</button>
				</form>
			</section>

			<section
				id="panel-register"
				class="auth-panel auth-panel--hidden"
				role="tabpanel"
				aria-labelledby="tab-register"
				hidden
			>
				<form id="register-form" class="auth-form" novalidate>
					<div class="auth-field">
						<label for="register-method">Como quieres entrar</label>
						<select id="register-method" name="method">
							<option value="password">Email + contrasena</option>
							<option value="magic_link">Magic Link</option>
						</select>
						<p id="register-method-help" class="auth-hint" aria-live="polite"></p>
					</div>

					<div class="auth-field">
						<label for="register-email">Correo electronico</label>
						<input
							id="register-email"
							name="email"
							type="email"
							autocomplete="email"
							placeholder="tu-correo@ejemplo.com"
						/>
						<p id="register-email-error" class="field-error" aria-live="polite"></p>
					</div>

					<div id="register-password-wrap" class="auth-field">
						<label for="register-password">Contrasena</label>
						<input
							id="register-password"
							name="password"
							type="password"
							autocomplete="new-password"
						/>
						<p id="register-password-error" class="field-error" aria-live="polite"></p>
					</div>

					<div class="auth-field">
						<label for="register-claim-code">claimCode</label>
						<input
							id="register-claim-code"
							name="claimCode"
							type="text"
							placeholder="Ejemplo: CLAIM-2026"
						/>
						<p class="auth-hint">
							Codigo compartido por el equipo de Celebra.me.
						</p>
						<p id="register-claim-code-error" class="field-error" aria-live="polite"></p>
					</div>

					<button id="register-submit" type="submit" class="auth-submit">
						Crear cuenta y reclamar evento
					</button>
				</form>
			</section>

			<p id="auth-status" class="auth-status" role="status" aria-live="polite" tabindex="-1"></p>
		</article>
	</section>

	<script>
		import { initLoginFlow } from '../lib/rsvp/login-bridge';
		initLoginFlow();
	</script>
</Layout>
