---
export const prerender = false;

// @ts-ignore - Falsely reported as unused
import type { EventRecord } from '@/interfaces/rsvp/domain.interface';
// @ts-ignore - Falsely reported as unused
import { buildInvitationPath } from '@/utils/invitation-link';

const { eventType: rawEventType, slug } = Astro.params;
if (!rawEventType || !slug) {
	return Astro.redirect('/404');
}

return Astro.redirect(
	Astro.url.searchParams.get('invite')
		? buildInvitationPath({
				eventType: rawEventType as EventRecord['eventType'],
				eventSlug: slug,
				inviteId: Astro.url.searchParams.get('invite')!,
			})
		: `/${rawEventType}/${slug}`
);
---
