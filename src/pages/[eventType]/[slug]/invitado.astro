---
export const prerender = false;

import { buildInvitationPath } from '@/utils/invitation-link';

const { eventType, slug } = Astro.params;
if (!eventType || !slug) {
	return Astro.redirect('/404');
}

const inviteId = Astro.url.searchParams.get('invite');
const redirectPath = inviteId
	? buildInvitationPath({ eventType, eventSlug: slug, inviteId })
	: `/${eventType}/${slug}`;

return Astro.redirect(redirectPath);
---
