---
// src/pages/[eventType]/[slug]/i/[shortId].astro
export const prerender = false;

import { getInvitationContextByShortId } from '@/lib/rsvp/services/invitation-context.service';
import { buildInvitationPath } from '@/utils/invitation-link';

const { shortId } = Astro.params;

if (!shortId) {
	return Astro.redirect('/404');
}

try {
	const { eventType, eventSlug, inviteId } = await getInvitationContextByShortId(shortId);
	const redirectPath = buildInvitationPath({
		eventType,
		eventSlug,
		inviteId,
	});

	return Astro.redirect(redirectPath);
} catch (error) {
	console.error('[ShortID Resolution] Error:', error);
	return Astro.redirect('/404');
}
---

<html>
	<head>
		<title>Redirigiendo...</title>
	</head>
	<body>
		<p>Cargando tu invitación...</p>
	</body>
</html>
