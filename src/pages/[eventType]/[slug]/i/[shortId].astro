---
// src/pages/[eventType]/[slug]/i/[shortId].astro
export const prerender = false;

import { getInvitationContextByShortId } from '@/lib/rsvp/service';

const { shortId } = Astro.params;

if (!shortId) {
	return Astro.redirect('/404');
}

try {
	const result = await getInvitationContextByShortId(shortId);
	void result; // TypeScript workaround for unused variable warning

	// Canonical URL now points to the landing page with the invite parameter
	// Pattern: /{eventType}/{slug}?invite={inviteId}
	return Astro.redirect(`/${result.eventType}/${result.eventSlug}?invite=${result.inviteId}`);
} catch (error) {
	console.error('[ShortID Resolution] Error:', error);
	return Astro.redirect('/404');
}
---

<html>
	<head>
		<title>Redirigiendo...</title>
	</head>
	<body>
		<p>Cargando tu invitación...</p>
	</body>
</html>
