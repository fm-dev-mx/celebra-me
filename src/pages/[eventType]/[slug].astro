---
// src/pages/[eventType]/[slug].astro
export const prerender = false;

import InvitationSections from '@/components/invitation/InvitationSections.astro';
import { getRoutableEventEntry } from '@/lib/content/events';
import { prepareInvitationPageData } from '@/lib/invitation/page-data';
import { getInvitationContextByInviteId, trackInvitationView } from '@/lib/rsvp/service';
import Layout from '@/layouts/Layout.astro';
import '@/styles/invitation.scss';
import Footer from '@/components/invitation/Footer.astro';
import Hero from '@/components/invitation/Hero.astro';
import MusicPlayer from '@/components/invitation/MusicPlayer';
import EventHeader from '@/components/invitation/EventHeader.astro';
import EnvelopeReveal from '@/components/invitation/EnvelopeReveal';

// --- Page Logic (Adapter Pattern) ---
const { eventType, slug } = Astro.params;
const inviteId = Astro.url.searchParams.get('invite');
const eventOverrideStyles = import.meta.glob('/src/styles/events/*.scss');

const eventEntry = await getRoutableEventEntry(slug as string, eventType as string);

if (!eventEntry) {
	return Astro.redirect('/404');
}

const canonicalEventType = eventEntry.data.eventType;
if (eventType !== canonicalEventType) {
	const canonicalUrl = new URL(`/${canonicalEventType}/${slug as string}`, Astro.url);
	if (inviteId) {
		canonicalUrl.searchParams.set('invite', inviteId);
	}
	return Astro.redirect(canonicalUrl.pathname + canonicalUrl.search, 301);
}

const eventOverrideImporter = eventOverrideStyles[`/src/styles/events/${slug as string}.scss`];
if (eventOverrideImporter) {
	await eventOverrideImporter();
}

// Guest Context Retrieval
let guestContext = null;
if (inviteId) {
	try {
		guestContext = await getInvitationContextByInviteId(inviteId);
		// Telemetry: Record that the invitation was viewed
		void trackInvitationView(inviteId);
	} catch (e) {
		console.error('[Personalization] Failed to load guest context:', e);
	}
}

const presenter = prepareInvitationPageData({
	eventEntry,
	slug: slug as string,
	guestContext,
});
---

<Layout
	title={presenter.layout.title}
	description={presenter.layout.description}
	image={presenter.layout.image}
	hideHeader={true}
	className={presenter.layout.className}
>
	<style is:inline lang="scss" set:html={presenter.wrapper.scopedStyles} />
	<main class={presenter.wrapper.className} {...presenter.wrapper.dataAttributes}>
		<!-- Scripts -->
		<script is:inline define:vars={{ eventSlug: presenter.eventSlug }}>
			// Legacy Token Resolution
			const legacyToken = new URLSearchParams(window.location.search).get('t');
			if (legacyToken) {
				const params = new URLSearchParams({
					eventSlug,
					token: legacyToken,
				});
				fetch(`/api/invitacion/resolve?${params.toString()}`)
					.then((response) => (response.ok ? response.json() : null))
					.then((payload) => {
						if (payload?.canonicalUrl) {
							window.location.replace(payload.canonicalUrl);
						}
					})
					.catch(() => { /* silent fallback */ });
			}
		</script>

		{presenter.wrapper.showEnvelope && (
			<script is:inline define:vars={{ eventSlug: presenter.eventSlug }}>
				// Sync unlock
				const key = `envelope-opened-${eventSlug}`;
				if (localStorage.getItem(key) === 'true') {
					document.body.classList.add('invitation-revealed');
				}
			</script>
		)}

		<!-- Components -->
		{
			presenter.envelope && (
				<EnvelopeReveal
					client:load
					name={presenter.envelope.name}
					date={presenter.envelope.date}
					city={presenter.envelope.city}
					sealStyle={presenter.envelope.sealStyle}
					sealIcon={presenter.envelope.sealIcon as 'boot' | 'heart' | 'monogram' | 'flower' | undefined}
					microcopy={presenter.envelope.microcopy}
					documentLabel={presenter.envelope.documentLabel}
					stampText={presenter.envelope.stampText}
					stampYear={presenter.envelope.stampYear}
					tooltipText={presenter.envelope.tooltipText}
					eventSlug={presenter.envelope.eventSlug}
					variant={presenter.envelope.variant}
					guestName={presenter.envelope.guestName}
				/>
			)
		}

		<EventHeader
			eventName={presenter.header.eventName}
			theme={presenter.header.theme}
			links={presenter.header.links}
			variant={presenter.header.variant}
		/>

		<Hero {...presenter.hero} />

		<InvitationSections presenter={presenter} />

		<Footer
			eventSlug={presenter.footer.eventSlug}
			showEnvelope={presenter.footer.showEnvelope}
		/>

		{presenter.music && (
			<MusicPlayer
				client:idle
				url={presenter.music.url}
				autoPlay={presenter.music.autoPlay}
				title={presenter.music.title}
				revealMode={presenter.music.revealMode}
				variant={presenter.music.variant}
			/>
		)}
	</main>
</Layout>
