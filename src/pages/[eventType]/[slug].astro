---
// src/pages/[eventType]/[slug].astro
export const prerender = false;

import InvitationSections from '@/components/invitation/InvitationSections.astro';
import { getRoutableEventEntry } from '@/lib/content/events';
import { prepareInvitationPageData } from '@/lib/invitation/page-data';
import { getInvitationContextByInviteId } from '@/lib/rsvp/services/invitation-context.service';
import { trackInvitationView } from '@/lib/rsvp/services/rsvp-submission.service';
import Layout from '@/layouts/Layout.astro';
import '@/styles/invitation.scss';
import Footer from '@/components/invitation/Footer.astro';
import Hero from '@/components/invitation/Hero.astro';
import MusicPlayer from '@/components/invitation/MusicPlayer.astro';
import EventHeader from '@/components/invitation/EventHeader.astro';
import EnvelopeReveal from '@/components/invitation/EnvelopeReveal.astro';

const { eventType, slug } = Astro.params;
const inviteId = Astro.url.searchParams.get('invite');
const eventOverrideStyles = import.meta.glob('/src/styles/events/*.scss');

const eventEntry = await getRoutableEventEntry(slug as string, eventType as string);

if (!eventEntry) {
	return Astro.redirect('/404');
}

const canonicalEventType = eventEntry.data.eventType;
if (eventType !== canonicalEventType) {
	const canonicalUrl = new URL(`/${canonicalEventType}/${slug as string}`, Astro.url);
	if (inviteId) {
		canonicalUrl.searchParams.set('invite', inviteId);
	}
	return Astro.redirect(canonicalUrl.pathname + canonicalUrl.search, 301);
}

const eventOverrideImporter = eventOverrideStyles[`/src/styles/events/${slug as string}.scss`];
if (eventOverrideImporter) {
	await eventOverrideImporter();
}

// Guest Context Retrieval
let guestContext = null;
if (inviteId) {
	try {
		guestContext = await getInvitationContextByInviteId(inviteId);
		// Telemetry: Record that the invitation was viewed
		void trackInvitationView(inviteId);
	} catch (e) {
		console.error('[Personalization] Failed to load guest context:', e);
	}
}

const pageData = prepareInvitationPageData({
	eventEntry,
	slug: slug as string,
	guestContext,
});
---

<Layout
	title={pageData.layout.title}
	description={pageData.layout.description}
	image={pageData.layout.image}
	hideHeader={true}
	className={pageData.layout.className}
	isDemo={pageData.isDemo}
	themeMode="dark"
>
	<style is:inline lang="scss" set:html={pageData.wrapper.scopedStyles} />
	<main class={pageData.wrapper.className} {...pageData.wrapper.dataAttributes}>

		<!-- Components -->
		{
			pageData.envelope && (
				<EnvelopeReveal
					name={pageData.envelope.name}
					date={pageData.envelope.date}
					city={pageData.envelope.city}
					sealStyle={pageData.envelope.sealStyle}
					sealIcon={pageData.envelope.sealIcon as 'boot' | 'heart' | 'monogram' | 'flower' | undefined}
					microcopy={pageData.envelope.microcopy}
					documentLabel={pageData.envelope.documentLabel}
					stampText={pageData.envelope.stampText}
					stampYear={pageData.envelope.stampYear}
					tooltipText={pageData.envelope.tooltipText}
					eventSlug={pageData.envelope.eventSlug}
					variant={pageData.envelope.variant}
					guestName={pageData.envelope.guestName}
					titleMaterial={pageData.envelope.titleMaterial}
					detailMaterial={pageData.envelope.detailMaterial}
				/>
			)
		}

		<EventHeader
			eventName={pageData.header.eventName}
			theme={pageData.header.theme}
			links={pageData.header.links}
			variant={pageData.header.variant}
		/>

		<Hero {...pageData.hero} />

		<InvitationSections pageData={pageData} />

		<Footer
			eventSlug={pageData.footer.eventSlug}
			showEnvelope={pageData.footer.showEnvelope}
			variant={pageData.footer.variant}
		/>

		{pageData.music && (
			<MusicPlayer
				url={pageData.music.url}
				autoPlay={pageData.music.autoPlay}
				title={pageData.music.title}
				revealMode={pageData.music.revealMode}
				variant={pageData.music.variant}
			/>
		)}
	</main>
</Layout>
