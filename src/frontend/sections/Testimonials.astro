---
// src/sections/Testimonials.astro
import Container from '@components/layout/Container.astro';
import Section from '@components/layout/Section.legacy.astro';
import SectionTitle from '@components/typography/SectionTitle.legacy.astro';
import TestimonialsCarousel from '@components/ui/TestimonialsCarousel';
import type { LegacyTestimonialsData } from '@/core/interfaces/data/landingPage.legacy.interface';
import ActionIcon from '@/frontend/components/common/actions/ActionIcon.legacy';

// Define the props interface for this component
interface Props {
	data: LegacyTestimonialsData;
}

// Destructure the data prop
const { data } = Astro.props;
---

<!-- Testimonials section wrapper -->
<Section id="testimonials-section" fullHeight={true} fullWidth={true}>
	<div id="testimonials"></div>
	<!-- Container wrapper -->
	<Container class="w-full">
		<!-- Section title -->
		<SectionTitle color="text-secondary-dark">
			{data.title}
		</SectionTitle>
		<!-- React TestimonialsCarousel component with client:visible directive for lazy loading -->
		<TestimonialsCarousel {...data} client:visible />
	</Container>

	<!-- Scroll to Pricing Section Button -->
	<ActionIcon
		variant="scroll"
		href="#pricing-section"
		title="Ir a la sección de Precios"
		color="accent"
		icon="ArrowDownIcon"
	/>
</Section>
