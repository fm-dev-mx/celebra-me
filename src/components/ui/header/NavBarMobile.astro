---
interface NavLink {
	label: string;
	href: string;
}

interface Props {
	headerId: string;
	links?: NavLink[];
	loginLink?: string;
	ctaLink?: string;
	loginLabel?: string;
	ctaLabel?: string;
	desktopBreakpoint?: 'lg' | 'xl';
	eventName?: string;
	eventSubtitle?: string;
}


const {
	headerId,
	links = [],
	loginLink,
	ctaLink,
	loginLabel = 'Iniciar sesión',
	ctaLabel = 'Crear Invitación',
	desktopBreakpoint = 'lg',
	eventName,
	eventSubtitle,
} = Astro.props;
const menuId = `${headerId}-mobile-menu`;
	const desktopBreakpointPx = desktopBreakpoint === 'xl' ? 1200 : 992;
	const staggerClass = (index: number) => `mobile-nav-stagger-${index}`;
---

<div
	data-nav-mobile
	data-header-id={headerId}
	data-desktop-breakpoint={desktopBreakpointPx}
>
	<button
		type="button"
		class="header-base__mobile-toggle"
		aria-label="Abrir menú"
		aria-expanded="false"
		aria-controls={menuId}
		data-nav-mobile-toggle
	>
		<div class="hamburger">
			<span class="hamburger__line"></span>
			<span class="hamburger__line"></span>
			<span class="hamburger__line"></span>
		</div>
	</button>

	<div class="header-base__mobile-overlay" hidden data-nav-mobile-overlay></div>

	<nav
		id={menuId}
		class="header-base__mobile-menu"
		hidden
		data-nav-mobile-menu
		aria-label="Navegación móvil"
	>
		{eventName && (
			<header class="mobile-nav-header">
				<p class="mobile-nav-header__name">{eventName}</p>
				{eventSubtitle && <p class="mobile-nav-header__subtitle">{eventSubtitle}</p>}
			</header>
		)}
		<div class="mobile-nav-links">
			{
				links.map((link, index) => (
					<a
						href={link.href}
						class:list={['mobile-nav-links__link', staggerClass(index)]}
						data-label={link.label.split(' · ')[0]}
						data-nav-mobile-link
					>
						{link.label.includes(' · ') ? link.label.split(' · ')[1] : link.label}
					</a>
				))
			}
		</div>

		<div class="mobile-nav-footer">
			<div class="mobile-nav-footer__divider"></div>
			{
				(loginLink || ctaLink) && (
					<div class="mobile-nav-actions">
						{loginLink && (
							<a
								href={loginLink}
								class:list={['mobile-nav-actions__login', staggerClass(links.length)]}
								data-nav-mobile-link
							>
								{loginLabel}
							</a>
						)}
						{ctaLink && (
							<a
								href={ctaLink}
								class:list={['mobile-nav-actions__cta', staggerClass(links.length + 1)]}
								data-nav-mobile-link
							>
								{ctaLabel}
							</a>
						)}
					</div>
				)
			}

			<div class="mobile-nav-signature">
				<p class="mobile-nav-footer__copy">CELEBRA-ME © 2026</p>
			</div>
		</div>
	</nav>
</div>

<script>
	const navRoots = Array.from(document.querySelectorAll('[data-nav-mobile]')) as HTMLElement[];

	navRoots.forEach((root) => {
		const headerId = root.dataset.headerId;
		const header = headerId ? document.getElementById(headerId) : null;
		const toggle = root.querySelector('[data-nav-mobile-toggle]');
		const menu = root.querySelector('[data-nav-mobile-menu]');
		const overlay = root.querySelector('[data-nav-mobile-overlay]');
		const links = Array.from(root.querySelectorAll('[data-nav-mobile-link]'));

		if (
			!(toggle instanceof HTMLButtonElement) ||
			!(menu instanceof HTMLElement) ||
			!(overlay instanceof HTMLElement)
		) {
			return;
		}

		const closeMenu = () => {
			toggle.setAttribute('aria-expanded', 'false');
			menu.hidden = true;
			overlay.hidden = true;
			if (header) {
				header.classList.remove('header-base--menu-open');
			}
			document.body.style.overflow = '';
		};

		const breakpoint = Number(root.dataset.desktopBreakpoint || '992');
		const desktopQuery = window.matchMedia(`(min-width: ${breakpoint}px)`);

		const openMenu = () => {
			if (desktopQuery.matches) {
				closeMenu();
				return;
			}

			toggle.setAttribute('aria-expanded', 'true');
			toggle.setAttribute('aria-label', 'Cerrar menú');
			menu.hidden = false;
			overlay.hidden = false;
			if (header) {
				header.classList.add('header-base--menu-open');
			}
			document.body.style.overflow = 'hidden';
		};

		const syncForViewport = () => {
			if (desktopQuery.matches) {
				closeMenu();
			}
		};

		toggle.addEventListener('click', () => {
			const isOpen = toggle.getAttribute('aria-expanded') === 'true';
			if (isOpen) {
				closeMenu();
			} else {
				openMenu();
			}
		});

		overlay.addEventListener('click', closeMenu);
		links.forEach((link) => link.addEventListener('click', closeMenu));

		window.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
				closeMenu();
			}
		});

		syncForViewport();

		desktopQuery.addEventListener('change', syncForViewport);
	});
</script>
