---
interface FAQ {
	question: string;
	answer: string;
}

interface Props {
	faqs: FAQ[];
}

const { faqs = [] } = Astro.props;

if (!faqs.length) {
	return null;
}
---

<div class="faq-list-container" data-faq-list>
	{
		faqs.map((faq, index) => (
			<div class="faq-item" data-faq-item>
				<button
					id={`faq-question-${index}`}
					class="faq-question-btn"
					type="button"
					aria-expanded="false"
					aria-controls={`faq-answer-${index}`}
				>
					<span class="question-text">{faq.question}</span>
					<span class="chevron-icon" aria-hidden="true">
						<svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor">
							<path d="m6 9 6 6 6-6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
						</svg>
					</span>
				</button>
				<div
					id={`faq-answer-${index}`}
					class="faq-answer-wrapper"
					hidden
					role="region"
					aria-hidden="true"
					aria-labelledby={`faq-question-${index}`}
				>
					<div class="faq-answer-inner">
						<div class="faq-answer-content">
							<p class="answer-text">{faq.answer}</p>
						</div>
					</div>
				</div>
			</div>
		))
	}
</div>

<script>
	const faqList = document.querySelector('[data-faq-list]');

	if (faqList) {
		const items = Array.from(faqList.querySelectorAll('[data-faq-item]'));
		const shouldReduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

		const setAnswerInteractivity = (
			answer: HTMLElement & { inert?: boolean },
			isInteractive: boolean,
		) => {
			if ('inert' in answer) {
				answer.inert = !isInteractive;
			}
		};

		const clearCloseTimer = (answer: HTMLElement) => {
			const closeTimer = answer.dataset.closeTimer;

			if (closeTimer) {
				window.clearTimeout(Number(closeTimer));
				delete answer.dataset.closeTimer;
			}
		};

		const closeItem = (item: Element, immediate = false) => {
			const button = item.querySelector('.faq-question-btn');
			const answer = item.querySelector('.faq-answer-wrapper');

			if (!(button instanceof HTMLButtonElement) || !(answer instanceof HTMLElement)) {
				return;
			}

			button.setAttribute('aria-expanded', 'false');
			answer.setAttribute('aria-hidden', 'true');
			setAnswerInteractivity(answer, false);
			item.classList.remove('is-open');
			clearCloseTimer(answer);

			if (immediate || shouldReduceMotion) {
				answer.hidden = true;
				return;
			}

			answer.hidden = false;
			answer.dataset.closeTimer = String(
				window.setTimeout(() => {
					if (!item.classList.contains('is-open')) {
						answer.hidden = true;
					}

					delete answer.dataset.closeTimer;
				}, 400),
			);
		};

		const openItem = (item: Element) => {
			const button = item.querySelector('.faq-question-btn');
			const answer = item.querySelector('.faq-answer-wrapper');

			if (!(button instanceof HTMLButtonElement) || !(answer instanceof HTMLElement)) {
				return;
			}

			clearCloseTimer(answer);
			answer.hidden = false;
			setAnswerInteractivity(answer, true);

			requestAnimationFrame(() => {
				button.setAttribute('aria-expanded', 'true');
				answer.setAttribute('aria-hidden', 'false');
				item.classList.add('is-open');
			});
		};

		items.forEach((item: Element) => {
			const button = item.querySelector('.faq-question-btn');

			if (!(button instanceof HTMLButtonElement)) {
				return;
			}

			closeItem(item, true);

			button.addEventListener('click', () => {
				const shouldOpen = button.getAttribute('aria-expanded') !== 'true';

				items.forEach((otherItem: Element) => {
					closeItem(otherItem);
				});

				if (shouldOpen) {
					openItem(item);
				}
			});
		});
	}
</script>
