---
/**
 * Logo component with two visual modes:
 * - Default (including 'gold', 'hero', 'xv'): renders the native gold-toned PNG
 * - White ('white', 'footer'): applies CSS brightness(0) invert(1) for dark surfaces
 */
interface Props {
	variant?: 'default' | 'xv' | 'footer' | 'hero' | 'white' | 'gold';
	class?: string;
	altText?: string;
}

import { getCommonAsset } from '@/lib/assets/asset-registry';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const { class: className, variant, altText } = Astro.props;

const logoAsset = getCommonAsset('headerLogo');
const logoSrc = logoAsset?.src;

if (!logoSrc) {
	console.error('Logo asset not found in AssetRegistry');
}

const isWhite = variant === 'white' || variant === 'footer';
---

{
	logoSrc && (
		<Image
			src={logoSrc as ImageMetadata}
			alt={altText || "Celebra.me Logo"}
			width={150}
			height={56}
			class:list={[
				'logo',
				{
					'logo--white': isWhite
				},
				className
			]}
			loading="eager"
		/>
	)
}
