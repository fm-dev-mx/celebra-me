---
import Icon from '@/components/common/icons/Icon.astro';

interface Props {
	className?: string;
	phone?: string;
	message?: string;
	label?: string;
}

const {
	className = '',
	phone = '5215500000000',
	message = '¡Hola! Me gustaría recibir información sobre las invitaciones digitales premium.',
	label = 'Crea tu invitación',
} = Astro.props;

const whatsappUrl = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<a
	href={whatsappUrl}
	target="_blank"
	rel="noopener noreferrer"
	class:list={['whatsapp-button', className]}
	aria-label="Contactar por WhatsApp"
	data-track-event="whatsapp_contact_clicked"
	data-track-section="hero"
	data-track-cta="hero_whatsapp"
	data-track-intent="whatsapp"
>
	<Icon name="WhatsApp" size={20} />
	{label}
</a>
