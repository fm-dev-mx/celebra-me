---
import type { DashboardNavItem } from '@/interfaces/dashboard/admin.interface';
import DashboardUserMenu from './DashboardUserMenu';
interface Props {
	items: DashboardNavItem[];
	currentPath: string;
	isAdmin: boolean;
	userEmail: string;
	roleLabel: 'ADMIN' | 'HOST';
	sidebarId?: string;
}

const { items, currentPath, isAdmin, userEmail, roleLabel, sidebarId = 'dashboard-sidebar' } =
	Astro.props as Props;
const visibleItems = items.filter((item) => !item.adminOnly || isAdmin);
---

<aside
	id={sidebarId}
	class="dashboard-sidebar"
	aria-label="Navegación de dashboard"
>
	<div class="dashboard-sidebar__brand">
		<a href="/dashboard/invitados">Celebra.me Panel</a>
	</div>
	<nav>
		<ul>
			{
				visibleItems.map((item) => (
					<li>
						<a
							href={item.href}
							class:list={{
								active:
									currentPath === item.href ||
									(item.href !== '/dashboard/invitados' &&
										currentPath.startsWith(`${item.href}/`)),
							}}
						>
							{item.label}
						</a>
					</li>
				))
			}
		</ul>
	</nav>
	<DashboardUserMenu client:load email={userEmail} roleLabel={roleLabel} />
</aside>
