---
import DashboardBreadcrumbs from './DashboardBreadcrumbs.astro';
import DashboardUserMenu from './DashboardUserMenu';

interface Crumb {
	label: string;
	href?: string;
}

interface Props {
	title: string;
	breadcrumbs: Crumb[];
	userEmail: string;
	roleLabel: 'ADMIN' | 'HOST';
}

const { title, breadcrumbs, userEmail, roleLabel } = Astro.props as Props;
---

<header class="dashboard-topbar">
	<div class="dashboard-topbar__main">
		<h1>{title}</h1>
		<DashboardBreadcrumbs items={breadcrumbs} />
	</div>
	<DashboardUserMenu client:load email={userEmail} roleLabel={roleLabel} />
</header>
