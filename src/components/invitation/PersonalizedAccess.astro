---
// src/components/invitation/PersonalizedAccess.astro
interface Props {
	maxAllowedAttendees: number;
	guestName: string;
}

const { maxAllowedAttendees, guestName } = Astro.props;

const seatsLabel =
	maxAllowedAttendees === 1 ? 'Lugar reservado' : 'Lugares reservados';

const accessAriaLabel = `Pase de acceso para ${guestName}. ${maxAllowedAttendees} ${seatsLabel.toLowerCase()}.`;
---

<section class="personalized-access" aria-labelledby="personalized-access-title">
	<div class="personalized-access__container">
		<article class="access-card" aria-label={accessAriaLabel}>
			<header class="access-card__header">
				<span class="access-card__eyebrow">Invitación personalizada</span>
				<div class="access-card__seal" aria-hidden="true">
					<svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
						<!-- Minimalist Floral Ornament -->
						<path d="M50 15C55 35 75 50 90 50C75 50 55 65 50 85C45 65 25 50 10 50C25 50 45 35 50 15Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
						<path d="M50 35C52 42 58 48 65 50C58 52 52 58 50 65C48 58 42 52 35 50C42 48 48 42 50 35Z" fill="currentColor" opacity="0.25"/>
						<circle cx="50" cy="50" r="46" stroke="currentColor" stroke-width="0.5" stroke-dasharray="1 3" opacity="0.3"/>
						<circle cx="50" cy="50" r="2" fill="currentColor"/>
					</svg>
				</div>
				<h3 id="personalized-access-title" class="access-card__title">
					Pase de acceso
				</h3>
				<p class="access-card__subtitle">
					Este pase te identifica como invitado y muestra el número de lugares reservados.
				</p>
			</header>

			<div class="access-card__body">
				<div class="access-card__field">
					<span class="access-card__label">Invitado</span>
					<strong class="access-card__guest">{guestName}</strong>
				</div>

				<div class="access-card__divider" aria-hidden="true"></div>

				<div class="access-card__quota">
					<span class="access-card__label">{seatsLabel}</span>
					<div class="access-card__count-frame">
						<span class="access-card__count">{maxAllowedAttendees}</span>
					</div>
				</div>
			</div>

			<footer class="access-card__footer">
				<p>
					Confirma tu asistencia en la sección de RSVP al final de la
					invitación.
				</p>
			</footer>
		</article>
	</div>
</section>

<style lang="scss">
	.personalized-access {
		padding: clamp(2.75rem, 7vw, 4.5rem) 1.25rem;
		background: transparent;

		&__container {
			width: min(100%, 32rem);
			margin-inline: auto;
		}
	}

	.access-card {
		position: relative;
		width: 100%;
		overflow: hidden;
		isolation: isolate;
		border-radius: 0.875rem;
		border: 1px solid
			var(--hero-card-border-hairline, var(--color-border-premium));
		background:
			linear-gradient(
				180deg,
				rgb(255 255 255 / 38%) 0%,
				transparent 26%,
				rgb(255 255 255 / 14%) 100%
			),
			var(--family-texture-image, none),
			var(--color-surface-elevated);
		background-position: center;
		background-size: auto, cover, auto;
		box-shadow:
			inset 0 1px 0 rgb(255 255 255 / 65%),
			inset 0 0 0 1px rgb(255 255 255 / 12%),
			0 18px 50px rgb(25 18 24 / 14%),
			var(--hero-card-shadow-ambient, var(--shadow-premium));

		&::before {
			content: '';
			position: absolute;
			inset: 0.625rem;
			border: 1px solid rgb(255 255 255 / 52%);
			border-radius: 0.625rem;
			pointer-events: none;
			z-index: 0;
		}

		&::after {
			content: '';
			position: absolute;
			inset: 0;
			background:
				radial-gradient(
					circle at top center,
					rgb(255 255 255 / 34%),
					transparent 38%
				),
				linear-gradient(180deg, transparent 0%, rgb(255 255 255 / 10%) 100%);
			pointer-events: none;
			z-index: 0;
		}

		> * {
			position: relative;
			z-index: 1;
		}

		&__header {
			padding: 2.25rem 1.75rem 1.5rem;
			text-align: center;
			display: grid;
			gap: 0.75rem;
		}

		&__eyebrow {
			font-family: var(--font-body, serif);
			font-size: 0.68rem;
			line-height: 1;
			letter-spacing: 0.24em;
			text-transform: uppercase;
			color: var(--color-text-muted);
		}

		&__seal {
			width: 3.5rem;
			aspect-ratio: 1;
			margin-inline: auto;
			position: relative;
			display: grid;
			place-items: center;
			color: var(--color-action-accent);
			border-radius: 50%;
			background: transparent;
			padding: 0.5rem;
			transition: all 0.5s var(--ease-premium, ease);

			&::before {
				content: '';
				position: absolute;
				inset: 0;
				border-radius: 50%;
				background: var(--color-action-accent);
				opacity: 0.04;
				transition: opacity 0.4s ease;
			}

			svg {
				width: 100%;
				height: 100%;
				opacity: 0.8;
				transition: transform 0.6s var(--ease-premium);
			}

			&:hover {
				&::before {
					opacity: 0.12;
				}
				
				svg {
					transform: scale(1.15) rotate(15deg);
					opacity: 1;
				}
			}
		}

		&__title {
			margin: 0;
			font-family: var(--font-display, serif);
			font-size: clamp(1.35rem, 2vw + 1rem, 1.9rem);
			font-weight: 500;
			line-height: 1.1;
			letter-spacing: 0.18em;
			text-transform: uppercase;
			color: var(--color-text-emphasis);
		}

		&__subtitle {
			max-width: 20rem;
			margin: 0 auto;
			font-family: var(--font-body, serif);
			font-size: 0.85rem;
			line-height: 1.6;
			color: var(--color-text-secondary);
		}

		&__body {
			padding: 1.5rem 1.75rem 2rem;
			display: grid;
			gap: 1.5rem;
		}

		&__field,
		&__quota {
			display: grid;
			gap: 0.625rem;
			text-align: center;
			justify-items: center;
		}

		&__label {
			font-family: var(--font-body, serif);
			font-size: 0.72rem;
			line-height: 1.2;
			letter-spacing: 0.24em;
			text-transform: uppercase;
			color: var(--color-text-muted);
		}

		&__guest {
			margin: 0;
			max-width: 16ch;
			font-family: var(--font-display, serif);
			font-size: clamp(1.9rem, 4vw + 1rem, 2.6rem);
			font-weight: 400;
			line-height: 0.95;
			color: var(--color-text-primary);
			text-wrap: balance;
			overflow-wrap: anywhere;
		}

		&__divider {
			position: relative;
			height: 1px;
			margin: 0.25rem 0;
			background: linear-gradient(
				90deg,
				transparent 0%,
				var(--hero-divider-color) 18%,
				var(--hero-divider-color) 82%,
				transparent 100%
			);
			opacity: 0.9;

			&::after {
				content: '';
				position: absolute;
				top: 50%;
				left: 50%;
				width: 0.55rem;
				height: 0.55rem;
				transform: translate(-50%, -50%) rotate(45deg);
				background: var(--color-surface-elevated);
				border: 1px solid var(--hero-divider-color);
				box-shadow: 0 0 0 0.2rem rgb(255 255 255 / 28%);
			}
		}

		&__count-frame {
			min-width: 8.5rem;
			padding: 1rem 1.5rem 1.1rem;
			border-radius: 1.125rem;
			border: 1px solid rgb(255 255 255 / 54%);
			background: linear-gradient(
				180deg,
				rgb(255 255 255 / 44%),
				rgb(255 255 255 / 12%)
			);
			box-shadow:
				inset 0 1px 0 rgb(255 255 255 / 70%),
				0 12px 30px rgb(25 18 24 / 8%);
		}

		&__count {
			display: block;
			font-family: var(--font-display, serif);
			font-size: clamp(3.25rem, 9vw, 4.75rem);
			line-height: 0.85;
			color: var(--color-text-emphasis);
		}

		&__footer {
			padding: 1.25rem 1.75rem 1.75rem;
			text-align: center;
			border-top: 1px solid rgb(255 255 255 / 42%);
			background: linear-gradient(
				180deg,
				rgb(255 255 255 / 8%),
				rgb(255 255 255 / 16%)
			);

			p {
				max-width: 22rem;
				margin: 0 auto;
				font-family: var(--font-body, serif);
				font-size: 0.9rem;
				line-height: 1.65;
				color: var(--color-text-secondary);
				font-style: italic;
			}
		}
	}

	@media (max-width: 480px) {
		.access-card {
			border-radius: 0.75rem;

			&::before {
				inset: 0.5rem;
				border-radius: 0.5rem;
			}

			&__header {
				padding: 2rem 1.25rem 1.35rem;
			}

			&__body {
				padding: 1.35rem 1.25rem 1.75rem;
			}

			&__footer {
				padding: 1.15rem 1.25rem 1.5rem;
			}

			&__title {
				letter-spacing: 0.14em;
			}

			&__guest {
				max-width: 13ch;
			}

			&__count-frame {
				min-width: 7.5rem;
				padding-inline: 1.25rem;
			}
		}
	}
</style>
