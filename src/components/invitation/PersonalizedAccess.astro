---
// src/components/invitation/PersonalizedAccess.astro
interface Props {
	maxAllowedAttendees: number;
	guestName: string;
	isDemoPreview?: boolean;
	variant?: string;
}

const {
	maxAllowedAttendees,
	guestName,
	isDemoPreview,
	variant = 'standard'
} = Astro.props;

const seatsLabel =
	maxAllowedAttendees === 1 ? 'Lugar reservado' : 'Lugares reservados';

const accessAriaLabel = `Pase de acceso para ${guestName}. ${maxAllowedAttendees} ${seatsLabel.toLowerCase()}.`;

// Decorative ornaments are variant-specific
const showOrnaments = variant !== 'standard';
---

<section
	class="personalized-access"
	aria-labelledby="personalized-access-title"
	data-variant={variant}
>
	<div class="personalized-access__container">
		{isDemoPreview && variant === 'editorial-magazine' && (
			<div class="personalized-access__demo-badge" aria-hidden="true">
				VISTA PREVIA DEMO
			</div>
		)}
		<article class="access-card" aria-label={accessAriaLabel}>
			{
				showOrnaments && (
					<div class="access-card__ornaments" aria-hidden="true">
						<div class="access-card__corner access-card__corner--tl" />
						<div class="access-card__corner access-card__corner--tr" />
						<div class="access-card__corner access-card__corner--bl" />
						<div class="access-card__corner access-card__corner--br" />
					</div>
				)
			}

			<header class="access-card__header">
				<span class="access-card__eyebrow" data-demo-label>
					{isDemoPreview && variant !== 'editorial-magazine' ? 'Vista previa demo' : 'Invitación personalizada'}
				</span>
				<div class="access-card__seal" aria-hidden="true">
					<svg
						viewBox="0 0 100 100"
						fill="none"
						xmlns="http://www.w3.org/2000/svg"
					>
						<path
							d="M50 15C55 35 75 50 90 50C75 50 55 65 50 85C45 65 25 50 10 50C25 50 45 35 50 15Z"
							stroke="currentColor"
							stroke-width="1.2"
							stroke-linejoin="round"></path>
						<path
							d="M50 35C52 42 58 48 65 50C58 52 52 58 50 65C48 58 42 52 35 50C42 48 48 42 50 35Z"
							fill="currentColor"
							opacity="0.25"></path>
						<circle
							cx="50"
							cy="50"
							r="46"
							stroke="currentColor"
							stroke-width="0.5"
							stroke-dasharray="1 3"
							opacity="0.3"></circle>
						<circle cx="50" cy="50" r="2" fill="currentColor"></circle>
					</svg>
				</div>
				<h3 id="personalized-access-title" class="access-card__title">
					Pase de acceso
				</h3>
				<p class="access-card__subtitle">
					Este pase te identifica como invitado y muestra el número de lugares
					reservados.
				</p>
			</header>

			<div class="access-card__body">
				<div class="access-card__field">
					<span class="access-card__label">Invitado</span>
					<strong class="access-card__guest">{guestName}</strong>
				</div>

				<div class="access-card__divider" aria-hidden="true"></div>

				<div class="access-card__quota">
					<span class="access-card__label">{seatsLabel}</span>
					<div class="access-card__count-frame">
						<span class="access-card__count">{maxAllowedAttendees}</span>
					</div>
				</div>
			</div>

			{variant === 'editorial-magazine' && (
				<div class="access-card__barcode-wrapper" aria-hidden="true">
					<div class="access-card__barcode"></div>
					<span class="access-card__serial">
						ED-XV · {guestName ? guestName.toUpperCase().split(/\s+/)[0] : 'INVITADO'} · 2027
					</span>
				</div>
			)}

			<footer class="access-card__footer">
				<p>
					Confirma tu asistencia en la sección de RSVP al final de la
					invitación.
				</p>
			</footer>
		</article>
	</div>
</section>
