---
/* eslint-disable no-restricted-syntax -- item-level focal points must override theme crop fallbacks */
import type { ImageMetadata } from 'astro';
import type { ImageAsset } from '@/lib/assets/asset-registry';
import { getLayoutClass } from '@/lib/components/gallery/getLayoutClass';

interface GalleryItem {
	image: ImageMetadata | ImageAsset;
	caption?: string;
	key?: string;
	focalPoint?: string;
	focalPointMobile?: string;
	focalPointTablet?: string;
	focalPointDesktop?: string;
}

interface Props {
	items: GalleryItem[];
	variant?: string;
}

const { items, variant = 'standard' } = Astro.props;

const resolveImage = (image: ImageMetadata | ImageAsset) => {
	const src = typeof image.src === 'string' ? image.src : image.src.src;
	const meta = 'width' in image ? image : (typeof image.src !== 'string' ? image.src : null);
	return { src, width: meta?.width ?? 800, height: meta?.height ?? 1000 };
};
---

<div class="gallery-grid" data-gallery data-variant={variant}>
	{
		items.map((item, index) => {
			const { src, width, height } = resolveImage(item.image);
			return (
			<div
				class:list={['gallery-grid__item', getLayoutClass(index, variant)]}
				data-gallery-item
				data-gallery-index={index}
				data-image-key={item.key}
				data-gallery-src={src}
				data-gallery-caption={item.caption ?? ''}
				style={`${item.focalPoint ? `--gallery-item-focal-point: ${item.focalPoint};` : ''}${item.focalPointMobile ? `--gallery-item-focal-point-mobile: ${item.focalPointMobile};` : ''}${item.focalPointTablet ? `--gallery-item-focal-point-tablet: ${item.focalPointTablet};` : ''}${item.focalPointDesktop ? `--gallery-item-focal-point-desktop: ${item.focalPointDesktop};` : ''}`}
				tabindex="0"
				role="button"
				aria-label={item.caption || `Ver imagen ${index + 1}`}
			>
			<img
					src={src}
					alt={item.caption || `Imagen ${index + 1}`}
					width={width}
					height={height}
					loading="lazy"
				/>
				{item.caption && (
					<div class="gallery-grid__overlay">
						<p class="gallery-grid__caption">{item.caption}</p>
					</div>
				)}
			</div>
			);
		})
	}
</div>

<script>
	const initGallery = () => {
		const gallery = document.querySelector('[data-gallery]');
		if (!gallery) return;
		const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		const galleryItems = Array.from(gallery.querySelectorAll('[data-gallery-item]'));

		if (prefersReducedMotion || !('IntersectionObserver' in window)) {
			galleryItems.forEach((item) => {
				(item as HTMLElement).dataset.inView = 'true';
			});
		} else {
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							const item = entry.target as HTMLElement;
							item.dataset.inView = 'true';
							observer.unobserve(item);
						}
					});
				},
				{ threshold: 0.18, rootMargin: '0px 0px -8% 0px' },
			);

			galleryItems.forEach((item) => observer.observe(item));
		}

		const invitationRoot = gallery.closest('[data-event-slug]');

		const openLightbox = (item: HTMLElement) => {
			if (
				invitationRoot instanceof HTMLElement &&
				invitationRoot.dataset.revealState !== 'revealed'
			) {
				return;
			}
			document.dispatchEvent(
				new CustomEvent('gallery:open', {
					detail: {
						src: item.dataset.gallerySrc || '',
						caption: item.dataset.galleryCaption || '',
						alt: item.getAttribute('aria-label') || ''
					}
				})
			);
		};

		galleryItems.forEach((item) => {
			const htmlItem = item as HTMLElement;
			htmlItem.addEventListener('click', () => openLightbox(htmlItem));
			htmlItem.addEventListener('keydown', (event: KeyboardEvent) => {
				if (event.key === 'Enter' || event.key === ' ') {
					event.preventDefault();
					openLightbox(htmlItem);
				}
			});
		});
	};

	initGallery();
</script>

