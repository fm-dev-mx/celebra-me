---
import type { ImageMetadata } from 'astro';
import type { ImageAsset } from '@/lib/assets/asset-registry';
import { getLayoutClass, getLayoutData } from '@/lib/components/gallery/getLayoutClass';

interface GalleryItem {
	image: ImageMetadata | ImageAsset;
	caption?: string;
}

interface Props {
	items: GalleryItem[];
	variant?: string;
}

const { items, variant = 'standard' } = Astro.props;

type NestedSrc = { src: string };
const hasNestedSrc = (value: unknown): value is NestedSrc =>
	typeof value === 'object' && value !== null && 'src' in value && typeof value.src === 'string';

const getSrc = (image: ImageMetadata | ImageAsset): string => {
	if ('src' in image) {
		const src = image.src as unknown;
		if (typeof src === 'string') return src;
		if (hasNestedSrc(src)) return src.src;
	}

	return String(image);
};
---

<div class="gallery-grid" data-gallery data-variant={variant}>
	{
		items.map((item, index) => {
			const data = getLayoutData(index, variant);
			return (
				<div
					class:list={['gallery-grid__item', getLayoutClass(index, variant)]}
					data-gallery-item
					data-gallery-index={index}
					data-gallery-src={getSrc(item.image)}
					data-gallery-caption={item.caption ?? ''}
					data-gallery-position={data?.positionDesktop ? JSON.stringify(data.positionDesktop) : ''}
					data-gallery-img-x={data?.imagePosition?.x}
					data-gallery-img-y={data?.imagePosition?.y}
					tabindex="0"
					role="button"
					aria-label={item.caption || `Ver imagen ${index + 1}`}
				>
					<img src={getSrc(item.image)} alt={item.caption || `Galería ${index + 1}`} loading="lazy" />
					{item.caption && (
						<div class="gallery-grid__overlay">
							<p class="gallery-grid__caption">{item.caption}</p>
						</div>
					)}
				</div>
			);
		})
	}
</div>

<div class="gallery-lightbox" data-gallery-lightbox hidden role="dialog" aria-modal="true" aria-label="Vista ampliada de la imagen">
	<button type="button" class="gallery-lightbox__close" data-gallery-close aria-label="Cerrar galería">
		<svg
			xmlns="http://www.w3.org/2000/svg"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="1.5"
			stroke-linecap="round"
			stroke-linejoin="round"
		>
			<line x1="18" y1="6" x2="6" y2="18" />
			<line x1="6" y1="6" x2="18" y2="18" />
		</svg>
	</button>

	<div class="gallery-lightbox__content" data-gallery-content>
		<img src="" alt="" data-gallery-image />
		<div class="gallery-lightbox__footer" data-gallery-footer hidden>
			<p data-gallery-footer-text></p>
		</div>
	</div>
</div>

<script>
	const initGallery = () => {
		const gallery = document.querySelector('[data-gallery]');
		if (!gallery) return;

		gallery.querySelectorAll('[data-gallery-item]').forEach((item) => {
			const htmlItem = item as HTMLElement;
			const positionStr = htmlItem.dataset.galleryPosition;
			if (positionStr) {
				try {
					const pos = JSON.parse(positionStr);
					if (pos.column) htmlItem.style.gridColumn = pos.column;
					if (pos.row) htmlItem.style.gridRow = pos.row;
					if (pos.marginTop) htmlItem.style.marginTop = pos.marginTop;
					if (pos.zIndex) htmlItem.style.zIndex = String(pos.zIndex);
				} catch (e) {
					console.warn('[Gallery] Invalid position data:', e);
				}
			}
			const imgX = htmlItem.dataset.galleryImgX;
			const imgY = htmlItem.dataset.galleryImgY;
			if (imgX && imgY) {
				const img = htmlItem.querySelector('img');
				if (img) img.style.objectPosition = `${imgX} ${imgY}`;
			}
		});

		const lightbox = document.querySelector('[data-gallery-lightbox]');
		if (!(lightbox instanceof HTMLElement)) return;

		const lightboxImage = lightbox.querySelector<HTMLImageElement>('[data-gallery-image]');
		const lightboxFooter = lightbox.querySelector<HTMLElement>('[data-gallery-footer]');
		const lightboxFooterText = lightbox.querySelector<HTMLElement>('[data-gallery-footer-text]');
		const closeButton = lightbox.querySelector<HTMLButtonElement>('[data-gallery-close]');
		const content = lightbox.querySelector<HTMLElement>('[data-gallery-content]');

		if (!lightboxImage || !lightboxFooter || !lightboxFooterText || !closeButton || !content) {
			return;
		}

		const invitationRoot = gallery.closest('[data-event-slug]');
		const focusableSelectors = 'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';
		let lastFocusedElement: HTMLElement | null = null;

		const getFocusableElements = () =>
			Array.from(lightbox.querySelectorAll<HTMLElement>(focusableSelectors)).filter(
				(el) => !el.hasAttribute('disabled') && el.offsetParent !== null
			);

		const trapFocus = (e: KeyboardEvent) => {
			if (e.key !== 'Tab') return;
			const focusable = getFocusableElements();
			if (focusable.length === 0) return;
			const first = focusable[0];
			const last = focusable[focusable.length - 1];
			if (e.shiftKey && document.activeElement === first) {
				e.preventDefault();
				last.focus();
			} else if (!e.shiftKey && document.activeElement === last) {
				e.preventDefault();
				first.focus();
			}
		};

		const closeLightbox = () => {
			lightbox.hidden = true;
			document.body.style.overflow = '';
			lightbox.removeEventListener('keydown', trapFocus);
			lastFocusedElement?.focus();
		};

		const openLightbox = (item: HTMLElement) => {
			if (
				invitationRoot instanceof HTMLElement &&
				invitationRoot.dataset.revealState !== 'revealed'
			) {
				return;
			}

			lastFocusedElement = document.activeElement as HTMLElement;
			lightboxImage.src = item.dataset.gallerySrc || '';
			lightboxImage.alt = item.dataset.galleryCaption || item.getAttribute('aria-label') || '';

			const caption = item.dataset.galleryCaption || '';
			lightboxFooterText.textContent = caption;
			lightboxFooter.hidden = !caption;

			lightbox.hidden = false;
			document.body.style.overflow = 'hidden';
			lightbox.addEventListener('keydown', trapFocus);
			requestAnimationFrame(() => closeButton.focus());
		};

		gallery.querySelectorAll('[data-gallery-item]').forEach((item) => {
			const htmlItem = item as HTMLElement;
			htmlItem.addEventListener('click', () => openLightbox(htmlItem));
			htmlItem.addEventListener('keydown', (event: KeyboardEvent) => {
				if (event.key === 'Enter' || event.key === ' ') {
					event.preventDefault();
					openLightbox(htmlItem);
				}
			});
		});

		closeButton.addEventListener('click', (event) => {
			event.stopPropagation();
			closeLightbox();
		});
		lightbox.addEventListener('click', closeLightbox);
		content.addEventListener('click', (event) => event.stopPropagation());

		window.addEventListener('keydown', (event: KeyboardEvent) => {
			if (event.key === 'Escape' && !lightbox.hidden) {
				closeLightbox();
			}
		});
	};

	initGallery();
</script>
