---
import '@/styles/invitation/_interlude.scss';
import OptimizedImage from '@/components/common/OptimizedImage.astro';
import type { ImageAsset } from '@/lib/assets/asset-registry';
import type { SharedSectionVariant } from '@/lib/theme/theme-contract';

interface Props {
	image: ImageAsset;
	alt?: string;
	height?: 'screen' | 'tall';
	variant?: SharedSectionVariant;
	focalPoint?: string;
	lightX?: string;
	lightY?: string;
	overlayOpacity?: string;
	interludeIndex?: number;
}

const {
	image,
	alt = '',
	height = 'screen',
	variant = 'standard',
	focalPoint,
	lightX,
	lightY,
	overlayOpacity,
	interludeIndex,
} = Astro.props;

// Prioritize first interlude for LCP if it's likely to be above/near fold.
const shouldPrioritizeImage = interludeIndex === 0 || interludeIndex === 1;
---

<section
	class="invitation-interlude"
	data-variant={variant}
	data-height={height}
	data-interlude-index={interludeIndex}
	data-focal-point={focalPoint}
	data-light-x={lightX}
	data-light-y={lightY}
	data-overlay-opacity={overlayOpacity}
	aria-label={alt}
>
	<div class="invitation-interlude__media">
		<OptimizedImage
			imagePath={image}
			alt={alt}
			width={1920}
			height={1400}
			class="invitation-interlude__image"
			loading={shouldPrioritizeImage ? 'eager' : 'lazy'}
			decoding="async"
			fetchpriority={shouldPrioritizeImage ? 'high' : 'auto'}
		/>
	</div>
</section>
<script>
import { initInterludeObserver } from '@/lib/invitation/interlude-observer';
initInterludeObserver();
</script>
