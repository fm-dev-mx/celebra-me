---
import '@/styles/invitation/_interlude.scss';
import OptimizedImage from '@/components/common/OptimizedImage.astro';
import type { ImageAsset } from '@/lib/assets/asset-registry';
import type { SharedSectionVariant } from '@/lib/theme/theme-contract';

interface Props {
	image: ImageAsset;
	alt: string;
	height?: 'screen' | 'tall';
	variant?: SharedSectionVariant;
	focalPoint?: string;
}

const { image, alt, height = 'screen', variant = 'standard', focalPoint } = Astro.props;
---

<section
	class="invitation-interlude"
	data-variant={variant}
	data-height={height}
	aria-label={alt}
>
	<style define:vars={{ focalPoint: focalPoint || 'center' }}>
		.invitation-interlude {
			--interlude-focal-point: var(--focalPoint);
		}
	</style>
	<div class="invitation-interlude__media">
		<OptimizedImage
			imagePath={image}
			alt={alt}
			width={1920}
			height={1400}
			class="invitation-interlude__image"
		/>
	</div>
</section>
<script>
	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
	const interludes = Array.from(document.querySelectorAll('.invitation-interlude'));

	if (!prefersReducedMotion && interludes.length > 0) {
		const updateParallax = () => {
			for (const interlude of interludes) {
				if (!(interlude instanceof HTMLElement)) {
					continue;
				}

				const variant = interlude.dataset.variant ?? '';
				if (
					!variant.includes('premium') &&
					variant !== 'editorial' &&
					!variant.startsWith('premiere-')
				) {
					continue;
				}

				const rect = interlude.getBoundingClientRect();
				const viewportCenter = window.innerHeight / 2;
				const offset = (rect.top + rect.height / 2 - viewportCenter) * -0.08;

				interlude.style.setProperty(
					'--interlude-parallax-offset',
					`${offset.toFixed(2)}px`,
				);
			}
		};

		updateParallax();
		window.addEventListener('scroll', updateParallax, { passive: true });
		window.addEventListener('resize', updateParallax);
	}
</script>
