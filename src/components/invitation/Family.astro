---
// src/components/invitation/Family.astro
import '@/styles/invitation/_family.scss';
import Container from '@/components/layout/Container.astro';
import OptimizedImage from '@/components/common/OptimizedImage.astro';
import type { ImageAsset } from '@/lib/assets/asset-registry';
import type { ThemePreset } from '@/lib/theme/theme-contract';
import { DEFAULT_PARENTS_ORDER, type ParentsOrder } from '@/lib/invitation/family-contract';
import { shouldHideRoleVisually } from '@/lib/invitation/family-helper';
import {
	shouldRenderFamilyMedia,
	type FamilyPresentation,
} from '@/lib/invitation/presentation-options';

interface Props {
	parents?: {
		father?: string;
		mother?: string;
		fatherDeceased?: boolean;
		motherDeceased?: boolean;
	};
	parentsOrder?: ParentsOrder;
	spouse?: string;
	children?: Array<{
		name: string;
		role?: string;
	}>;
	godparents?: Array<{
		name: string;
		role?: string;
	}>;
	godparentGroups?: Array<{
		honoreeName: string;
		label?: string;
		godparents: Array<{
			name: string;
			role?: string;
		}>;
	}>;
	groups?: Array<{
		title: string;
		items: Array<{
			name: string;
			role?: string;
			deceased?: boolean;
		}>;
	}>;
	featuredImage?: string | ImageAsset;
	presentation?: FamilyPresentation;
	celebrantName: string;
	labels?: {
		sectionTitle?: string;
		sectionSubtitle?: string;
		spouseTitle?: string;
		spouseRole?: string;
		childrenTitle?: string;
		parentsTitle?: string;
		godparentsTitle?: string;
		fatherRole?: string;
		motherRole?: string;
		sectionMessage?: string;
	};
	focalPoint?: string;
	variant?: ThemePreset;
	visible?: boolean;
}

interface FamilyEntry {
	name: string;
	role?: string;
	lead?: boolean;
	deceased?: boolean;
}

interface FamilyBlock {
	id: string;
	title: string;
	entries: FamilyEntry[];
	godparentGroups?: Array<{
		honoreeName: string;
		label?: string;
		entries: FamilyEntry[];
	}>;
}

const {
	parents,
	parentsOrder: parentsOrderProp,
	spouse,
	children,
	godparents,
	godparentGroups,
	groups,
	featuredImage,
	presentation,
	celebrantName,
	labels,
	focalPoint,
	variant,
	visible = true,
} = Astro.props;

if (!visible) return;

const resolvedLabels = {
	sectionTitle: labels?.sectionTitle ?? 'Los que hacen mi vida completa',
	sectionSubtitle: labels?.sectionSubtitle ?? 'Mi Familia',
	spouseTitle: labels?.spouseTitle ?? 'Mi Compañera de Vida',
	spouseRole: labels?.spouseRole ?? 'Esposa',
	childrenTitle: labels?.childrenTitle ?? 'Nuestros Hijos',
	parentsTitle: labels?.parentsTitle ?? 'Con la bendición de',
	godparentsTitle: labels?.godparentsTitle ?? 'Padrinos',
	fatherRole: labels?.fatherRole ?? 'Padre',
	motherRole: labels?.motherRole ?? 'Madre',
	sectionMessage:
		labels?.sectionMessage ??
		'Gracias por caminar conmigo en este momento tan especial. Su amor, guía y bendición forman parte de este día que guardaré para siempre.',
};

const shouldRenderMedia = shouldRenderFamilyMedia(presentation, Boolean(featuredImage));
const imagePath = featuredImage
	? (typeof featuredImage === 'string' ? featuredImage : (featuredImage.src as string))
	: undefined;
const resolvedFocalPoint = focalPoint || 'center';

const initials = celebrantName
	.trim()
	.split(/\s+/)
	.map((part) => part.at(0))
	.filter(Boolean)
	.slice(0, 2)
	.join('')
	.toLocaleUpperCase('es-MX');

const parentsOrder = parentsOrderProp ?? DEFAULT_PARENTS_ORDER;

const parentEntries: FamilyEntry[] = [];
if (parents?.father) {
	parentEntries.push({ name: parents.father, role: resolvedLabels.fatherRole || undefined, deceased: Boolean(parents.fatherDeceased) });
}
if (parents?.mother) {
	parentEntries.push({ name: parents.mother, role: resolvedLabels.motherRole || undefined, deceased: Boolean(parents.motherDeceased) });
}
if (parentsOrder === 'mother-first') {
	parentEntries.reverse();
}

const baseFamilyBlocks: FamilyBlock[] =
	groups && groups.length > 0
		? groups.map((group, index) => ({
				id: `group-${index}`,
				title: group.title,
				entries: group.items.map((item) => ({
					name: item.name,
					role: item.role,
					deceased: item.deceased,
				})),
			}))
		: [
				...(spouse
					? [
							{
								id: 'spouse',
								title: resolvedLabels.spouseTitle,
								entries: [{ name: spouse, role: resolvedLabels.spouseRole, lead: true }],
							},
						]
					: []),
				...(children && children.length > 0
					? [
							{
								id: 'children',
								title: resolvedLabels.childrenTitle,
								entries: children.map((child) => ({
									name: child.name,
									role: child.role,
								})),
							},
						]
					: []),
				...(parents && (parents.father || parents.mother)
					? [
							{
								id: 'parents',
								title: resolvedLabels.parentsTitle,
								entries: parentEntries,
							},
						]
					: []),
			];

const godparentBlock: FamilyBlock[] = (godparentGroups ?? []).length > 0
	? [
			{
				id: 'godparents',
				title: resolvedLabels.godparentsTitle,
				entries: [],
				godparentGroups: (godparentGroups ?? []).map((group) => ({
					honoreeName: group.honoreeName,
					label: group.label,
					entries: group.godparents.map((godparent) => ({
						name: godparent.name,
						role: godparent.role,
					})),
				})),
			},
		]
	: godparents && godparents.length > 0
		? [
				{
					id: 'godparents',
					title: resolvedLabels.godparentsTitle,
					entries: godparents.map((godparent) => ({
						name: godparent.name,
						role: godparent.role,
					})),
				},
			]
		: [];

const familyBlocks: FamilyBlock[] = baseFamilyBlocks.concat(godparentBlock);

const hasContent = familyBlocks.length > 0 || shouldRenderMedia;
if (!hasContent) return;
---

<section
	id="family-section"
	class="family"
	data-variant={variant}
	data-presentation={presentation}
>
	<div class="family__bg-texture" aria-hidden="true"></div>

	<Container class="family__container">
		<header class="family__header family__reveal">
			<div class="family__header-inner">
				<span class="family__eyebrow">{resolvedLabels.sectionSubtitle}</span>
				<h2 class="family__title">{resolvedLabels.sectionTitle}</h2>
				<div class="family__header-divider" aria-hidden="true"></div>
				<p class="family__message">{resolvedLabels.sectionMessage}</p>
			</div>
		</header>

		<div
			class:list={['family__panel', !shouldRenderMedia && 'family__panel--no-media']}
			data-family-initials={initials}
		>
			<div class="family__content-overlay" aria-hidden="true"></div>

			{shouldRenderMedia && (
				<figure class="family__media family__reveal">
					<div class="family__media-frame">
						<OptimizedImage
							imagePath={imagePath}
							alt={celebrantName}
							width={600}
							height={800}
						/>
					</div>
				</figure>
			)}

			<div class="family__content">
				{familyBlocks.map((block) => (
					<section
						class:list={[
							'family__group',
							`family__group--${block.id}`,
							'family__reveal',
						]}
					>
						<h3 class="family__group-title">{block.title}</h3>
						{block.godparentGroups ? (
							<div class="family__godparent-groups">
								{block.godparentGroups.map((group) => (
									<section class="family__godparent-subgroup">
										<div class="family__godparent-label">
											{group.label ?? group.honoreeName}
										</div>
										<div class="family__godparent-names">
											<ul class="family__list family__list--godparents family__list--godparents-grouped">
												{group.entries.map((entry) => (
													<li class:list={['family__item', 'family__item--godparent']}>
														<p class="family__name">
															<span>{entry.name}</span>
														</p>
														{entry.role && (
															<span class={shouldHideRoleVisually(group.label ?? block.title, entry.role) ? 'sr-only' : 'family__meta'}>
																{entry.role}
															</span>
														)}
													</li>
												))}
											</ul>
										</div>
									</section>
								))}
							</div>
						) : (
							<ul
								class:list={[
									'family__list',
									block.id === 'children' && 'family__list--children',
									block.id === 'godparents' && 'family__list--godparents',
								]}
							>
								{block.entries.map((entry) => (
									<li class:list={['family__item', entry.lead && 'family__item--lead', block.id === 'godparents' && 'family__item--godparent']}>
										<p class="family__name">
											<span>{entry.name}</span>
											{entry.deceased && (
												<span class="family__deceased-indicator" aria-hidden="true">†</span>
											)}
										</p>
										{entry.role && (
											<span class={shouldHideRoleVisually(block.title, entry.role) ? 'sr-only' : 'family__meta'}>
												{entry.role}
											</span>
										)}
									</li>
								))}
							</ul>
						)}
					</section>
				))}
			</div>
		</div>
	</Container>
</section>
<style define:vars={{ familyFocalPoint: resolvedFocalPoint }}>
	.family {
		--family-focal-point: var(--familyFocalPoint);
	}
</style>
<script>
	import { createIntersectionObserver } from '@/utils/animations';

	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (!prefersReducedMotion) {
		document.querySelectorAll('.family').forEach((section) => {
			section.classList.add('has-motion');
		});

		createIntersectionObserver(
			'.family.has-motion',
			(target) => target.classList.add('is-visible'),
		);
	}
</script>
