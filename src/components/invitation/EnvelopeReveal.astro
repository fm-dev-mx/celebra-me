---
import Icon from '@/components/common/icons/Icon.astro';

interface Props {
	name: string;
	date: string;
	city: string;
	sealStyle: 'wax' | 'ribbon' | 'flower' | 'monogram';
	sealIcon?: 'boot' | 'heart' | 'monogram' | 'flower';
	microcopy: string;
	documentLabel?: string;
	stampText?: string;
	stampYear?: string;
	eventSlug: string;
	tooltipText?: string;
	variant?: string;
	guestName?: string;
}

const {
	name,
	date,
	city,
	sealStyle,
	sealIcon = 'monogram',
	microcopy,
	documentLabel,
	stampText,
	stampYear,
	eventSlug,
	tooltipText = 'ACCEDER A LA INVITACIÓN',
	variant,
	guestName,
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('es-MX', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
});

const sealIconMap = {
	boot: 'Boot',
	heart: 'HeartSeal',
	monogram: 'MonogramSeal',
	flower: 'FlowerSeal',
} as const;
---

<div
	class="envelope-wrapper"
	data-envelope
	data-phase="closed"
	data-event-slug={eventSlug}
	data-tooltip-text={tooltipText}
	data-variant={variant}
>
	<div class="envelope-container">
		<div class="envelope-base"></div>

		<div class="envelope-card" data-envelope-card>
			<div class="rivet rivet--tl"></div>
			<div class="rivet rivet--tr"></div>
			<div class="rivet rivet--bl"></div>
			<div class="rivet rivet--br"></div>
			<div class="envelope-card__content">
				<div class="envelope-card__header">
					<div class="envelope-card__monogram">
						<Icon
							name={sealIconMap[sealIcon]}
							class={`seal-icon seal-icon--${sealIcon}`}
						/>
					</div>
				</div>
				<div class="envelope-card__body">
					<span class="envelope-card__label">{documentLabel || 'Invitación'}</span>
					<h2 class="envelope-card__name">{name}</h2>
					{guestName && (
						<div class="envelope-card__guest-personalized">
							<p class="personalized-label">Entrega especial para:</p>
							<strong class="personalized-name">{guestName}</strong>
						</div>
					)}
				</div>
				<div class="envelope-card__footer">
					<p class="envelope-card__details">{formattedDate} • {city}</p>
				</div>
			</div>
		</div>

		<div class="envelope-pocket"></div>
		<div class="envelope-flap" data-envelope-flap>
			<div class="envelope-flap-shadow"></div>
		</div>

		<div class="envelope-tease">
			<div class="envelope-tease__interactive-content" data-envelope-content>
				<div class="tease-header">
					{stampText && (
						<div class="envelope-stamp-area">
							<div class="envelope-stamp">
								<span>{stampText}</span>
								{stampYear && <small>{stampYear}</small>}
							</div>
						</div>
					)}
					{documentLabel && (
						<span class="envelope-manifest-label">{documentLabel}</span>
					)}
				</div>

				<div class="envelope-seal-zone">
					<button
						type="button"
						class={`envelope-seal-button envelope-seal-button--${sealStyle}`}
						data-envelope-open
						aria-label="Abrir sobre de la invitación"
					>
						<div class="envelope-seal-button__visual">
							<Icon
								name={sealIconMap[sealIcon]}
								class={`seal-icon seal-icon--${sealIcon}`}
							/>
						</div>
						<div class="envelope-seal-button__pulse"></div>
						<span class="envelope-tooltip" data-envelope-tooltip hidden>
							{tooltipText}
						</span>
					</button>
				</div>

				<div class="tease-content-bottom">
					<h2 class="envelope-name">{name}</h2>
					<div class="tease-details-group">
						<div class="tease-divider"></div>
						<p class="envelope-details">{formattedDate} • {city}</p>
					</div>
					{guestName && (
						<div class="envelope-guest-personalized">
							<p class="personalized-label">Entrega especial para:</p>
							<strong class="personalized-name">{guestName}</strong>
						</div>
					)}
				</div>
			</div>
		</div>
	</div>

	{microcopy && (
		<div class="envelope-external-instruction" data-envelope-microcopy>
			<p>{microcopy}</p>
			<div class="instruction-line"></div>
		</div>
	)}
</div>

<script>
	const PHASE_DELAY_RISING = 1100; // Increased to let the flap breathe
	const PHASE_DELAY_EXIT = 2800; // Increased to allow the card to fully settle
	const EXIT_ANIMATION_DELAY = 1400;
	const FAILSAFE_REVEAL_DELAY = PHASE_DELAY_EXIT + EXIT_ANIMATION_DELAY + 1500;

	const envelopes = document.querySelectorAll('[data-envelope]');

	envelopes.forEach((root) => {
		if (!(root instanceof HTMLElement)) {
			return;
		}

		const eventSlug = root.dataset.eventSlug;
		const invitationRoot =
			root.parentElement?.closest('.event-theme-wrapper[data-event-slug]') ||
			root.closest('.event-theme-wrapper[data-event-slug]');
		const openButton = root.querySelector('[data-envelope-open]');
		const flap = root.querySelector('[data-envelope-flap]');
		const card = root.querySelector('[data-envelope-card]');
		const tooltip = root.querySelector('[data-envelope-tooltip]') as HTMLElement | null;

		if (
			!(openButton instanceof HTMLButtonElement) ||
			!(flap instanceof HTMLElement) ||
			!(card instanceof HTMLElement) ||
			!eventSlug
		) {
			return;
		}

		let phase = 'closed';
		let hasRevealed = false;
		const timers = new Set<number>();
		const params = new URLSearchParams(window.location.search);
		const storageKey = `envelope-opened-${eventSlug}`;

		const schedule = (callback: () => void, delay: number) => {
			const timerId = window.setTimeout(() => {
				timers.delete(timerId);
				callback();
			}, delay);
			timers.add(timerId);
			return timerId;
		};

		const clearTimers = () => {
			timers.forEach((timerId) => window.clearTimeout(timerId));
			timers.clear();
		};

		const revealInvitation = () => {
			if (hasRevealed) {
				return;
			}

			hasRevealed = true;
			clearTimers();
			document.body.style.overflow = 'auto';
			if (invitationRoot instanceof HTMLElement) {
				invitationRoot.dataset.revealState = 'revealed';
			}

			// Dispatch event for other components (like MusicPlayer)
			window.dispatchEvent(new CustomEvent('envelope:opened', { detail: { eventSlug } }));

			// Allow exit animation to complete before hiding
			schedule(() => {
				root.hidden = true;
			}, EXIT_ANIMATION_DELAY);
		};

		const setPhase = (nextPhase: 'closed' | 'opening' | 'rising' | 'exit') => {
			if (hasRevealed && nextPhase !== 'exit') {
				return;
			}

			phase = nextPhase;
			root.dataset.phase = phase;

			if (phase === 'exit') {
				revealInvitation();
			} else {
				document.body.style.overflow = 'hidden';
			}
		};

		const skipEnvelope = params.get('skipEnvelope') === 'true';
		const forceEnvelope = params.get('forceEnvelope') === 'true';
		const wasOpened = localStorage.getItem(storageKey) === 'true';

		if (skipEnvelope || (!forceEnvelope && wasOpened)) {
			phase = 'exit';
			root.hidden = true;
			document.body.style.overflow = 'auto';
			if (invitationRoot instanceof HTMLElement) {
				invitationRoot.dataset.revealState = 'revealed';
			}
			hasRevealed = true;
		}

		root.dataset.phase = phase;

		if (phase === 'exit') {
			return;
		}

		schedule(() => {
			if (phase === 'closed' && tooltip) {
				tooltip.hidden = false;
			}
		}, 1500);

		const audio = new Audio(
			'https://res.cloudinary.com/dusxvauvj/video/upload/v1771015768/scroll-papper5s_qixwes.wav',
		);

		openButton.addEventListener('click', (event) => {
			if (event) {
				event.stopPropagation();
				event.preventDefault();
			}

			if (phase !== 'closed') {
				return;
			}

			if (tooltip) tooltip.hidden = true;
			audio.volume = 0.4;
			void audio.play().catch((error) => {
				console.warn('Audio play blocked:', error);
			});

			localStorage.setItem(storageKey, 'true');
			clearTimers();
			setPhase('opening');

			schedule(() => {
				if (phase === 'opening') {
					setPhase('rising');
				}
			}, PHASE_DELAY_RISING);

			schedule(() => {
				if (phase === 'opening' || phase === 'rising') {
					setPhase('exit');
				}
			}, PHASE_DELAY_EXIT);

			schedule(() => {
				if (!hasRevealed) {
					setPhase('exit');
				}
			}, FAILSAFE_REVEAL_DELAY);
		});

		window.addEventListener(
			'pagehide',
			() => {
				clearTimers();
				if (audio) {
					audio.pause();
					audio.src = '';
					audio.load();
				}
			},
			{ once: true },
		);
	});
</script>
