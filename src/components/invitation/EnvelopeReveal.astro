---
import Icon from '@/components/common/icons/Icon.astro';
import InvitationRevealCard from '@/components/invitation/InvitationRevealCard.astro';
import {
	SEAL_ICON_MAP,
	type EnvelopeSealIcon,
	type RevealCardData,
} from '@/lib/invitation/reveal-card';

interface Props {
  name: string;
  sealStyle: 'wax' | 'ribbon' | 'flower' | 'monogram';
  sealIcon?: EnvelopeSealIcon;
  microcopy: string;
  documentLabel?: string;
  stampText?: string;
  stampYear?: string;
  eventSlug: string;
  tooltipText?: string;
  variant?: string;
  guestName?: string;
  audioUrl?: string;
  card: RevealCardData;
}

const {
  name,
  sealStyle,
  sealIcon = 'monogram',
  microcopy,
  documentLabel,
  stampText,
  stampYear,
  eventSlug,
  tooltipText = 'ACCEDER A LA INVITACIÓN',
  variant,
  guestName,
  audioUrl = '',
  card,
} = Astro.props;

const sealIconName = SEAL_ICON_MAP[sealIcon];
---

<div
  class="envelope-wrapper"
  data-envelope
  data-phase="closed"
  data-event-slug={eventSlug}
  data-variant={variant}
  data-audio-url={audioUrl}
>
	<div class="envelope-container">
		<div class="envelope-base"></div>

		<div class="envelope-pocket"></div>

		<div class="envelope-flap" data-envelope-flap>
			<div class="envelope-flap-shadow"></div>
		</div>

		<div class="envelope-tease">
			<div class="envelope-tease__interactive-content">
				<div class="envelope-zone envelope-zone--stamp">
					{
						stampText && (
							<div class="envelope-stamp-area">
								<div class="envelope-stamp">
									<span>{stampText}</span>
									{stampYear && <small>{stampYear}</small>}
								</div>
							</div>
						)
					}

					{documentLabel && <span class="envelope-manifest-label">{documentLabel}</span>}
				</div>

				<div class="envelope-zone envelope-zone--seal">
					<button
						type="button"
						class={`envelope-seal-button envelope-seal-button--${sealStyle}`}
						data-envelope-open
						aria-label="Abrir sobre de la invitación"
					>
						<div class="envelope-seal-button__visual">
							<Icon name={sealIconName} class={`seal-icon seal-icon--${sealIcon}`} />
						</div>
						<div class="envelope-seal-button__pulse"></div>
						<span class="envelope-tooltip" data-envelope-tooltip hidden>
							{tooltipText}
						</span>
					</button>
				</div>

				<div class="envelope-zone envelope-zone--identity">
					<h2 class="envelope-name">{name}</h2>
					<div class="tease-details-group">
						<div class="tease-divider"></div>
						<p class="envelope-details">{card.details}</p>
					</div>

					{
						guestName && (
							<div class="guest-personalized">
								<p class="personalized-label">Entrega especial para:</p>
								<strong class="personalized-name">{guestName}</strong>
							</div>
						)
					}
				</div>
			</div>
		</div>
	</div>

	<div class="envelope-reveal-stage" data-envelope-card>
		<InvitationRevealCard card={card} />
	</div>

	{
		microcopy && (
			<div class="envelope-external-instruction" data-envelope-microcopy>
				<p>{microcopy}</p>
				<div class="instruction-line"></div>
			</div>
		)
	}
</div>

<script>
	type EnvelopePhase = 'closed' | 'opening' | 'rising' | 'exit';

const DEV_SKIP_ENABLED = import.meta.env.DEV;
const TOOLTIP_DELAY = 1500; // 1.5 seconds
const FALLBACK_PHASE_DURATION = 900; // 0.9 seconds

	const wait = (ms: number) => new Promise((resolve) => setTimeout(resolve, ms));

	const parseCssTimeToMs = (value: string): number => {
		const [raw] = value.trim().split(',');
		if (!raw) return FALLBACK_PHASE_DURATION;

		const num = Number.parseFloat(raw);
		if (!Number.isFinite(num)) return FALLBACK_PHASE_DURATION;

		return raw.endsWith('ms') ? num : raw.endsWith('s') ? num * 1000 : num;
	};

	const getMotionPreference = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	const getStoredFlag = (key: string) => {
		try {
			return window.localStorage.getItem(key) === 'true';
		} catch {
			return false;
		}
	};

	const setStoredFlag = (key: string) => {
		try {
			window.localStorage.setItem(key, 'true');
		} catch {
			// Storage can fail in private mode
		}
	};

document.querySelectorAll('[data-envelope]').forEach((root) => {
  if (!(root instanceof HTMLElement)) return;

  const { eventSlug, audioUrl = '' } = root.dataset;

  if (!eventSlug) return;

  const invitationRoot =
    root.parentElement?.closest('.event-theme-wrapper[data-event-slug]') ||
    root.closest('.event-theme-wrapper[data-event-slug]');

  const openButton = root.querySelector('[data-envelope-open]');
  const tooltip = root.querySelector('[data-envelope-tooltip]');

  if (!(openButton instanceof HTMLButtonElement)) return;

  let phase: EnvelopePhase = 'closed';
  let hasRevealed = false;
  let audio: HTMLAudioElement | null = null;

  const params = new URLSearchParams(window.location.search);
  const storageKey = `envelope-opened-${eventSlug}`;
  const isDemoInvitation =
    invitationRoot instanceof HTMLElement
      ? invitationRoot.dataset.isDemo === 'true'
      : false;
		const canUseDevSkip = DEV_SKIP_ENABLED && params.get('skipEnvelope') === 'true';
		const shouldRespectStoredReveal =
			!isDemoInvitation && params.get('forceEnvelope') !== 'true' && getStoredFlag(storageKey);
		const shouldSkipEnvelope = canUseDevSkip || shouldRespectStoredReveal;
		const shouldReduceMotion = getMotionPreference();

		const getPhaseDuration = (phaseName: 'opening' | 'rising' | 'exit') =>
			parseCssTimeToMs(
				window.getComputedStyle(root).getPropertyValue(`--env-phase-${phaseName}-duration`),
			);

		const completeReveal = ({ hideDelay = getPhaseDuration('exit'), hideImmediately = false } = {}) => {
			if (hasRevealed) return;

			hasRevealed = true;
			phase = 'exit';
			root.dataset.phase = 'exit';
			document.body.style.overflow = 'auto';

			if (invitationRoot instanceof HTMLElement) {
				invitationRoot.dataset.revealState = 'revealed';
			}

			window.dispatchEvent(new CustomEvent('envelope:opened', { detail: { eventSlug } }));

			if (hideImmediately || hideDelay <= 0) {
				root.hidden = true;
				return;
			}

			window.setTimeout(() => {
				root.hidden = true;
			}, hideDelay);
		};

		const setPhase = (nextPhase: EnvelopePhase) => {
			if (hasRevealed && nextPhase !== 'exit') return;

			phase = nextPhase;
			root.dataset.phase = nextPhase;
			document.body.style.overflow = nextPhase === 'exit' ? 'auto' : 'hidden';

			if (nextPhase === 'exit') {
				completeReveal();
			}
		};

		const playOpenSound = () => {
			if (!audioUrl) return;

			audio?.pause();
			audio = new Audio(audioUrl);
			audio.volume = 0.4;
			void audio.play().catch(() => {});
		};

		if (shouldSkipEnvelope) {
			completeReveal({ hideImmediately: true });
			return;
		}

		root.dataset.phase = phase;
		document.body.style.overflow = 'hidden';

		const tooltipTimeout = window.setTimeout(() => {
			if (phase === 'closed' && tooltip instanceof HTMLElement) {
				tooltip.hidden = false;
			}
		}, TOOLTIP_DELAY);

		openButton.addEventListener('click', async (event) => {
			event.stopPropagation();
			event.preventDefault();

			if (phase !== 'closed' || hasRevealed) return;

			clearTimeout(tooltipTimeout);

			if (tooltip instanceof HTMLElement) {
				tooltip.hidden = true;
			}

			playOpenSound();
			if (!isDemoInvitation) {
				setStoredFlag(storageKey);
			}

			if (shouldReduceMotion) {
				completeReveal({ hideImmediately: true });
				return;
			}

			setPhase('opening');
			await wait(getPhaseDuration('opening'));

			setPhase('rising');
			await wait(getPhaseDuration('rising'));

			setPhase('exit');
		});

		window.addEventListener(
			'pagehide',
			() => {
				audio?.pause();
				if (audio) audio.src = '';
				audio = null;
			},
			{ once: true },
		);
	});
</script>
