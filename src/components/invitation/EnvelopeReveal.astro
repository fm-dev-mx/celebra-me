---
import Icon from '@/components/common/icons/Icon.astro';

interface Props {
	name: string;
	date: string;
	city: string;
	sealStyle: 'wax' | 'ribbon' | 'flower' | 'monogram';
	sealIcon?: 'boot' | 'heart' | 'monogram' | 'flower' | 'special-edition';
	microcopy: string;
	documentLabel?: string;
	stampText?: string;
	stampYear?: string;
	eventSlug: string;
	tooltipText?: string;
	variant?: string;
	guestName?: string;
}

const {
	name,
	date,
	city,
	sealStyle,
	sealIcon = 'monogram',
	microcopy,
	documentLabel,
	stampText,
	stampYear,
	eventSlug,
	tooltipText = 'ACCEDER A LA INVITACIÓN',
	variant,
	guestName,
} = Astro.props;

const formattedDate = new Intl.DateTimeFormat('es-MX', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
	timeZone: 'UTC',
}).format(new Date(date));
const envelopeDetails = `${formattedDate} • ${city}`;
const cardLabel = documentLabel || 'Invitación';

const sealIconMap = {
	boot: 'Boot',
	heart: 'HeartSeal',
	monogram: 'MonogramSeal',
	flower: 'FlowerSeal',
	'special-edition': 'Diamond',
} as const;

const sealIconName = sealIconMap[sealIcon];
---

<div
	class="envelope-wrapper"
	data-envelope
	data-phase="closed"
	data-event-slug={eventSlug}
	data-variant={variant}
>
	<div class="envelope-container">
		<div class="envelope-base"></div>

		<div class="envelope-card" data-envelope-card>
			<div class="envelope-card__content">
				<Icon
					name={sealIconName}
					class={`seal-icon seal-icon--${sealIcon} envelope-card__monogram`}
				/>
				<span class="envelope-card__label">{cardLabel}</span>
				<h2 class="envelope-card__name">{name}</h2>
				{guestName && (
					<div class="envelope-card__guest-personalized">
						<p class="personalized-label">Entrega especial para:</p>
						<strong class="personalized-name">{guestName}</strong>
					</div>
				)}
				<p class="envelope-card__details">{envelopeDetails}</p>
			</div>
		</div>

		<div class="envelope-pocket"></div>
		<div class="envelope-flap" data-envelope-flap>
			<div class="envelope-flap-shadow"></div>
		</div>

		<div class="envelope-tease">
			<div class="envelope-tease__interactive-content">
				<div class="envelope-zone envelope-zone--stamp">
					{stampText && (
						<div class="envelope-stamp-area">
							<div class="envelope-stamp">
								<span>{stampText}</span>
								{stampYear && <small>{stampYear}</small>}
							</div>
						</div>
					)}
					{documentLabel && (
						<span class="envelope-manifest-label">{documentLabel}</span>
					)}
				</div>

				<div class="envelope-zone envelope-zone--seal">
					<button
						type="button"
						class={`envelope-seal-button envelope-seal-button--${sealStyle}`}
						data-envelope-open
						aria-label="Abrir sobre de la invitación"
					>
						<div class="envelope-seal-button__visual">
							<Icon
								name={sealIconName}
								class={`seal-icon seal-icon--${sealIcon}`}
							/>
						</div>
						<div class="envelope-seal-button__pulse"></div>
						<span class="envelope-tooltip" data-envelope-tooltip hidden>
							{tooltipText}
						</span>
					</button>
				</div>

				<div class="envelope-zone envelope-zone--identity">
					<h2 class="envelope-name">{name}</h2>
					<div class="tease-details-group">
						<div class="tease-divider"></div>
						<p class="envelope-details">{envelopeDetails}</p>
					</div>
					{guestName && (
						<div class="envelope-guest-personalized">
							<p class="personalized-label">Entrega especial para:</p>
							<strong class="personalized-name">{guestName}</strong>
						</div>
					)}
				</div>
			</div>
		</div>
	</div>

	{microcopy && (
		<div class="envelope-external-instruction" data-envelope-microcopy>
			<p>{microcopy}</p>
			<div class="instruction-line"></div>
		</div>
	)}
</div>

<script>
	const PHASE_DELAY_RISING = 1100;
	const PHASE_DELAY_EXIT = 2800;
	const EXIT_ANIMATION_DELAY = 1400;
	const FAILSAFE_REVEAL_DELAY = PHASE_DELAY_EXIT + EXIT_ANIMATION_DELAY + 1500;
const envelopes = document.querySelectorAll('[data-envelope]');

	envelopes.forEach((root) => {
		if (!(root instanceof HTMLElement)) {
			return;
		}

		const eventSlug = root.dataset.eventSlug;
		const invitationRoot =
			root.parentElement?.closest('.event-theme-wrapper[data-event-slug]') ||
			root.closest('.event-theme-wrapper[data-event-slug]');
		const openButton = root.querySelector('[data-envelope-open]');
		const tooltip = root.querySelector('[data-envelope-tooltip]') as HTMLElement | null;

		if (!(openButton instanceof HTMLButtonElement) || !eventSlug) {
			return;
		}

		let phase: 'closed' | 'opening' | 'rising' | 'exit' = 'closed';
		let hasRevealed = false;
		const wait = (ms: number) => new Promise((resolve) => setTimeout(resolve, ms));
		const params = new URLSearchParams(window.location.search);
		const storageKey = `envelope-opened-${eventSlug}`;

		const revealInvitation = () => {
			if (hasRevealed) return;
			hasRevealed = true;
			document.body.style.overflow = 'auto';
			if (invitationRoot instanceof HTMLElement) {
				invitationRoot.dataset.revealState = 'revealed';
			}
			window.dispatchEvent(new CustomEvent('envelope:opened', { detail: { eventSlug } }));
			setTimeout(() => {
				root.hidden = true;
			}, EXIT_ANIMATION_DELAY);
		};

		const setPhase = (nextPhase: 'closed' | 'opening' | 'rising' | 'exit') => {
			if (hasRevealed && nextPhase !== 'exit') return;
			phase = nextPhase;
			root.dataset.phase = phase;
			if (phase === 'exit') revealInvitation();
			else document.body.style.overflow = 'hidden';
		};

		root.style.setProperty('--env-transition-rise', `${PHASE_DELAY_RISING}ms`);
		root.style.setProperty('--env-transition-exit', `${PHASE_DELAY_EXIT}ms`);

		const skipEnvelope = params.get('skipEnvelope') === 'true';
		const forceEnvelope = params.get('forceEnvelope') === 'true';
		const wasOpened = localStorage.getItem(storageKey) === 'true';

		if (skipEnvelope || (!forceEnvelope && wasOpened)) {
			phase = 'exit';
			root.hidden = true;
			document.body.style.overflow = 'auto';
			if (invitationRoot instanceof HTMLElement) {
				invitationRoot.dataset.revealState = 'revealed';
			}
			hasRevealed = true;
		}

		root.dataset.phase = phase;

		if (phase === 'exit') {
			return;
		}

		setTimeout(() => {
			if (phase === 'closed' && tooltip) tooltip.hidden = false;
		}, 1500);

		const audio = new Audio('https://res.cloudinary.com/dusxvauvj/video/upload/v1771015768/scroll-papper5s_qixwes.wav');

		openButton.addEventListener('click', async (event) => {
	event.stopPropagation();
	event.preventDefault();

			if (phase !== 'closed' || hasRevealed) return;

			if (tooltip) tooltip.hidden = true;
			audio.volume = 0.4;
			void audio.play().catch(() => {});

			localStorage.setItem(storageKey, 'true');
			setPhase('opening');

			setTimeout(() => {
				if (!hasRevealed && phase !== 'exit') {
					setPhase('exit');
				}
			}, FAILSAFE_REVEAL_DELAY);

			await wait(PHASE_DELAY_RISING);
			if (phase === 'opening') setPhase('rising');

			await wait(PHASE_DELAY_EXIT - PHASE_DELAY_RISING);
			if (phase === 'rising') setPhase('exit');
		});

		window.addEventListener(
			'pagehide',
			() => {
				audio.pause();
				audio.src = '';
			},
			{ once: true },
		);
	});
</script>
