---
import InvitationRevealCard from '@/components/invitation/InvitationRevealCard.astro';
import SealIcon from '@/components/common/icons/invitation/SealIcon.astro';
import type { ImageAsset } from '@/lib/assets/asset-registry';
import {
	type EnvelopeSealIcon,
	type RevealCardData,
} from '@/lib/invitation/reveal-card';

interface Props {
	name: string;
	sealStyle: 'wax' | 'ribbon' | 'flower' | 'monogram';
	sealIcon?: EnvelopeSealIcon;
	sealInitials?: string;
	sealVariant?: 'premium-rose';
	sealImage?: ImageAsset;
	microcopy: string;
	documentLabel?: string;
	stampText?: string;
	stampYear?: string;
	eventSlug: string;
	tooltipText?: string;
	variant?: string;
	audioUrl?: string;
	card: RevealCardData;
}

const {
	name,
	sealStyle,
	sealIcon = 'monogram',
	sealInitials,
	sealVariant,
	sealImage,
	microcopy,
	documentLabel,
	stampText,
	stampYear,
	eventSlug,
	tooltipText = 'ACCEDER A LA INVITACIÓN',
	variant,
	audioUrl,
	card,
} = Astro.props;

const envelopeDisplay = card.venueName
	? `${card.details.split(' • ')[0]} • ${card.venueName}`
	: card.details;
---

<ds-envelope-reveal
	class="envelope-wrapper"
	data-event-slug={eventSlug}
	data-variant={variant}
	data-seal-variant={sealVariant || ''}
	data-audio-url={audioUrl || ''}
	data-dev-skip={String(import.meta.env.DEV)}
>
	<div class="envelope-container">
		<div class="envelope-base"></div>
		<div class="envelope-pocket"></div>

		<div class="envelope-flap" data-envelope-flap>
			<div class="envelope-flap-shadow"></div>
		</div>

		<div class="envelope-tease">
			<div class="envelope-zone--stamp">
				{
					stampText && (
						<div class="envelope-stamp">
							<span>{stampText}</span>
							{stampYear && <small>{stampYear}</small>}
						</div>
					)
				}
				{documentLabel && <span class="envelope-manifest-label">{documentLabel}</span>}
			</div>

			<div class="envelope-zone--seal">
				<button
					type="button"
					class={`envelope-seal-button envelope-seal-button--${sealStyle}`}
					data-envelope-open
					aria-label="Abrir sobre de la invitación"
				>
					<div class="envelope-seal-button__visual">
						{
							sealImage ? (
								<img
									src={typeof sealImage.src === 'string' ? sealImage.src : sealImage.src.src}
									alt={sealInitials || ''}
									class="seal-icon seal-icon--image"
								/>
							) : (
								<SealIcon
									sealIcon={sealIcon}
									sealInitials={sealInitials}
									class="seal-icon"
								/>
							)
						}
					</div>
					<div class="envelope-seal-button__pulse"></div>
					<span class="envelope-tooltip" data-envelope-tooltip hidden>
						{tooltipText}
					</span>
				</button>
			</div>

			<div class="envelope-zone--identity" aria-hidden="true">
				<h2 class="envelope-name">{name}</h2>
				<div class="tease-details-group">
					<div class="tease-divider"></div>
					<p class="envelope-details">{envelopeDisplay}</p>
				</div>

				{
					card.guestName && (
						<div class="guest-personalized">
							<p class="personalized-label">Entrega especial para:</p>
							<strong class="personalized-name">{card.guestName}</strong>
						</div>
					)
				}
			</div>
		</div>
	</div>

	<div class="envelope-reveal-stage" data-envelope-card aria-hidden="true">
		<InvitationRevealCard card={card} />
	</div>

	{
		microcopy && (
			<div class="envelope-external-instruction" data-envelope-microcopy>
				<p>{microcopy}</p>
				<div class="instruction-line"></div>
			</div>
		)
	}
</ds-envelope-reveal>

<script>
	import { RevealManager, getMotionPreference } from '@/lib/invitation/reveal-manager';

	const EXIT_ANIMATION_MS = 2200;

	class DsEnvelopeReveal extends HTMLElement {
		connectedCallback() {
			const { eventSlug, audioUrl } = this.dataset;
			if (!eventSlug) return;

			const invitationRoot = this.closest('.event-theme-wrapper[data-event-slug]');
			if (!invitationRoot) return;

			const isDemoInvitation = (invitationRoot as HTMLElement).dataset.isDemo === 'true';
			const devSkipEnabled = this.dataset.devSkip === 'true';

			const manager = new RevealManager({
				eventSlug,
				audioUrl: audioUrl || '',
				isDemoInvitation,
				devSkipEnabled,
			});

			const openButton = this.querySelector('[data-envelope-open]');
			const tooltip = this.querySelector('[data-envelope-tooltip]');
			const revealCard = this.querySelector('[data-envelope-card]');
			let hasRevealed = false;

			const completeReveal = () => {
				if (hasRevealed) return;
				hasRevealed = true;

				document.documentElement.classList.remove('envelope-open');

				if (invitationRoot instanceof HTMLElement) {
					invitationRoot.dataset.revealState = 'revealed';
				}

				window.requestAnimationFrame(() => {
					const hero = document.getElementById('inicio');
					if (hero instanceof HTMLElement) {
						hero.scrollIntoView({ block: 'start', inline: 'nearest', behavior: 'auto' });
					} else {
						window.scrollTo({ top: 0, left: 0, behavior: 'auto' });
					}
				});

				window.dispatchEvent(new CustomEvent('envelope:opened', { detail: { eventSlug } }));

				window.setTimeout(() => {
					this.hidden = true;
				}, EXIT_ANIMATION_MS);
			};

			if (manager.shouldSkipEnvelope()) {
				completeReveal();
				this.hidden = true;
				return;
			}

			document.documentElement.classList.add('envelope-open');

			const tooltipTimeout = window.setTimeout(() => {
				if (tooltip instanceof HTMLElement) {
					tooltip.hidden = false;
				}
			}, 1500);

			openButton?.addEventListener('click', (event) => {
				event.stopPropagation();
				event.preventDefault();

				clearTimeout(tooltipTimeout);
				if (tooltip instanceof HTMLElement) tooltip.hidden = true;

				manager.playOpenSound();
				manager.setStoredFlag();

				if (getMotionPreference()) {
					completeReveal();
					this.hidden = true;
					return;
				}

				this.classList.add('is-opening');

				if (revealCard instanceof HTMLElement) {
					const onAnimationEnd = (e: AnimationEvent) => {
						if (e.animationName.includes('envCardRise')) {
							revealCard.removeEventListener('animationend', onAnimationEnd);
							completeReveal();
						}
					};
					revealCard.addEventListener('animationend', onAnimationEnd);
				} else {
					window.setTimeout(completeReveal, 2000);
				}
			});
		}
	}

	customElements.define('ds-envelope-reveal', DsEnvelopeReveal);
</script>
