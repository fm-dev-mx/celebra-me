---
import type { RevealCardData } from '@/lib/invitation/reveal-card';

interface Props {
	card: RevealCardData;
}

const { card } = Astro.props;
---

<article class="invitation-reveal-card" aria-label={card.label}>
	<div class="invitation-reveal-card__inner">
		<p class="invitation-reveal-card__label">{card.label}</p>
		<h2 class="invitation-reveal-card__name">{card.name}</h2>
		<p class="invitation-reveal-card__date">{card.date}</p>

		{
			card.tagline && (
				<p class="invitation-reveal-card__tagline">{card.tagline}</p>
			)
		}

		<div class="invitation-reveal-card__divider" aria-hidden="true"></div>

		{
			card.guestName && (
				<div class="invitation-reveal-card__guest">
					<p class="invitation-reveal-card__guest-label">Entrega especial para:</p>
					<strong class="invitation-reveal-card__guest-name">{card.guestName}</strong>
				</div>
			)
		}
	</div>
</article>
