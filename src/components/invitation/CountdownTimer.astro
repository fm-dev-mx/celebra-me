---
interface Props {
	targetIso: string;
	isDemo?: boolean;
}

const { targetIso, isDemo } = Astro.props;

const targetDate = new Date(targetIso);
const difference = targetDate.getTime() - Date.now();
const initialTimeLeft =
	difference > 0
		? {
				days: Math.floor(difference / (1000 * 60 * 60 * 24)),
				hours: Math.floor((difference / (1000 * 60 * 60)) % 24),
				minutes: Math.floor((difference / 1000 / 60) % 60),
				seconds: Math.floor((difference / 1000) % 60),
			}
		: { days: 0, hours: 0, minutes: 0, seconds: 0 };

const segments = [
	{ key: 'days', label: 'Días', value: initialTimeLeft.days },
	{ key: 'hours', label: 'Horas', value: initialTimeLeft.hours },
	{ key: 'minutes', label: 'Minutos', value: initialTimeLeft.minutes },
	{ key: 'seconds', label: 'Segundos', value: initialTimeLeft.seconds },
];
---

<div class="countdown__timer" data-countdown data-target-iso={targetIso} data-is-demo={isDemo ? "true" : undefined}>
	{
		segments.map((segment, index) => (
			<div class="countdown__segment" data-index={index} data-unit={segment.key}>
				<div class="countdown__value-wrapper">
					<span
						class="countdown__value"
						data-countdown-value={segment.key}
						data-value={segment.value.toString().padStart(2, '0')}
					>
						{segment.value.toString().padStart(2, '0')}
					</span>
				</div>
				<span class="countdown__label">{segment.label}</span>
			</div>
		))
	}
</div>

<script>
	const countdownRoots = Array.from(document.querySelectorAll('[data-countdown]'));

	countdownRoots.forEach((root) => {
		if (!(root instanceof HTMLElement)) {
			return;
		}

		const targetIso = root.dataset.targetIso;
		if (!targetIso) {
			return;
		}

		// Demo countdown: compute a random target 30-60 days in the future,
		// recomputed on each new page load/session entry.
		// Does NOT affect real invitations (isDemo=false or absent).
		const isDemo = root.dataset.isDemo === 'true';
		const effectiveTarget = isDemo
			? new Date(Date.now() + (Math.floor(Math.random() * 31) + 30) * 86400000).toISOString()
			: targetIso;

		const updateCountdown = () => {
			const difference = new Date(effectiveTarget).getTime() - Date.now();
			const values =
				difference > 0
					? {
							days: Math.floor(difference / (1000 * 60 * 60 * 24)),
							hours: Math.floor((difference / (1000 * 60 * 60)) % 24),
							minutes: Math.floor((difference / 1000 / 60) % 60),
							seconds: Math.floor((difference / 1000) % 60),
						}
					: { days: 0, hours: 0, minutes: 0, seconds: 0 };

			Object.entries(values).forEach(([key, value]) => {
				const element = root.querySelector(`[data-countdown-value="${key}"]`);
				if (!(element instanceof HTMLElement)) {
					return;
				}

				const paddedValue = value.toString().padStart(2, '0');
				element.textContent = paddedValue;
				element.dataset.value = paddedValue;
			});
		};

		updateCountdown();

		// Demo: also update the date text below the timer to match the randomized
		// countdown target, keeping date display consistent with the timer.
		if (isDemo) {
			const section = root.closest('.countdown-section');
			if (section) {
				const dateContainer = section.querySelector('.countdown-date');
				if (dateContainer) {
					const demoDate = new Date(effectiveTarget);
					const locale = 'es-MX';

					const desktopEl = dateContainer.querySelector('.event-date-desktop');
					const mobileWeekdayEl = dateContainer.querySelector('.event-date-mobile-weekday');
					const mobileFullEl = dateContainer.querySelector('.event-date-mobile-full');

					if (desktopEl) {
						desktopEl.textContent = new Intl.DateTimeFormat(locale, {
							weekday: 'long', day: '2-digit', month: 'long', year: 'numeric',
						}).format(demoDate).toUpperCase();
					}
					if (mobileWeekdayEl) {
						mobileWeekdayEl.textContent = new Intl.DateTimeFormat(locale, {
							weekday: 'long',
						}).format(demoDate).toUpperCase();
					}
					if (mobileFullEl) {
						mobileFullEl.textContent = new Intl.DateTimeFormat(locale, {
							day: '2-digit', month: 'long', year: 'numeric',
						}).format(demoDate).toUpperCase();
					}
				}
			}
		}

		window.setInterval(updateCountdown, 1000);
	});
</script>
