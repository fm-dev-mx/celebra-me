---
import Layout from '@/layouts/Layout.astro';
---

<Layout title="Invitación no disponible" hideHeader={true} themeMode="dark">
	<main class="invitation-error">
		<h1>Invitación no disponible</h1>
		<p>Lo sentimos, esta invitación no está disponible en este momento. Intenta de nuevo más tarde.</p>
	</main>
	<style>
		.invitation-error {
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			min-height: 100vh;
			padding: 2rem;
			text-align: center;
			font-family: system-ui, -apple-system, sans-serif;
		}
		.invitation-error h1 {
			font-size: 1.5rem;
			margin-bottom: 1rem;
		}
		.invitation-error p {
			font-size: 1rem;
			line-height: 1.6;
			color: var(--color-text-muted);
			max-width: 480px;
		}
	</style>
</Layout>
