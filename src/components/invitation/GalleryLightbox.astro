---
import '@/styles/invitation/_gallery.scss';
---

<div class="gallery-lightbox" data-gallery-lightbox hidden role="dialog" aria-modal="true" aria-label="Vista ampliada de la imagen">
	<button type="button" class="gallery-lightbox__close" data-gallery-close aria-label="Cerrar galería">
		<svg
			xmlns="http://www.w3.org/2000/svg"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="1.5"
			stroke-linecap="round"
			stroke-linejoin="round"
		>
			<line x1="18" y1="6" x2="6" y2="18" />
			<line x1="6" y1="6" x2="18" y2="18" />
		</svg>
	</button>

	<div class="gallery-lightbox__content" data-gallery-content>
		<img src="" alt="" data-gallery-image />
		<div class="gallery-lightbox__footer" data-gallery-footer hidden>
			<p data-gallery-footer-text></p>
		</div>
	</div>
</div>

<script>
	const initialized = new WeakSet<HTMLElement>();

	const initLightbox = () => {
		const lightbox = document.querySelector('[data-gallery-lightbox]');
		if (!(lightbox instanceof HTMLElement)) return;
		if (initialized.has(lightbox)) return;
		initialized.add(lightbox);

		const lightboxImage = lightbox.querySelector<HTMLImageElement>('[data-gallery-image]');
		const lightboxFooterEl = lightbox.querySelector<HTMLElement>('[data-gallery-footer]');
		const lightboxFooterText = lightbox.querySelector<HTMLElement>('[data-gallery-footer-text]');
		const closeButton = lightbox.querySelector<HTMLButtonElement>('[data-gallery-close]');
		const content = lightbox.querySelector<HTMLElement>('[data-gallery-content]');

		if (!lightboxImage || !lightboxFooterEl || !lightboxFooterText || !closeButton || !content) {
			return;
		}

		const focusableSelectors = 'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';
		let lastFocusedElement: HTMLElement | null = null;

		const getFocusableElements = () =>
			Array.from(lightbox.querySelectorAll<HTMLElement>(focusableSelectors)).filter(
				(el) => !el.hasAttribute('disabled') && el.offsetParent !== null
			);

		const trapFocus = (e: KeyboardEvent) => {
			if (e.key !== 'Tab') return;
			const focusable = getFocusableElements();
			if (focusable.length === 0) return;
			const first = focusable[0];
			const last = focusable[focusable.length - 1];
			if (e.shiftKey && document.activeElement === first) {
				e.preventDefault();
				last.focus();
			} else if (!e.shiftKey && document.activeElement === last) {
				e.preventDefault();
				first.focus();
			}
		};

		const closeLightbox = () => {
			lightbox.hidden = true;
			document.body.style.overflow = '';
			lightbox.removeEventListener('keydown', trapFocus);
			lastFocusedElement?.focus();
		};

		const openLightbox = (src: string, caption: string, alt: string) => {
			lastFocusedElement = document.activeElement as HTMLElement;
			lightboxImage.src = src;
			lightboxImage.alt = caption || alt || '';

			lightboxFooterText.textContent = caption;
			lightboxFooterEl.hidden = !caption;

			lightbox.hidden = false;
			document.body.style.overflow = 'hidden';
			lightbox.addEventListener('keydown', trapFocus);
			requestAnimationFrame(() => closeButton.focus());
		};

		document.addEventListener('gallery:open', ((e: CustomEvent) => {
			openLightbox(e.detail.src, e.detail.caption, e.detail.alt);
		}) as EventListener);

		closeButton.addEventListener('click', (event) => {
			event.stopPropagation();
			closeLightbox();
		});
		lightbox.addEventListener('click', closeLightbox);
		content.addEventListener('click', (event) => event.stopPropagation());

		window.addEventListener('keydown', (event: KeyboardEvent) => {
			if (event.key === 'Escape' && !lightbox.hidden) {
				closeLightbox();
			}
		});
	};

	initLightbox();
</script>
