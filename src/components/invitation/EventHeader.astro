---
/**
 * src/components/invitation/EventHeader.astro
 *
 * Invitation Page implementation of the Header.
 * Context-aware: Uses event theme and guest-specific links.
 * Uses premium NavBarMobile for consistent mobile UX.
 */

import HeaderBase from '@components/common/HeaderBase.astro';
import NavBarMobile from '@components/ui/header/NavBarMobile.astro';
import '@styles/invitation/_event-header.scss';

export interface Props {
	links: {
		label: string;
		href: string;
	}[];
	variant?: string;
	initials?: string;
	eventName?: string;
	eventSubtitle?: string;
	isDemo?: boolean;
}

const {
	links,
	variant = 'standard',
	initials,
	eventName,
	eventSubtitle,
	isDemo = false,
} = Astro.props;
const RSVP_HREF = '#rsvp';
const rsvpLink = links.find((link) => link.href === RSVP_HREF);
const mobileLinks = links.filter((link) => link.href !== RSVP_HREF);
const desktopLinkHrefs = ['#inicio', '#event-location', '#galeria', '#itinerary', '#rsvp'];
const filteredDesktopLinks = links.filter((link) => desktopLinkHrefs.includes(link.href));
const desktopLinks = filteredDesktopLinks.length > 0 ? filteredDesktopLinks : links;
---

<HeaderBase transparentOnHero={true} headerId="event-header" variant={variant}>
	<div slot="logo">
		<a href="#" class="event-header__title">
			<span class="event-header__title-initials">{initials}</span>
		</a>
	</div>

	<div slot="desktop-nav" class="event-header__actions">
		{
			desktopLinks.map((link) => (
				<a
					href={link.href}
					class:list={[
						'event-header__action-btn',
						{ 'event-header__action-btn--cta': link.href === RSVP_HREF }
					]}
				>
					{link.label}
				</a>
			))
		}
	</div>

	<div slot="mobile-nav-premium">
		<NavBarMobile
			links={mobileLinks}
			headerId="event-header"
			desktopBreakpoint="lg"
			ctaLink={rsvpLink?.href}
			ctaLabel={rsvpLink?.label ?? 'Confirmar'}
			eventName={eventName}
			eventSubtitle={eventSubtitle}
			initials={initials}
			isDemo={isDemo}
		/>
	</div>
</HeaderBase>
