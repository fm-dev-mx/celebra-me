---
/**
 * src/components/invitation/EventHeader.astro
 *
 * Invitation Page implementation of the Header.
 * Context-aware: Uses event theme and guest-specific links.
 * Uses premium NavBarMobile for consistent mobile UX.
 */

import HeaderBase from '@components/common/HeaderBase.astro';
import NavBarMobile from '@components/ui/header/NavBarMobile.astro';
import '@styles/invitation/_event-header.scss';

export interface Props {
	eventName?: string;
	links: {
		label: string;
		href: string;
	}[];
	variant?: string;
}

const {
	eventName = 'Mi Evento',
	links,
	variant = 'standard',
} = Astro.props;

const RSVP_HREF = '#rsvp';
const rsvpLink = links.find((link) => link.href === RSVP_HREF);
const mobileLinks = rsvpLink
	? links.filter((link) => link.href !== RSVP_HREF)
	: links;
---

<HeaderBase transparentOnHero={true} headerId="event-header" variant={variant}>
	<div slot="logo">
		<a href="#" class="event-header__title">
			{eventName}
		</a>
	</div>

	<div slot="desktop-nav" class="event-header__actions">
		{
			links.map((link) => (
				<a
					href={link.href}
					class:list={[
						'event-header__action-btn',
						{ 'event-header__action-btn--cta': link.href === RSVP_HREF }
					]}
				>
					{link.label}
				</a>
			))
		}
	</div>

	<div slot="mobile-nav-premium">
		<NavBarMobile
			links={mobileLinks}
			headerId="event-header"
			desktopBreakpoint="xl"
			ctaLink={rsvpLink?.href}
			ctaLabel={rsvpLink ? 'Confirmar asistencia' : undefined}
		/>
	</div>
</HeaderBase>
