---
// src/components/invitation/Itinerary.astro
import '@/styles/invitation/_itinerary.scss';
import TimelineList from './TimelineList.astro';
import ItineraryProgram from './ItineraryProgram.astro';
import type { ItineraryItem } from '@/lib/adapters/types';
import type { ThemePreset } from '@/lib/theme/theme-contract';

interface Props {
	title?: string;
	subtitle?: string;
	items: ItineraryItem[];
	variant?: ThemePreset;
	monogram?: string;
}

const { title = "Itinerario", items, variant, monogram, subtitle } = Astro.props;
---

<section class="itinerary" id="itinerary" data-variant={variant}>
	<div class="itinerary__container">
		{title && (
			<div class="itinerary__header">
				<h2 class="itinerary__title">{title}</h2>
				{subtitle && (
					<p class="itinerary__subtitle" data-itinerary-subtitle>{subtitle}</p>
				)}
				<div class="itinerary__header-flourish" aria-hidden="true">
					<span class="flourish-line"></span>
					<span class="flourish-diamond"></span>
					<span class="flourish-line"></span>
				</div>
			</div>
		)}

		<div class="itinerary__timeline">
			<div class="itinerary__line-start" aria-hidden="true"></div>

			{variant === 'celestial-blue' ? (
				<ItineraryProgram items={items} variant={variant} monogram={monogram} />
			) : (
				<TimelineList items={items} variant={variant} />
			)}

			<div class="itinerary__line-end" aria-hidden="true"></div>
		</div>
	</div>
</section>
