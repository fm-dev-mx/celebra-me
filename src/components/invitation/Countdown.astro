---
// src/components/invitation/Countdown.astro
// Premium countdown section
import '@/styles/invitation/_countdown.scss';
import CountdownTimer from '@/components/invitation/CountdownTimer.astro';
import type { CountdownVariant } from '@/lib/theme/theme-contract';

interface Props {
	eventDate: string; // ISO Date string
	title?: string;
	footerText?: string;
	variant?: CountdownVariant;
}

const {
	eventDate,
	title = "¡Falta muy poco!",
	footerText,
	variant = 'editorial',
} = Astro.props;

// Invitation dates are floating event-local values serialized with a UTC
// suffix (e.g. "2026-08-01T18:00:00.000Z"). timeZone: 'UTC' prevents
// visual date shifting on non-UTC servers.
function formatCountdownDate(dateString: string): { desktop: string; mobileWeekday: string; mobileFull: string } {
	const date = new Date(dateString);
	if (isNaN(date.getTime())) {
		return { desktop: 'Fecha no válida', mobileWeekday: 'Fecha', mobileFull: 'no válida' };
	}
	const locale = 'es-MX';
	const tz = { timeZone: 'UTC' } as const;
	const fmt = (opts: Intl.DateTimeFormatOptions) =>
		new Intl.DateTimeFormat(locale, { ...opts, ...tz }).format(date).toUpperCase();
	return {
		desktop: fmt({ weekday: 'long', day: '2-digit', month: 'long', year: 'numeric' }),
		mobileWeekday: fmt({ weekday: 'long' }),
		mobileFull: fmt({ day: '2-digit', month: 'long', year: 'numeric' }),
	};
}

const formattedDate = formatCountdownDate(eventDate);
---

<section class="countdown-section" id="countdown" data-variant={variant}>
	<div class="countdown-texture" aria-hidden="true"></div>
	<div class="countdown-container">
		<h2 class="countdown-title">{title}</h2>

		<div class="countdown-timer-wrapper">
			<CountdownTimer eventDate={eventDate} />
		</div>

		<div class="countdown-date">
			<div class="subtitle-line"></div>
			<p class="event-date">
				<span class="event-date-desktop">{formattedDate.desktop}</span>
				<span class="event-date-mobile">
					<span class="event-date-mobile-weekday">{formattedDate.mobileWeekday}</span>
					<span class="event-date-mobile-full">{formattedDate.mobileFull}</span>
				</span>
			</p>
			<div class="subtitle-line"></div>
		</div>

		{footerText && (
			<footer class="countdown-footer">
				<p class="countdown-invitation-text">{footerText}</p>
			</footer>
		)}
	</div>
</section>
<script>
	const countdownSections = Array.from(document.querySelectorAll('.countdown-section'));
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('is-visible');
				}
			});
		},
		{ threshold: 0.15 },
	);

	countdownSections.forEach((section) => observer.observe(section));
</script>

