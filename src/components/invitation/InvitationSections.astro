---
import Countdown from '@/components/invitation/Countdown.astro';
import EventLocation from '@/components/invitation/EventLocation.astro';
import Family from '@/components/invitation/Family.astro';
import Gallery from '@/components/invitation/Gallery.astro';
import Gifts from '@/components/invitation/Gifts.astro';
import Interlude from '@/components/invitation/Interlude.astro';
import Itinerary from '@/components/invitation/Itinerary.astro';
import PersonalizedAccess from '@/components/invitation/PersonalizedAccess.astro';
import Quote from '@/components/invitation/Quote.astro';
import RSVP from '@/components/invitation/RSVP';
import ThankYou from '@/components/invitation/ThankYou.astro';
import type { InvitationPageData } from '@/lib/invitation/page-data';
import type { ComponentProps } from 'astro/types';

interface Props {
	presenter: InvitationPageData;
}

type RenderDescriptor =
	| { kind: 'interlude'; props: ComponentProps<typeof Interlude> }
	| { kind: 'quote'; props: ComponentProps<typeof Quote> }
	| { kind: 'family'; props: ComponentProps<typeof Family> }
	| { kind: 'gallery'; props: ComponentProps<typeof Gallery> }
	| { kind: 'countdown'; props: ComponentProps<typeof Countdown> }
	| { kind: 'location'; props: ComponentProps<typeof EventLocation> }
	| { kind: 'itinerary'; props: ComponentProps<typeof Itinerary> }
	| { kind: 'rsvp'; props: ComponentProps<typeof RSVP> }
	| { kind: 'gifts'; props: ComponentProps<typeof Gifts> }
	| { kind: 'thankYou'; props: ComponentProps<typeof ThankYou> }
	| { kind: 'personalized-access'; props: ComponentProps<typeof PersonalizedAccess> };

const { presenter } = Astro.props;
const { renderPlan, sections, personalizedAccess, rsvp, themePreset } = presenter;

const renderInterlude = (
	block: Extract<(typeof renderPlan)[number], { type: 'interlude' }>,
): RenderDescriptor => ({
	kind: 'interlude',
	props: {
		image: block.image,
		alt: block.alt,
		height: block.height,
		variant: block.variant ?? themePreset,
	},
});

const renderSection = (section: string) => {
	switch (section) {
		case 'quote':
			return sections.quote
				? {
						kind: 'quote',
						props: {
							text: sections.quote.text,
							author: sections.quote.author,
							variant: sections.quote.variant,
							animation: sections.quote.animation,
						},
					}
				: null;
		case 'family':
			return sections.family
				? {
						kind: 'family',
						props: {
							parents: sections.family.parents,
							spouse: sections.family.spouse,
							children: sections.family.children,
							godparents: sections.family.godparents,
							groups: sections.family.groups,
							featuredImage: sections.family.featuredImage,
							labels: sections.family.labels,
							celebrantName: sections.family.celebrantName,
							variant: sections.family.variant,
						},
					}
				: null;
		case 'gallery':
			return sections.gallery
				? {
						kind: 'gallery',
						props: {
							title: sections.gallery.title,
							subtitle: sections.gallery.subtitle,
							items: sections.gallery.items,
							variant: sections.gallery.variant,
						},
					}
				: null;
		case 'countdown':
			return sections.countdown
				? {
						kind: 'countdown',
						props: {
							eventDate: sections.countdown.eventDate,
							title: sections.countdown.title,
							subtitlePrefix: sections.countdown.subtitlePrefix,
							footerText: sections.countdown.footerText,
							variant: sections.countdown.variant,
							showParticles: sections.countdown.showParticles,
						},
					}
				: null;
		case 'location':
			return sections.location
				? {
						kind: 'location',
						props: {
							ceremony: sections.location.ceremony,
							reception: sections.location.reception,
							indications: sections.location.indications,
							variant: sections.location.variant,
							mapStyle: sections.location.mapStyle,
							showFlourishes: sections.location.showFlourishes,
						},
					}
				: null;
		case 'itinerary':
			return sections.itinerary
				? {
						kind: 'itinerary',
						props: {
							title: sections.itinerary.title,
							items: sections.itinerary.items,
							variant: sections.itinerary.variant,
						},
					}
				: null;
		case 'rsvp':
			return rsvp ? { kind: 'rsvp', props: rsvp } : null;
		case 'gifts':
			return sections.gifts
				? {
						kind: 'gifts',
						props: {
							gifts: sections.gifts.items,
							title: sections.gifts.title,
							subtitle: sections.gifts.subtitle,
							variant: sections.gifts.variant,
						},
					}
				: null;
		case 'thankYou':
			return sections.thankYou
				? {
						kind: 'thankYou',
						props: {
							message: sections.thankYou.message,
							closingName: sections.thankYou.closingName,
							image: sections.thankYou.image,
							variant: sections.thankYou.variant,
						},
					}
				: null;
		default:
			return null;
	}
};

const renderBlock = (block: (typeof renderPlan)[number]) => {
	if (block.type === 'interlude') return renderInterlude(block);

	if (block.type === 'personalized-access') {
		return personalizedAccess
			? {
					kind: 'personalized-access',
					props: {
						guestName: personalizedAccess.guestName,
						maxAllowedAttendees: personalizedAccess.maxAllowedAttendees,
					},
				}
			: null;
	}

	return renderSection(block.section);
};
---

{
	renderPlan.map((block) => {
		const resolved = renderBlock(block) as RenderDescriptor | null;
		if (!resolved) return null;

		switch (resolved.kind) {
			case 'interlude':
				return <Interlude {...resolved.props} />;
			case 'quote':
				return <Quote {...resolved.props} />;
			case 'family':
				return <Family {...resolved.props} />;
			case 'gallery':
				return <Gallery {...resolved.props} />;
			case 'countdown':
				return <Countdown {...resolved.props} />;
			case 'location':
				return <EventLocation {...resolved.props} />;
			case 'itinerary':
				return <Itinerary {...resolved.props} />;
			case 'rsvp':
				return <RSVP client:visible {...resolved.props} />;
			case 'gifts':
				return <Gifts {...resolved.props} />;
			case 'thankYou':
				return <ThankYou {...resolved.props} />;
			case 'personalized-access':
				return <PersonalizedAccess {...resolved.props} />;
			default:
				return null;
		}
	})
}
