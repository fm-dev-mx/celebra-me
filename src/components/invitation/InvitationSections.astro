---
import Countdown from '@/components/invitation/Countdown.astro';
import EventLocation from '@/components/invitation/EventLocation.astro';
import Family from '@/components/invitation/Family.astro';
import Gallery from '@/components/invitation/Gallery.astro';
import Gifts from '@/components/invitation/Gifts.astro';
import Interlude from '@/components/invitation/Interlude.astro';
import Itinerary from '@/components/invitation/Itinerary.astro';
import PersonalizedAccess from '@/components/invitation/PersonalizedAccess.astro';
import Quote from '@/components/invitation/Quote.astro';
import RSVP from '@/components/invitation/RSVP';
import ThankYou from '@/components/invitation/ThankYou.astro';
import type { InvitationPageData } from '@/lib/invitation/page-data';
import {
	buildInvitationSectionRenderDescriptors,
	type InvitationSectionRenderDescriptor,
} from '@/lib/invitation/section-render-data';

interface Props {
	pageData: InvitationPageData;
}

const { pageData } = Astro.props;
const renderDescriptors = buildInvitationSectionRenderDescriptors(pageData);
---

{
	renderDescriptors.map((descriptor: InvitationSectionRenderDescriptor) => {
		switch (descriptor.kind) {
			case 'interlude':
				return <Interlude {...descriptor.props} />;
			case 'quote':
				return <Quote {...descriptor.props} />;
			case 'family':
				return <Family {...descriptor.props} />;
			case 'gallery':
				return <Gallery {...descriptor.props} />;
			case 'countdown':
				return <Countdown {...descriptor.props} />;
			case 'location':
				return <EventLocation {...descriptor.props} />;
			case 'itinerary':
				return <Itinerary {...descriptor.props} />;
			case 'rsvp':
				return <RSVP client:visible {...descriptor.props} />;
			case 'gifts':
				return <Gifts {...descriptor.props} />;
			case 'thankYou':
				return <ThankYou {...descriptor.props} />;
			case 'personalized-access':
				return <PersonalizedAccess {...descriptor.props} />;
			default:
				return null;
		}
	})
}
