---
import Countdown from '@/components/invitation/Countdown.astro';
import EventLocation from '@/components/invitation/EventLocation.astro';
import Family from '@/components/invitation/Family.astro';
import Gallery from '@/components/invitation/Gallery.astro';
import Gifts from '@/components/invitation/Gifts.astro';
import Interlude from '@/components/invitation/Interlude.astro';
import Itinerary from '@/components/invitation/Itinerary.astro';
import PersonalizedAccess from '@/components/invitation/PersonalizedAccess.astro';
import Quote from '@/components/invitation/Quote.astro';
import RSVP from '@/components/invitation/RSVP';
import ThankYou from '@/components/invitation/ThankYou.astro';
import type { InvitationPageContext } from '@/lib/invitation/page-data';
import {
	buildInvitationSectionRenderDescriptors,
} from '@/lib/invitation/section-render-data';

interface Props {
	pageContext: InvitationPageContext;
}

const { pageContext } = Astro.props;
const sections = buildInvitationSectionRenderDescriptors(pageContext);

const interludeIndices = new Map<number, number>();
{
	let count = 0;
	for (const [i, s] of sections.entries()) {
		if (s.component === 'interlude') {
			count++;
			interludeIndices.set(i, count);
		}
	}
}
---

<div id="invitation-sections-container" data-total-sections={sections.length}>
	{
		sections.map(({component, props, afterInterlude}, index) => {
			const interludeIndex = component === 'interlude' ? interludeIndices.get(index) : undefined;

			return (
				<div
					data-section-id={`section-${index}-${component}`}
					class="invitation-section-wrapper"
					{...(afterInterlude && { 'data-after-interlude': '' })}
				>
					{component === 'interlude' && <Interlude {...props} interludeIndex={interludeIndex} />}
					{component === 'quote' && <Quote {...props} />}
					{component === 'family' && <Family {...props} />}
					{component === 'gallery' && <Gallery {...props} />}
					{component === 'countdown' && <Countdown {...props} />}
					{component === 'location' && <EventLocation {...props} />}
					{component === 'itinerary' && <Itinerary {...props} />}
					{component === 'rsvp' && <RSVP client:visible {...props} />}
					{component === 'gifts' && <Gifts {...props} />}
					{component === 'thankYou' && <ThankYou {...props} />}
					{component === 'personalized-access' && <PersonalizedAccess {...props} />}
				</div>
			);
		})
	}
</div>
