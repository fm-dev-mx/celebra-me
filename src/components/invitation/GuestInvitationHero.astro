---
import '@styles/invitation/_hero.scss';
interface Props {
	eventTitle: string;
	guestName: string;
}

const { eventTitle, guestName } = Astro.props as Props;
---

<section class="invitation-hero guest-invitation-hero">
	<div class="invitation-hero__content">
		<span class="invitation-hero__label">Especialmente para</span>
		<h1 class="invitation-hero__title">{guestName}</h1>
		<div class="invitation-hero__divider"></div>
		<div class="invitation-hero__details">
			<p>Nos encantaría contar contigo en <br /><strong>{eventTitle}</strong></p>
		</div>
	</div>
</section>

