---
// src/components/invitation/Hero.astro
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { ImageAsset } from '@/lib/assets/asset-registry';
import '@/styles/invitation/_hero.scss';

interface Props {
	name: string;
	secondaryName?: string; // New prop for Wedding (Groom/Bride)
	label?: string; // New prop for generic label
	nickname?: string;
	date: string;
	time?: string;
	venueName: string;
	backgroundImage: ImageMetadata | ImageAsset;
	portrait?: ImageMetadata | ImageAsset; // ADU-8: Optional celebrant portrait
	variant?: string;
	guestName?: string;
}

const {
	name,
	secondaryName,
	label,
	nickname,
	date,
	time,
	venueName,
	backgroundImage,
	portrait,
	variant = 'standard',
	guestName,
} = Astro.props;

// Distinguish between ImageAsset (wrapper with .src) and ImageMetadata (Astro object)
const getSrc = (image: ImageMetadata | ImageAsset): string => {
	if ('src' in image) {
		const src = image.src as unknown;
		if (typeof src === 'string') return src;
		if (src && typeof src === 'object' && 'src' in src && typeof (src as any).src === 'string') {
			return (src as any).src;
		}
	}
	// Fallback for ImageMetadata
	return image as unknown as string;
};

const bgSrc = getSrc(backgroundImage);
const portraitSrc = portrait ? getSrc(portrait) : null;

const formattedDate = new Date(date).toLocaleDateString('es-MX', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
});
---

<section id="inicio" class="invitation-hero" data-variant={variant}>
	<div class="invitation-hero__background">
		<Image
			src={bgSrc}
			alt={name}
			width={1920}
			height={1080}
			format="webp"
			quality={80}
			loading="eager"
			fetchpriority="high"
		/>
	</div>

	<div class="invitation-hero__content">
		{label && <span class="invitation-hero__label">{label}</span>}

		{guestName && (
			<div class="invitation-hero__personal-greeting">
				<span>¡Hola, {guestName}!</span>
			</div>
		)}

		<h1 class="invitation-hero__title">
			{name}
			{secondaryName && (
				<span class="invitation-hero__ampersand">&</span>
				<span class="invitation-hero__secondary-name">{secondaryName}</span>
			)}
		</h1>

		{nickname && (
			<div class="invitation-hero__nickname-badge">
				<span>{nickname}</span>
			</div>
		)}

		{portraitSrc && (
			<div class="invitation-hero__portrait">
				<Image
					src={portraitSrc}
					alt={`Retrato de ${name}`}
					width={600}
					height={800}
					format="webp"
					quality={90}
				/>
			</div>
		)}

		<div class="invitation-hero__divider"></div>

		<div class="invitation-hero__details">
			<p class="invitation-hero__date">{formattedDate}</p>
			{time && <p class="invitation-hero__time">{time}</p>}
			<p class="invitation-hero__venue">
				<span class="calligraphy-accent">en</span> {venueName}
			</p>
		</div>
	</div>

	<div class="invitation-hero__scroll-indicator">
		<span class="invitation-hero__scroll-text">Desliza</span>
		<div class="invitation-hero__scroll-chevron">
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<path d="m6 9 6 6 6-6"/>
			</svg>
		</div>
	</div>
</section>
