---
// src/components/invitation/Hero.astro
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { ImageAsset } from '@/lib/assets/asset-registry';
import type { HeroLayoutVariant, ThemePreset } from '@/lib/theme/theme-contract';
import '@/styles/invitation/_hero.scss';

interface Props {
	name: string;
	secondaryName?: string;
	label?: string;
	nickname?: string;
	date: string;
	time?: string;
	venueName: string;
	backgroundImage: ImageMetadata | ImageAsset;
	portrait?: ImageMetadata | ImageAsset;
	variant?: ThemePreset;
	layoutVariant?: HeroLayoutVariant;
	guestName?: string;
}

const {
	name,
	secondaryName,
	label,
	nickname,
	date,
	time,
	venueName,
	backgroundImage,
	portrait,
	variant,
	layoutVariant,
	guestName,
} = Astro.props;

// Universal image resolution helper
const resolveImage = (image: ImageMetadata | ImageAsset) => {
	return 'src' in image ? image.src : image;
};

const bgSrc = resolveImage(backgroundImage);
const portraitSrc = portrait ? resolveImage(portrait) : null;

const formattedDate = new Date(date).toLocaleDateString('es-MX', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
});

// Robust name handling for editorial layout
const names = name.trim().split(/\s+/);
const firstName = names.slice(0, 2).join(' ');
const surnames = names.slice(2);

---

<section
	id="inicio"
	class="invitation-hero"
	data-variant={variant}
	data-layout-variant={layoutVariant}
>
	<div class="invitation-hero__background">
		<Image
			src={bgSrc}
			alt={name}
			width={1920}
			height={1080}
			format="webp"
			quality={80}
			loading="eager"
			fetchpriority="high"
		/>
	</div>

	<div class="invitation-hero__content">
		{label && <span class="invitation-hero__label">{label}</span>}

		<div class="invitation-hero__title-wrapper">
			<h1 class="invitation-hero__title">
				<span class="invitation-hero__title-line">{firstName}</span>
				{surnames.map((surname) => (
					<Fragment key={surname}>
						<br />
						<span class="invitation-hero__title-line invitation-hero__title-line--surname">{surname}</span>
					</Fragment>
				))}
				{secondaryName && (
					<>
						<br />
						<span class="invitation-hero__ampersand">&</span>
						<span class="invitation-hero__secondary-name">{secondaryName}</span>
					</>
				)}
			</h1>
		</div>

		{nickname && (
			<div class="invitation-hero__nickname-badge">
				<span>{nickname}</span>
			</div>
		)}

		{portraitSrc && (
			<div class="invitation-hero__portrait">
				<Image
					src={portraitSrc}
					alt={`Retrato de ${name}`}
					width={600}
					height={800}
					format="webp"
					quality={90}
				/>
			</div>
		)}

		<div class="invitation-hero__divider"></div>

		<div class="invitation-hero__details">
			<p class="invitation-hero__date">{formattedDate}</p>
			{time && <p class="invitation-hero__time">{time}</p>}
			<p class="invitation-hero__venue">
				<span class="calligraphy-accent">en</span> {venueName}
			</p>
		</div>
	</div>

	<div class="invitation-hero__scroll-indicator">
		<span class="invitation-hero__scroll-text">Desliza</span>
		<div class="invitation-hero__scroll-chevron">
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<path d="m6 9 6 6 6-6"/>
			</svg>
		</div>
	</div>
</section>
