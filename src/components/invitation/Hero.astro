---
// src/components/invitation/Hero.astro
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { ImageAsset } from '@/lib/assets/asset-registry';
import type { ThemePreset } from '@/lib/theme/theme-contract';
import '@/styles/invitation/_hero.scss';

interface Props {
	name: string;
	secondaryName?: string;
	label?: string;
	nickname?: string;
	date: string;
	time?: string;
	venueName?: string;
	backgroundImage: ImageMetadata | ImageAsset;
	backgroundImageDesktop?: { src: string };
	backgroundImageMobile?: ImageMetadata | ImageAsset;
	portrait?: ImageMetadata | ImageAsset;
	variant?: ThemePreset;
	guestName?: string;
	scrollLabel?: string;
	focalPoint?: string;
	focalPointMobile?: string;
	focalPointTablet?: string;
	focalPointDesktop?: string;
}

const {
	name,
	secondaryName,
	label,
	nickname,
	date,
	time,
	venueName,
	backgroundImage,
	backgroundImageDesktop,
	backgroundImageMobile,
	portrait,
	variant,
	scrollLabel,
	focalPoint,
	focalPointMobile,
	focalPointTablet,
	focalPointDesktop,
} = Astro.props;

const resolveImage = (image: ImageMetadata | ImageAsset): ImageMetadata =>
	'src' in image ? (image.src as ImageMetadata) : image;

const bgSrc = resolveImage(backgroundImage);
const desktopBgSrc = backgroundImageDesktop?.src ?? null;
const mobileBgSrc = backgroundImageMobile
	? typeof backgroundImageMobile.src === 'string'
		? backgroundImageMobile.src
		: backgroundImageMobile.src.src
	: null;
const portraitSrc = portrait ? resolveImage(portrait) : null;

// Invitation dates are floating event-local values serialized with a UTC
// suffix (e.g. "2026-08-01T18:00:00.000Z"). timeZone: 'UTC' prevents
// visual date shifting on non-UTC servers.
const formattedDate = new Date(date).toLocaleDateString('es-MX', {
	day: 'numeric',
	month: 'long',
	year: 'numeric',
	timeZone: 'UTC',
});

// Robust name handling for editorial layout
const names = name.trim().split(/\s+/);
const firstName = names.slice(0, 2).join(' ');
const surnames = names.slice(2);

const fpDefault = focalPoint || '50% 40%';
const fpMobile = focalPointMobile || fpDefault;
const fpTablet = focalPointTablet || fpDefault;
const fpDesktop = focalPointDesktop || fpDefault;

---

<section
	id="inicio"
	class="invitation-hero"
	data-variant={variant}
>
	<div class="invitation-hero__background">
		<picture>
			{mobileBgSrc && (
				<source media="(max-width: 991px)" srcset={mobileBgSrc} />
			)}
			{desktopBgSrc && (
				<source media="(min-width: 992px)" srcset={desktopBgSrc} />
			)}
			<Image
				src={bgSrc}
				alt={name}
				width={1080}
				height={1920}
				format="webp"
				quality={80}
				loading="eager"
				fetchpriority="high"
			/>
		</picture>
	</div>

	<div class="invitation-hero__content">
		{label && <span class="invitation-hero__label">{label}</span>}

		<div class="invitation-hero__title-wrapper">
			<h1 class="invitation-hero__title">
				<span class="invitation-hero__title-line">{firstName}</span>
				{surnames.map((surname) => (
					<Fragment key={surname}>
						<br />
						<span class="invitation-hero__title-line invitation-hero__title-line--surname">{surname}</span>
					</Fragment>
				))}
				{secondaryName && (
					<>
						<br />
						<span class="invitation-hero__ampersand">&</span>
						<span class="invitation-hero__secondary-name">{secondaryName}</span>
					</>
				)}
			</h1>
		</div>

		{nickname && (
			<div class="invitation-hero__nickname-badge">
				<span>{nickname}</span>
			</div>
		)}

		{portraitSrc && (
			<div class="invitation-hero__portrait">
				<Image
					src={portraitSrc}
					alt={`Retrato de ${name}`}
					width={600}
					height={800}
					format="webp"
					quality={90}
				/>
			</div>
		)}

		<div class="invitation-hero__divider"></div>

		<div class="invitation-hero__details">
			<p class="invitation-hero__date">{formattedDate}</p>
			{time && <p class="invitation-hero__time">{time}</p>}
			{venueName && <p class="invitation-hero__venue">
				<span class="calligraphy-accent">en</span> {venueName}
			</p>}
		</div>
	</div>

	<div class="invitation-hero__scroll-indicator">
		<span class="invitation-hero__scroll-text">{scrollLabel || 'Desliza'}</span>
		<div class="invitation-hero__scroll-chevron">
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<path d="m6 9 6 6 6-6"/>
			</svg>
		</div>
	</div>
</section>

<style define:vars={{
	fpDefault,
	fpMobile,
	fpTablet,
	fpDesktop,
}}>
	.invitation-hero {
		--hero-focal-point-default: var(--fpDefault);
		--hero-focal-point-mobile: var(--fpMobile);
		--hero-focal-point-tablet: var(--fpTablet);
		--hero-focal-point-desktop: var(--fpDesktop);
	}
</style>


