---
// src/components/invitation/Gallery.astro
import type { ImageMetadata } from 'astro';
import type { ImageAsset } from '@/lib/assets/asset-registry';
import PhotoGallery from './PhotoGallery.astro';
import GalleryLightbox from './GalleryLightbox.astro';
import '@/styles/invitation/_gallery.scss';

interface GalleryItem {
	image: ImageMetadata | ImageAsset;
	caption?: string;
	focalPoint?: string;
	focalPointMobile?: string;
	focalPointTablet?: string;
	focalPointDesktop?: string;
}

interface Props {
	eyebrow?: string;
	title?: string;
	subtitle?: string;
	items: GalleryItem[];
	variant?: string;
	presentation?: 'pet-keepsake';
}

const { eyebrow = '', title, subtitle, items, variant = 'standard', presentation } = Astro.props;

if (!items || items.length === 0) return null;
---

<section id="galeria" class="gallery-section" data-variant={variant} {...(presentation && { 'data-presentation': presentation })}>
	<div class="gallery-section__container">
		<header class="gallery-section__header">
			{eyebrow && <span class="gallery-section__eyebrow">{eyebrow}</span>}
			<h2 class="gallery-section__title">{title}</h2>
			{subtitle && <p class="gallery-section__subtitle">{subtitle}</p>}
		</header>

		<PhotoGallery items={items} variant={variant} />
	</div>
</section>

<GalleryLightbox variant={variant} />
