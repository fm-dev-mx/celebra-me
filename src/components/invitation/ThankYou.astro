---
// src/components/invitation/ThankYou.astro
import '@/styles/invitation/_thank-you.scss';
import OptimizedImage from '@/components/common/OptimizedImage.astro';
import type { ImageAsset } from '@/lib/assets/asset-registry';

interface Props {
	message: string;
	closingName: string;
	image?: string | ImageAsset;
	variant?: string;
	focalPoint?: string;
	overlayAnchor?: 'left' | 'right' | 'top' | 'bottom';
	overlaySafeArea?: {
		x: number;
		y: number;
		width: number;
		height: number;
	};
}

const {
	message,
	closingName,
	image,
	variant = 'standard',
	focalPoint,
	overlayAnchor,
	overlaySafeArea,
} = Astro.props;
const isCelestialBlue = variant === 'celestial-blue';
const hasSubjectAwareOverlay = Boolean(overlayAnchor || overlaySafeArea);

const firstLetter = message.charAt(0);
const remainingMessage = message.slice(1);

const IMAGE_CONFIGS = {
	'subject-aware': {
		width: 1600,
		height: 2000,
		widths: [640, 960, 1200, 1600],
		sizes: '100vw',
		format: 'webp' as const,
		quality: 90,
		class: 'photo-image',
	},
	'celestial-blue': {
		width: 700,
		height: 1050,
		class: 'photo-image thank-you-editorial__image',
	},
	standard: {
		width: 400,
		height: 400,
		class: 'photo-image',
	},
} as const;

const configKey: keyof typeof IMAGE_CONFIGS = hasSubjectAwareOverlay ? 'subject-aware' : (variant in IMAGE_CONFIGS ? (variant as keyof typeof IMAGE_CONFIGS) : 'standard');
const imageConfig = IMAGE_CONFIGS[configKey];

---

<section
	id="thank-you-section"
	class="thank-you-section"
	data-variant={variant}
	data-focal-point={focalPoint || 'center'}
	data-overlay-anchor={overlayAnchor}
	data-has-overlay-safe-area={overlaySafeArea ? 'true' : undefined}
>
	{
		isCelestialBlue ? (
			<div class="thank-you-editorial">
				<div class="thank-you-editorial__ambient" aria-hidden="true" />
				{image && (
					<figure class="thank-you-editorial__media photo-frame">
						<div class="thank-you-editorial__image-shell">
							<OptimizedImage
								imagePath={image}
								alt={closingName}
								{...imageConfig}
							/>
						</div>
					</figure>
				)}

				<div class="thank-you-editorial__copy">
					<div class="message-container">
						<p class="thank-you-message">
							<span class="drop-cap">{firstLetter}</span>{remainingMessage}
						</p>
					</div>

					<div class="signature-block">
						<p class="closing-name">
							{closingName}
						</p>
					</div>

					<footer class="thank-you-footer">
						<p>Concierge digital por Celebra-me</p>
					</footer>
				</div>
			</div>
		) : (
			<div class="thank-you-content">
				{image && (
					<div class="photo-frame">
						<OptimizedImage
							imagePath={image}
							alt={closingName}
							{...imageConfig}
						/>
					</div>
				)}
				<div class="message-container">
					<p class="thank-you-message">
						<span class="drop-cap">{firstLetter}</span>{remainingMessage}
					</p>
				</div>

				<div class="signature-block">
					<p class="closing-name">
						{closingName}
					</p>
				</div>

				<footer class="thank-you-footer">
					<p>Concierge digital por Celebra-me</p>
				</footer>
			</div>
		)
	}
</section>

<style define:vars={{
	safeX: overlaySafeArea ? `${overlaySafeArea.x * 100}%` : '0%',
	safeY: overlaySafeArea ? `${overlaySafeArea.y * 100}%` : '0%',
	safeW: overlaySafeArea ? `${overlaySafeArea.width * 100}%` : '0%',
	safeH: overlaySafeArea ? `${overlaySafeArea.height * 100}%` : '0%',
}}>
	.thank-you-section {
		--thank-you-safe-x: var(--safeX);
		--thank-you-safe-y: var(--safeY);
		--thank-you-safe-width: var(--safeW);
		--thank-you-safe-height: var(--safeH);
	}
</style>

<script>
document.querySelectorAll<HTMLElement>('.thank-you-section[data-focal-point]').forEach((section) => {
	section.style.setProperty('--thank-you-focal-point', section.dataset.focalPoint || 'center');
});
</script>
