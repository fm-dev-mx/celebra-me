---
// src/components/invitation/Footer.astro
import '@/styles/invitation/_footer.scss';
import Logo from '@/components/ui/Logo.astro';
import OptimizedImage from '@/components/common/OptimizedImage.astro';
import type { SharedSectionVariant } from '@/lib/theme/theme-contract';
import { getContactPhone, getWhatsAppLink, isPlaceholderContactPhone } from '@/utils/whatsapp';

interface Props {
	eventSlug?: string;
	showEnvelope?: boolean;
	variant?: SharedSectionVariant;
	closingPhrase?: string;
	showFooterBranding?: boolean;
	showContactCta?: boolean;
}

const {
	eventSlug,
	showEnvelope = false,
	variant = 'standard',
	closingPhrase,
	showFooterBranding = true,
	showContactCta = true,
} = Astro.props;
const hasReplay = Boolean(showEnvelope && eventSlug);
const logoVariant = variant === 'editorial' ? 'footer' : 'default';

const whatsappMessage = 'Hola, estoy interesado en crear una invitación digital.';
const whatsappLink = getWhatsAppLink(whatsappMessage);
const shouldShowContactCta = showContactCta && !isPlaceholderContactPhone(getContactPhone());
---

<footer
	class="invitation-footer"
	data-variant={variant}
>
	{closingPhrase && (
		<p class="footer__closing-phrase">{closingPhrase}</p>
	)}

	<div class="footer__divider" aria-hidden="true"></div>

	<div class="footer__content">
		{showFooterBranding || shouldShowContactCta ? (
		<div class="footer__primary-row">
			{showFooterBranding && (
			<div class="footer__info">
				<p class="powered-by">Powered by</p>
				<Logo
					variant={logoVariant}
					altText="Celebra-me"
					class:list={[{ 'footer-brand-logo': variant === 'editorial' }]}
				/>
			</div>
			)}

			{shouldShowContactCta && (
			<div class="footer__actions">
				<a
					class="whatsapp-button"
					href={whatsappLink}
					target="_blank"
					rel="noopener noreferrer"
				>
					<OptimizedImage
						imagePath="/icons/whatsappIcon.svg"
						alt="WhatsApp"
						width={16}
						height={16}
						class:list={[
							{
								'footer-action__icon-media': variant === 'editorial',
							},
						]}
					/>
					<span>Contáctanos</span>
				</a>
			</div>
			)}
		</div>
		) : null}

		{hasReplay && (
			<button
				type="button"
				class="footer__replay-link"
				data-slug={eventSlug}
				aria-label="Volver a ver la apertura del sobre"
			>
				Volver a ver la apertura
			</button>
		)}
	</div>
</footer>

{hasReplay && (
	<script>
		const replayLink = document.querySelector('.footer__replay-link');

		if (replayLink instanceof HTMLElement) {
			replayLink.addEventListener('click', () => {
				const slug = replayLink.dataset.slug;
				if (!slug) {
					return;
				}

				localStorage.removeItem(`envelope-opened-${slug}`);
				window.location.reload();
			});
		}
	</script>
)}
