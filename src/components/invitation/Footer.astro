---
// src/components/invitation/Footer.astro
import '@/styles/invitation/_footer.scss';
import Logo from '@/components/ui/Logo.astro';
import OptimizedImage from '@/components/common/OptimizedImage.astro';
import type { SharedSectionVariant } from '@/lib/theme/theme-contract';

interface Props {
	eventSlug?: string;
	showEnvelope?: boolean;
	variant?: SharedSectionVariant;
}

const { eventSlug, showEnvelope = false, variant = 'standard' } = Astro.props;
const hasReplay = Boolean(showEnvelope && eventSlug);
const isEditorialFooter = variant === 'editorial';
const logoVariant = isEditorialFooter ? 'footer' : 'default';

// Define contact details
const contactNumber = '526681167477';
const whatsappMessage = 'Hola, estoy interesado en crear una invitación digital.';
const whatsappLink = `https://api.whatsapp.com/send?phone=${contactNumber}&text=${encodeURIComponent(whatsappMessage)}`;
---

<footer
	class:list={[
		'invitation-footer',
	]}
	data-variant={variant}
>
	<div class:list={['footer-content', { 'footer-content--with-replay': hasReplay }]}>
		<div class="footer-info">
			<p class="powered-by">Powered by</p>
			<Logo
				variant={logoVariant}
				altText="Celebra-me"
				class:list={[{ 'footer-brand-logo': isEditorialFooter }]}
			/>
		</div>

		<div class="footer-contact">
			<a
				class="whatsapp-button"
				href={whatsappLink}
				target="_blank"
				rel="noopener noreferrer"
			>
				<OptimizedImage
					imagePath="/icons/whatsappIcon.svg"
					alt="WhatsApp"
					width={24}
					height={24}
					class:list={[
						{
							'footer-action__icon-media': isEditorialFooter,
							'w-6 h-6': !isEditorialFooter,
						},
					]}
				/>
				Contáctanos
			</a>
		</div>

		{hasReplay && (
			<button
				type="button"
				class="footer__replay-link"
				data-slug={eventSlug}
				aria-label="Volver a ver la apertura del sobre"
			>
				✉ Volver a ver la apertura
			</button>
		)}
	</div>
	{hasReplay && (
		<script>
			const replayLink = document.querySelector('.footer__replay-link');

			if (replayLink instanceof HTMLElement) {
				replayLink.addEventListener('click', () => {
					const slug = replayLink.dataset.slug;
					if (!slug) {
						return;
					}

					localStorage.removeItem(`envelope-opened-${slug}`);
					window.location.reload();
				});
			}
		</script>
	)}
</footer>
