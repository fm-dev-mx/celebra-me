---
/*
  EventLocation Component
  Displays modern, interactive cards for the event venues.
 */
import '@/styles/invitation/_event-location.scss';
import VenueCard from '@/components/invitation/components/VenueCard.astro';
import Icon from '@/components/common/icons/Icon.astro';
import SectionNavButton from '@/components/invitation/components/SectionNavButton.astro';

import type { ImageMetadata } from 'astro';
import type { ImageAsset } from '@/lib/assets/asset-registry';
import type { IconName } from '@/lib/icons/icon-catalog';
import type {
	IndicationStyleVariant,
	LocationVariant,
} from '@/lib/theme/theme-contract';
import type { LocationVisibility } from '@/lib/adapters/types';

interface VenueData {
	venueEvent: string;
	venueName: string;
	address: string;
	city?: string;
	date: string;
	time: string;
	mapUrl?: string;
	appleMapsUrl?: string;
	googleMapsUrl?: string;
	wazeUrl?: string;
	image?: string | ImageMetadata | ImageAsset;
	focalPoint?: string;
	coordinates?: {
		lat: number;
		lng: number;
	};
}

interface Indication {
	iconName: IconName;
	styleVariant: IndicationStyleVariant;
	text: string;
}

interface VenueEntry extends VenueData {
	id?: string;
	type?: string;
	label?: string;
	isVisible?: boolean;
	sortOrder?: number;
}

interface Props {
	visibility?: LocationVisibility;
	isLocked?: boolean;
	lockedTitle?: string;
	lockedMessage?: string;
	lockedCtaLabel?: string;
	ceremony?: VenueData;
	reception?: VenueData;
	venues?: VenueEntry[];
	indications?: Indication[];
	variant?: LocationVariant;
	showFlourishes?: boolean;
	indicationsHeading?: string;
	nextSectionLink?: {
		href: string;
		label?: string;
	};
	introEyebrow?: string;
	introHeading?: string;
	introLede?: string;
}

const {
	isLocked = false,
	lockedTitle = 'Ubicación reservada',
	lockedMessage = 'Los detalles del lugar se mostrarán después de confirmar asistencia.',
	lockedCtaLabel = 'Confirmar asistencia',
	ceremony,
	reception,
	venues: venueEntries,
	indications,
	variant = 'structured',
	showFlourishes = true,
	indicationsHeading,
	nextSectionLink,
	introEyebrow,
	introHeading,
	introLede,
} = Astro.props;

// Use venues array if present, otherwise fall back to legacy ceremony/reception
const displayVenues = venueEntries && venueEntries.length > 0
	? venueEntries
	: [
			...(ceremony ? [{ ...ceremony, type: 'ceremony' as const, isVisible: true }] : []),
			...(reception ? [{ ...reception, type: 'reception' as const, isVisible: true }] : []),
		];

const isSingleVenue = displayVenues.length === 1;
---

<section class="event-location" id="event-location" data-variant={variant}>
	<span class="event-location__anchor" id="location" aria-hidden="true"></span>
	{introHeading && (
		<header class="event-location__intro">
			{introEyebrow && <p class="event-location__eyebrow">{introEyebrow}</p>}
			<h2 class="event-location__heading">{introHeading}</h2>
			{introLede && <p class="event-location__lede">{introLede}</p>}
		</header>
	)}
	{isLocked ? (
		<div class="event-location__locked" data-gated-location>
			<div class="event-location__locked-icon" aria-hidden="true">
				<Icon name="Forbidden" size={28} />
			</div>
			<h3 class="event-location__locked-title">{lockedTitle}</h3>
			<p class="event-location__locked-message">{lockedMessage}</p>
			<a class="event-location__locked-cta" href="#rsvp">{lockedCtaLabel}</a>
		</div>
	) : (
		<div class={`event-location__container ${isSingleVenue ? 'event-location__container--single' : ''}`}>
			{displayVenues.map((venue: VenueData & { type?: string }) => (
				<VenueCard
					venue={venue}
					type={venue.type === 'ceremony' || venue.type === 'reception' ? venue.type : 'custom'}
					variant={variant}
					showFlourishes={showFlourishes}
				/>
			))}
		</div>
	)}

	{indications && indications.length > 0 && (
		<div class="event-location__indications-container">
			<div class="event-location__divider" aria-hidden="true"></div>
			{indicationsHeading && (
				<p class="event-location__indications-heading">{indicationsHeading}</p>
			)}
			<div class="event-location__indications">
				{indications.map((indication) => {
					const isReserved = indication.styleVariant === 'reserved';
					return (
						<div class={`event-location__indication-item ${isReserved ? 'event-location__indication-item--reserved' : ''}`}>
							<div class="event-location__indication-icon">
								<Icon name={indication.iconName} size={24} />
							</div>
							<p class="event-location__indication-text" set:html={indication.text} />
						</div>
					);
				})}
			</div>
		</div>
	)}

	{nextSectionLink && (
		<div class="nav-button-container">
			<SectionNavButton
				href={nextSectionLink.href}
				class="event-location"
				section={nextSectionLink.label}
			/>
		</div>
	)}

</section>
<script>
	import { initCopyButtons, revealIOSOnly } from '@/utils/ui';

	const sections = document.querySelectorAll('.event-location');

	if (sections.length > 0) {
		initCopyButtons('.copy-button', 'data-address');
		revealIOSOnly('[data-apple-link]');

		sections.forEach((section) => {
			if (section instanceof HTMLElement) {
				const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

				if (!prefersReducedMotion) {
					section.classList.add('has-motion');
					const observer = new IntersectionObserver(
						(entries) => {
							entries.forEach((entry) => {
								if (entry.isIntersecting) {
									section.classList.add('is-visible');
									observer.unobserve(entry.target);
								}
							});
						},
						{ threshold: 0.1, rootMargin: '0px 0px -50px 0px' },
					);

					observer.observe(section);
				}
			}
		});
	}

	document.querySelectorAll('[data-gated-location]').forEach(() => {
		window.addEventListener('celebrame:rsvp-confirmed', (event) => {
			const inviteId = event instanceof CustomEvent ? event.detail?.inviteId : undefined;
			if (typeof inviteId !== 'string' || inviteId.length === 0) return;

			const nextUrl = new URL(window.location.href);
			nextUrl.searchParams.set('invite', inviteId);
			nextUrl.hash = 'event-location';
			window.location.assign(nextUrl.toString());
		});
	});
</script>
