---
// src/components/invitation/Gifts.astro
import '@/styles/invitation/_gifts.scss';
import { GiftIcon } from '@/components/common/icons/invitation/Gift';
import { BankCardIcon } from '@/components/common/icons/ui/BankCard';
import { CashIcon } from '@/components/common/icons/ui/Cash';
import { PayPalIcon } from '@/components/common/icons/social/PayPal';

interface GiftStoreLink {
	label: string;
	url: string;
}

interface GiftStore {
	type: 'store';
	title: string;
	url?: string;
	links?: GiftStoreLink[];
	logo?: string;
	description?: string;
}

interface GiftBank {
	type: 'bank';
	title: string;
	bankName: string;
	accountHolder: string;
	clabe: string;
	accountNumber?: string;
}

interface GiftPaypal {
	type: 'paypal';
	title: string;
	url: string;
}

interface GiftCash {
	type: 'cash';
	title: string;
	text?: string;
}

type Gift = GiftStore | GiftBank | GiftPaypal | GiftCash;

interface Props {
	gifts: Gift[];
	variant?: string;
	eyebrow?: string;
	title?: string;
	subtitle?: string;
	labels?: {
		copy?: string;
		copied?: string;
		viewRegistry?: string;
		sendGift?: string;
		bank?: string;
		titular?: string;
		clabe?: string;
	};
}

const {
	gifts,
	variant = 'standard',
	eyebrow,
	title = 'Mesa de Regalos',
	subtitle = 'Su presencia es nuestro mayor regalo, pero si desean tener un detalle, aquí les compartimos algunas opciones.',
	labels = {
		copy: 'Copiar',
		copied: '¡Copiado!',
		viewRegistry: 'Ver mesa de regalos',
		sendGift: 'Enviar Regalo',
		bank: 'Banco',
		titular: 'Titular',
		clabe: 'CLABE',
	},
} = Astro.props;

const ICON_MAP = {
	store: GiftIcon,
	bank: BankCardIcon,
	paypal: PayPalIcon,
	cash: CashIcon,
};
---

<section id="regalos" class="gifts-section" data-variant={variant}>
	<div class="gifts-section__container">
		<header class="gifts-section__header">
			{eyebrow && <span class="gifts-section__eyebrow">{eyebrow}</span>}
			<h2 class="gifts-section__title">{title}</h2>
			<div class="gifts-section__flourish" aria-hidden="true">
				<span class="flourish-line"></span>
				<span class="flourish-diamond"></span>
				<span class="flourish-line"></span>
			</div>
			{subtitle && <p class="gifts-section__subtitle">{subtitle}</p>}
		</header>

		<div class="gifts-section__separator" aria-hidden="true"></div>

		<div class="gifts-grid" data-count={gifts.length}>
			{
				gifts.map((gift) => {
					const Icon = ICON_MAP[gift.type];
					return (
						<div class={`gift-card gift-card--${gift.type}`}>
							<div class="gift-card__inner">
								<div class="gift-card__icon-medallion">
									<div class="gift-card__icon-inner">
										<Icon size={24} />
									</div>
								</div>

								<h3 class="gift-card__title">{gift.title}</h3>

								{gift.type === 'store' && gift.description && (
									<p class="gift-card__store-label">{gift.description}</p>
								)}

								{gift.type === 'store' && (
									<div class="gift-card__actions">
										{gift.links && gift.links.length > 0 ? (
											gift.links.map((link) => (
												<a
													href={link.url}
													target="_blank"
													rel="noopener noreferrer"
													class="gift-card__button"
												>
													{link.label}
												</a>
											))
										) : (
											<a href={gift.url} target="_blank" rel="noopener noreferrer" class="gift-card__button">
												{labels.viewRegistry}
											</a>
										)}
									</div>
								)}

								{gift.type === 'bank' && (
									<div class="bank-details">
										<p class="bank-details__item">
											<strong>{labels.bank}:</strong>
											<span data-status={gift.bankName.includes('PENDIENTE') ? 'pending' : undefined}>{gift.bankName}</span>
										</p>
										<p class="bank-details__item">
											<strong>{labels.titular}:</strong>
											<span data-status={gift.accountHolder.includes('PENDIENTE') ? 'pending' : undefined}>{gift.accountHolder}</span>
										</p>
										<div class="bank-details__clabe-wrapper">
											<p class="bank-details__item">
												<strong>{labels.clabe}:</strong>
												<span class="clabe-number">{gift.clabe}</span>
											</p>
											<button class="copy-button" data-clabe={gift.clabe} data-label-copy={labels.copy} data-label-copied={labels.copied} aria-label="Copiar número CLABE">
												{labels.copy}
											</button>
										</div>
									</div>
								)}


								{gift.type === 'paypal' && (
									<a href={gift.url} target="_blank" rel="noopener noreferrer" class="gift-card__button gift-card__button--paypal">
										{labels.sendGift}
									</a>
								)}

								{gift.type === 'cash' && gift.text && (
									<p class="gift-card__description">{gift.text}</p>
								)}
							</div>
						</div>
					);
				})
			}
		</div>
	</div>
</section>
<script>
	import { createIntersectionObserver } from '@/utils/animations';

	const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (!prefersReducedMotion) {
		document.querySelectorAll('.gifts-section').forEach((section) => {
			section.classList.add('has-motion');
		});

		createIntersectionObserver(
			'.gifts-section.has-motion',
			(target) => target.classList.add('is-visible'),
		);
	}

	document.querySelectorAll('.copy-button').forEach((button) => {
		const labelCopy = button.getAttribute('data-label-copy') || 'Copiar';
		const labelCopied = button.getAttribute('data-label-copied') || '¡Copiado!';

		button.addEventListener('click', async () => {
			const clabe = button.getAttribute('data-clabe');
			if (!clabe) {
				return;
			}

			const normalizedClabe = clabe.replace(/\s+/g, '');
			await navigator.clipboard.writeText(normalizedClabe);
			button.textContent = labelCopied;
			button.classList.add('copy-button--success');
			window.setTimeout(() => {
				button.textContent = labelCopy;
				button.classList.remove('copy-button--success');
			}, 2000);
		});
	});
</script>

