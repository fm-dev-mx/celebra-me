---
/**
 * src/components/home/Hero.astro
 * Hero "Prime" Component
 */
import ActionBase from '@components/common/actions/ActionBase.astro';
import ActionIcon from '@components/common/actions/ActionIcon.astro';
import WhatsAppButton from '@components/ui/WhatsAppButton.tsx';
import type { HeroData } from '@/interfaces/ui/sections/landing-page.interface';
import { getCommonAsset } from '@/lib/assets/asset-registry';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Import consolidated Premium styles
import '@/styles/components/_hero.scss';

interface Props {
	data: HeroData;
}

const { data } = Astro.props;

const avatar1 = getCommonAsset('avatar1');
const avatar2 = getCommonAsset('avatar2');
const avatar3 = getCommonAsset('avatar3');
---

<section class="hero-prime" id="inicio" role="region" aria-labelledby="hero-title">
	<!-- 1. Background Layer -->
	<div class="hero-prime__bg">
		<!-- Priority Image (Lazy load off for LCP) -->
		<Image
			src={data.backgroundImage.desktopUrl}
			alt="Experiencia de lujo en invitaciones digitales para eventos exclusivos"
			class="hero-bg-img"
			width={1920}
			height={1080}
			loading="eager"
		/>

		{data.backgroundImage.videoUrl && (
			<video
				autoplay
				loop
				muted
				playsinline
				poster={data.backgroundImage.desktopUrl}
				class="hero-bg-video"
			>
				<source src={data.backgroundImage.videoUrl} type="video/webm" />
				<source src={data.backgroundImage.videoUrl.replace('.webm', '.mp4')} type="video/mp4" />
			</video>
		)}
	</div>

	<!-- 2. Overlay Layer -->
	<div class="hero-prime__overlay"></div>

	<!-- 3. Content Layer -->
	<div class="hero-prime__content">
		<!-- Title (Stagger 1) -->
		<h1 class="hero-prime__title stagger-1" id="hero-title">
			{data.title}
		</h1>

		<!-- Subtitle (Stagger 2) -->
		<p class="hero-prime__subtitle stagger-2">
			{data.subtitle}
		</p>

		<!-- Actions (Stagger 3) -->
		<div class="hero-prime__actions stagger-3">
			<WhatsAppButton
				client:idle
				className="shine-effect"
				phone={data.whatsappPhone}
				message={data.whatsappMessage}
				label={data.primaryCtaLabel}
			/>
			<ActionBase as="a" href={data.secondaryCtaUrl || '#servicios'} variant="outline" color="white" class="shine-effect">
				{data.secondaryCtaLabel}
			</ActionBase>
		</div>

		<!-- Social Proof (Optional) -->
		{data.socialProofText && (
			<div class="hero-prime__social-proof stagger-3">
				<div class="avatars">
					<Image src={avatar1.src as ImageMetadata} alt="Usuario de Celebra-me" width={40} height={40} />
					<Image src={avatar2.src as ImageMetadata} alt="Usuario de Celebra-me" width={40} height={40} />
					<Image src={avatar3.src as ImageMetadata} alt="Usuario de Celebra-me" width={40} height={40} />
				</div>
				<span>{data.socialProofText}</span>
			</div>
		)}
	</div>

	<!-- Scroll Indicator -->
	<div class="hero-prime__scroll-indicator">
		<ActionIcon
			icon="ArrowDownIcon"
			variant="scroll"
			color="white"
			as="a"
			href="#servicios"
			title="Descubre más"
		/>
	</div>
</section>
<!-- Keep premium hero motion local instead of depending on a separate behavior wrapper. -->
<script>
	const hero = document.getElementById('inicio');
	const shouldReduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	if (hero && !shouldReduceMotion) {
		const background = hero.querySelector('.hero-prime__bg');
		const media = background?.querySelectorAll('img, video') ?? [];

		const handleMouseMove = (event: MouseEvent) => {
			const moveX = (event.clientX - window.innerWidth / 2) / 50;
			const moveY = (event.clientY - window.innerHeight / 2) / 50;
			media.forEach((element) => {
				(element as HTMLElement).style.transform = `scale(1.1) translate(${moveX}px, ${moveY}px)`;
			});
		};

		const handleMouseLeave = () => {
			media.forEach((element) => {
				(element as HTMLElement).style.transform = 'scale(1.1) translate(0, 0)';
			});
		};

		hero.addEventListener('mousemove', (event) => handleMouseMove(event as MouseEvent));
		hero.addEventListener('mouseleave', handleMouseLeave);
	}
</script>
