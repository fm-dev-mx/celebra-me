---
/**
 * src/components/home/HomeHeader.astro
 *
 * Landing Page implementation of the Header.
 * Consumes HeaderBase and injects marketing content.
 */

import HeaderBase from '@components/common/HeaderBase.astro';
import NavBarMobile from '@components/ui/header/NavBarMobile.astro';
import Logo from '@components/ui/Logo.astro';
import '@styles/home/_home-header.scss';

const navLinks = [
    { label: 'Demos', href: '/xv/noir-premiere-xv' },
    { label: 'Servicios', href: '#servicios' },
    { label: 'Planes', href: '#pricing' },
    { label: 'Nosotros', href: '#nosotros' },
];

const loginLink = '/login?next=%2Fdashboard%2Finvitados';
const ctaLink = '#contacto';
---

<HeaderBase
    transparentOnHero={true}
    headerId="home-header"
>

    <!-- SLOT: Logo -->
    <a href="/" slot="logo" class="home-header__logo-container" aria-label="Celebra-me Inicio">
        <Logo variant="white" class="logo-img home-header__logo--white" />
        <Logo variant="gold" class="logo-img home-header__logo--gold" />
    </a>

    <!-- SLOT: Desktop Nav -->
    <div slot="desktop-nav" class="home-header__desktop">
        <div class="home-nav">
            {navLinks.map(link => (
                <a href={link.href} class="home-nav__link">{link.label}</a>
            ))}
        </div>

        <div class="home-nav-actions">
            <a href={loginLink} class="home-nav-actions__login">
                Iniciar sesión
            </a>
            <a href={ctaLink} class="home-nav-actions__cta">
                Crear Invitación
            </a>
        </div>
    </div>

    <div slot="mobile-nav-premium">
        <NavBarMobile
            links={navLinks}
            headerId="home-header"
            loginLink={loginLink}
            ctaLink={ctaLink}
            loginLabel="Iniciar sesión"
            ctaLabel="Crear Invitación"
        />
    </div>

</HeaderBase>
