---
// src/sections/Contact.astro
import ContactForm from '@components/ui/ContactForm.astro';
import ActionIcon from '@components/common/actions/ActionIcon.astro';
import Icon from '@components/common/icons/Icon.astro';
import type { ContactData } from '@/interfaces/ui/sections/landing-page.interface';
import { getWhatsAppLink } from '@/utils/whatsapp';

// Import stylesheet
import '@/styles/home/_contact.scss';

interface Props {
	data: ContactData;
}

// Destructure the data prop
const { data } = Astro.props;
---

<!-- Contact Section -->
<section id="contacto" class="contact-section" data-track-section="contact">
	<div class="contact-texture"></div>

	<div class="container">
		<header class="contact-header">
			<span class="contact-pretitle">Concierge Service</span>
			<h2 class="contact-title">{data.title}</h2>
			<div class="contact-divider"></div>
		</header>

		<div class="contact-grid">
			<!-- Contact Information -->
			<div class="contact-info">
				<div class="contact-info__content">
					<h3 class="contact-info__title">Atención Personalizada</h3>
					<p class="contact-info__description">
						Transformamos su evento en una experiencia digital única. Inicie su solicitud de diseño con nuestro equipo.
					</p>

					<div class="contact-channels">
						<a
							href={getWhatsAppLink('Hola, me gustaría conocer más sobre sus invitaciones digitales para eventos.')}
							target="_blank"
							class="channel-link"
							data-track-event="whatsapp_contact_clicked"
							data-track-section="contact"
							data-track-cta="contact_whatsapp"
							data-track-intent="whatsapp"
						>
							<div class="channel-icon-wrapper">
								<Icon name="WhatsApp" size={24} />
							</div>
							<div class="channel-text">
								<span class="channel-label">Asesoría Inmediata</span>
								<span class="channel-value">Contáctanos por WhatsApp</span>
							</div>
						</a>

						<a
							href="mailto:contacto@celebra-me.com"
							target="_blank"
							class="channel-link"
							data-track-event="cta_clicked"
							data-track-section="contact"
							data-track-cta="contact_email"
							data-track-intent="email"
						>
							<div class="channel-icon-wrapper">
								<Icon name="Message" size={24} />
							</div>
							<div class="channel-text">
								<span class="channel-label">Vía Correo</span>
								<span class="channel-value">contacto@celebra-me.com</span>
							</div>
						</a>
					</div>
				</div>

				<div class="contact-info__footer">
					<p>Excelencia en cada detalle • Celebra-me © 2026</p>
				</div>
			</div>

			<!-- Contact Form Component -->
			<div class="contact-form-wrapper">
				<ContactForm />
			</div>
		</div>

		<!-- Scroll Action -->
		<div class="contact-footer">
			<ActionIcon
				icon="ArrowUpIcon"
				variant="scroll"
				href="#pricing"
				color="secondary"
				title="Regresar a los planes"
			/>
		</div>
	</div>
</section>
