---
/**
 * src/components/common/HeaderBase.astro
 *
 * Foundation component for all headers (Landing & Invitation).
 * Handles:
 * - Scroll detection (Shrink effect, Glassmorphism transparency)
 * - Mobile Menu state & animations
 * - Auto-Hide on landscape mobile
 */

import '@styles/layout/_header-base.scss';

export interface Props {
    transparentOnHero?: boolean;
    headerId: string;
    variant?: string;
}

const {
    transparentOnHero = true,
    headerId,
    variant = 'standard',
} = Astro.props;
---

<header
    id={headerId}
    class={`header-base ${transparentOnHero ? 'header-base--transparent' : ''}`}
    data-variant={variant}
    data-transparent={transparentOnHero.toString()}
    data-threshold-shrink="50"
    data-threshold-hide="100"
>
    <div class="header-base__container">
        <!-- Slot: Logo (Adaptive logic lives in parent) -->
        <div class="header-base__logo">
            <slot name="logo" />
        </div>

        <!-- Slot: Desktop Navigation -->
        <nav class="header-base__desktop-nav" aria-label="Navegación principal">
            <slot name="desktop-nav" />
        </nav>

        <!-- Slot for shared Astro mobile navigation -->
        <slot name="mobile-nav-premium" />
    </div>
</header>

<script>
	/**
	 * Shared header behavior:
	 * - shrink on scroll
	 * - hero transparency toggle
	 * - auto-hide while scrolling down
	 * - exposes --nav-current-height on :root for page-level consumers (e.g. scrollPaddingTop)
	 *
	 * Thresholds are read from data-threshold-shrink / data-threshold-hide
	 * per header instance, allowing per-page customization.
	 */
	const headers = Array.from(document.querySelectorAll('.header-base'));
	const root = document.documentElement;

	let lastScrollY = window.scrollY;

	const updateHeaderState = () => {
		const currentScrollY = window.scrollY;

		headers.forEach((header) => {
			if (!(header instanceof HTMLElement)) {
				return;
			}

			const shrinkAt = Number(header.dataset.thresholdShrink ?? 50);
			const hideAt = Number(header.dataset.thresholdHide ?? 100);
			const hasScrolled = currentScrollY > shrinkAt;

			const isTransparentConfigured = header.dataset.transparent === 'true';
			const isMenuOpen = header.classList.contains('header-base--menu-open');

			header.classList.toggle('header-base--scrolled', hasScrolled);

			if (isTransparentConfigured && !isMenuOpen) {
				header.classList.toggle('header-base--transparent', !hasScrolled);
			} else {
				header.classList.remove('header-base--transparent');
			}

			if (isMenuOpen) {
				header.classList.remove('header-base--hidden');
			} else {
				const isScrollingDown = currentScrollY > lastScrollY;
				header.classList.toggle(
					'header-base--hidden',
					currentScrollY > hideAt && isScrollingDown,
				);
			}

			if (header.classList.contains('header-base--hidden')) {
				root.style.setProperty('--nav-current-height', '0px');
			} else if (header.classList.contains('header-base--scrolled')) {
				root.style.setProperty('--nav-current-height', 'var(--nav-height-scrolled)');
			} else {
				root.style.setProperty('--nav-current-height', 'var(--nav-height)');
			}
		});

		lastScrollY = currentScrollY;
	};

	updateHeaderState();
	window.addEventListener('scroll', updateHeaderState, { passive: true });
</script>
