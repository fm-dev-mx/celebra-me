---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { ImageAsset } from '@/lib/assets/asset-registry';

interface Props {
	imagePath: ImageMetadata | string | ImageAsset | null | undefined;
	alt: string;
	rounded?: string;
	width?: number;
	height?: number;
	class?: string;
	loading?: 'eager' | 'lazy';
	decoding?: 'async' | 'auto' | 'sync';
	fetchpriority?: 'high' | 'low' | 'auto';
	sizes?: string;
	widths?: number[] | readonly number[];
	format?: 'avif' | 'jpeg' | 'jpg' | 'png' | 'svg' | 'webp';
	quality?: number;
}

const {
	imagePath,
	alt,
	rounded = '',
	width = 350,
	height = 350,
	class: className,
	loading,
	decoding,
	fetchpriority,
	sizes,
	widths,
	format,
	quality,
} = Astro.props;

const resolveSrc = (input: ImageMetadata | string | ImageAsset | null | undefined) => {
	if (!input) return null;
	if (typeof input === 'object' && 'src' in input && !('width' in input)) {
		return input.src;
	}
	return input;
};

const finalSrc = resolveSrc(imagePath);
---

{
	finalSrc ? (
		<Image
			src={finalSrc as any}
			alt={alt}
			{...widths ? { widths: widths as number[], sizes } : {}}
			width={width}
			height={height}
			class:list={[rounded, className]}
			loading={loading}
			decoding={decoding}
			fetchpriority={fetchpriority}
			format={format}
			quality={quality}
		/>
	) : (
		<svg
			width={width}
			height={height}
			viewBox={`0 0 ${width} ${height}`}
			class:list={['optimized-image__fallback', rounded, className]}
			aria-label={alt}
		>
			<rect width="100%" height="100%" fill="currentColor" opacity="0.1" />
			<text
				x="50%"
				y="50%"
				text-anchor="middle"
				dominant-baseline="middle"
				class="optimized-image__fallback-label"
			>
				{alt}
			</text>
		</svg>
	)
}

<style lang="scss">
	.optimized-image__fallback {
		display: block;
		background: var(--color-surface-secondary);
		border: 1px solid var(--color-border-subtle);
		color: var(--color-text-secondary);
	}

	.optimized-image__fallback-label {
		font-size: 12px;
		fill: currentColor;
	}
</style>
