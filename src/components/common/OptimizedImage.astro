---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { ImageAsset } from '@/lib/assets/asset-registry';

interface Props {
	imagePath: ImageMetadata | string | ImageAsset | null | undefined;
	alt: string;
	rounded?: string;
	width?: number;
	height?: number;
	class?: string;
}

const { imagePath, alt, rounded = '', width = 350, height = 350, class: className } = Astro.props;

const resolveSrc = (input: ImageMetadata | string | ImageAsset | null | undefined) => {
	if (!input) return null;
	if (typeof input === 'object' && 'src' in input && !('width' in input)) {
		// It's an ImageAsset (has src but not width/height like ImageMetadata)
		// actually ImageMetadata has src, width, height, format.
		// ImageAsset has src (string|Metadata), alt.
		return (input as ImageAsset).src;
	}
	return input;
};

const finalSrc = resolveSrc(imagePath);
---

{
	finalSrc ? (
		typeof finalSrc === 'string' ? (
			<Image
				src={finalSrc}
				alt={alt}
				width={width}
				height={height}
				class:list={[rounded, className]}
			/>
		) : (
			<Image
				src={finalSrc as ImageMetadata}
				alt={alt}
				width={width}
				height={height}
				class:list={[rounded, className]}
			/>
		)
	) : (
		<svg
			width={width}
			height={height}
			viewBox={`0 0 ${width} ${height}`}
			class:list={['optimized-image__fallback', rounded, className]}
			aria-label={alt}
		>
			<rect width="100%" height="100%" fill="currentColor" opacity="0.1" />
			<text
				x="50%"
				y="50%"
				text-anchor="middle"
				dominant-baseline="middle"
				class="optimized-image__fallback-label"
			>
				{alt}
			</text>
		</svg>
	)
}

<style lang="scss">
	.optimized-image__fallback {
		display: block;
		background: var(--color-surface-secondary);
		border: 1px solid var(--color-border-subtle);
		color: var(--color-text-secondary);
	}

	.optimized-image__fallback-label {
		font-size: 12px;
		fill: currentColor;
	}
</style>
