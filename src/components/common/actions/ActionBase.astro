---
/**
 * src/components/common/actions/ActionBase.astro
 * Base Action Component (Button or Link)
 */
import '@/styles/components/actions/_action-base.scss';

interface _Props {
	variant?: 'default' | 'outline' | 'text';
	color?: 'primary' | 'secondary' | 'white';
	as?: 'a' | 'button';
	href?: string;
	title?: string;
	class?: string;
	className?: string;
	target?: string;
}

const {
	variant = 'default',
	color = 'primary',
	as: Tag = 'a',
	href,
	title,
	class: classNameAttr,
	className: classNameProp,
	target,
} = Astro.props as _Props;

const finalClassName = classNameAttr || classNameProp;
---

<Tag
	href={href}
	title={title}
	target={target}
	class:list={[
		'action-base',
		`action-base--${color}`,
		variant !== 'default' ? `action-base--${variant}` : '',
		finalClassName,
	]}
>
	<slot />
</Tag>
