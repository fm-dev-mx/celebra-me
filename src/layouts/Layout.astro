---
/** src/layouts/Layout.astro */
import '@/styles/global.scss';

import Header from '@/components/home/HomeHeader.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import GoogleAnalytics from '@/components/common/GoogleAnalytics.astro';
import SvgFilters from '@/components/common/SvgFilters.astro';
import { resolvePublicSiteOrigin } from '@/lib/invitation/social-metadata';
import { classifyTrackingRoute, shouldLoadGoogleAnalytics } from '@/lib/tracking/route-policy';

// Typography: Montserrat UI font is loaded globally. Preset-specific fonts are loaded dynamically.
import '@fontsource-variable/montserrat';

import type { ImageMetadata } from 'astro';

interface Props {
	title: string;
	description?: string;
	image?: string | ImageMetadata;
	hideHeader?: boolean;
	className?: string;
	isDemo?: boolean;
	themeMode?: 'light' | 'dark';
	headLinks?: Array<{ rel: 'stylesheet'; href: string }>;
}

const {
	title,
	description = 'Celebra.me - Invitaciones digitales',
	image = '/images/og-image.webp',
	hideHeader = false,
	className,
	isDemo = false,
	themeMode = 'dark',
	headLinks = [],
} = Astro.props;

const isVercelProduction = process.env.VERCEL_ENV === 'production';

const resolvedImageSrc = typeof image === 'string' ? image : image.src;

const canonicalOrigin = resolvePublicSiteOrigin();

let canonicalUrl = new URL(Astro.url.pathname, canonicalOrigin);
if (canonicalUrl.pathname !== '/' && canonicalUrl.pathname.endsWith('/')) {
	canonicalUrl.pathname = canonicalUrl.pathname.replace(/\/+$/, '');
}

const ogImage = new URL(resolvedImageSrc, canonicalOrigin);

const gaId = import.meta.env.PUBLIC_GOOGLE_ANALYTICS_ID;
const routePolicy = classifyTrackingRoute(Astro.url);
const loadGoogleAnalytics = shouldLoadGoogleAnalytics(Astro.url, {
	vercelEnv: process.env.VERCEL_ENV,
	gaId,
});
const loadCommercialTracking = isVercelProduction && routePolicy.internalAllowed;
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/x-icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		{!isVercelProduction && <meta name="ga-debug" content={`gaId=${gaId ?? '(empty)'}`} />}
		<title>{title}</title>

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:alt" content={title} />
		<link rel="canonical" href={canonicalUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:locale" content="es_MX" />
		<meta property="og:site_name" content="Celebra.me" />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:url" content={canonicalUrl} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		{headLinks.map(l => <link rel={l.rel} href={l.href} />)}

		{loadGoogleAnalytics && <GoogleAnalytics id={gaId} />}
		<SvgFilters />
	</head>
	<body
		class:list={[className, { 'is-demo': isDemo }]}
		data-theme-mode={themeMode}
		data-tracking-route-class={loadCommercialTracking ? routePolicy.routeClass : undefined}
	>
		{!hideHeader && <Header />}

		<main>
			<slot />
		</main>

		{isVercelProduction && <Analytics />}
		{isVercelProduction && <SpeedInsights />}
		{loadCommercialTracking && (
			<script>
				import { initCommercialTracking } from '@/lib/tracking/client';
				initCommercialTracking();
			</script>
		)}
	</body>
</html>
