---
import '@/styles/dashboard.scss';
import DashboardSidebar from '@/components/dashboard/shell/DashboardSidebar.astro';
import { getSessionContextFromRequest } from '@/lib/rsvp/auth/auth';
import { toDisplayRole } from '@/lib/rsvp/auth/roles';
import type { DashboardNavItem } from '@/interfaces/dashboard/admin.interface';
import GoogleAnalytics from '@/components/common/GoogleAnalytics.astro';

interface Props {
	title: string;
}

const { title } = Astro.props as Props;

// Middleware already enforces the authenticated session and redirects to /login.
// The layout only reads the session to render user-specific navigation.
const session = await getSessionContextFromRequest(Astro.request);

// Keep a defensive fallback in case the session was stripped before rendering.
if (!session) {
	return Astro.redirect(`/login?next=${encodeURIComponent(Astro.url.pathname)}`);
}

// The CSRF token is generated by middleware and forwarded through locals.
const { csrfToken } = Astro.locals;

const navItems: DashboardNavItem[] = [
	{ label: 'Invitados', href: '/dashboard/invitados' },
	{ label: 'Administración', href: '/dashboard/admin', adminOnly: true },
	{ label: 'Códigos de acceso', href: '/dashboard/claimcodes', adminOnly: true },
	{ label: 'Eventos', href: '/dashboard/eventos', adminOnly: true },
	{ label: 'Usuarios', href: '/dashboard/usuarios', adminOnly: true },
];
const currentSectionLabel =
	navItems.find(
		(item) =>
			item.href === Astro.url.pathname ||
			(item.href !== '/dashboard/invitados' && Astro.url.pathname.startsWith(`${item.href}/`)),
	)?.label ?? title;

const isProd = import.meta.env.PROD;
const gaId = import.meta.env.PUBLIC_GOOGLE_ANALYTICS_ID;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="csrf-token" content={csrfToken} />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="alternate icon" href="/favicon.ico" />
		<title>{title}</title>

		{isProd && gaId && <GoogleAnalytics id={gaId} />}
	</head>

	<body class="theme-preset--jewelry-box dashboard-shell-body">
		<div class="dashboard-shell">
			<div class="dashboard-shell__backdrop" data-dashboard-backdrop aria-hidden="true"></div>
			<DashboardSidebar
				sidebarId="dashboard-sidebar"
				items={navItems}
				currentPath={Astro.url.pathname}
				userEmail={session.email}
				roleLabel={toDisplayRole(session.role)}
				isAdmin={session.isSuperAdmin}
			/>
			<div class="dashboard-shell__content">
				<header class="dashboard-topbar">
					<button
						type="button"
						class="dashboard-topbar__menu-button"
						data-dashboard-menu-toggle
						aria-controls="dashboard-sidebar"
						aria-expanded="false"
					>
						<span class="dashboard-topbar__menu-line"></span>
						<span class="dashboard-topbar__menu-line"></span>
						<span class="dashboard-topbar__menu-line"></span>
						<span class="sr-only">Abrir navegación del panel</span>
					</button>

					<div class="dashboard-topbar__meta">
						<span class="dashboard-topbar__eyebrow">Celebra-me Panel</span>
						<h1>{currentSectionLabel}</h1>
					</div>
				</header>
				<main class="dashboard-main">
					<slot />
				</main>
			</div>
		</div>
	</body>
</html>
<script>
	const topbar = document.querySelector('.dashboard-topbar');
	const sidebar = document.getElementById('dashboard-sidebar');
	const menuButton = document.querySelector('[data-dashboard-menu-toggle]');
	const backdrop = document.querySelector('[data-dashboard-backdrop]');

	const closeDashboardNav = () => {
		if (!(sidebar instanceof HTMLElement) || !(menuButton instanceof HTMLButtonElement)) {
			return;
		}

		sidebar.classList.remove('dashboard-sidebar--open');
		menuButton.setAttribute('aria-expanded', 'false');
		document.body.classList.remove('dashboard-shell-body--nav-open');
	};

	if (
		sidebar instanceof HTMLElement &&
		menuButton instanceof HTMLButtonElement &&
		backdrop instanceof HTMLElement
	) {
		const toggleDashboardNav = () => {
			const isOpen = sidebar.classList.toggle('dashboard-sidebar--open');
			menuButton.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
			document.body.classList.toggle('dashboard-shell-body--nav-open', isOpen);
		};

		menuButton.addEventListener('click', toggleDashboardNav);
		backdrop.addEventListener('click', closeDashboardNav);
		sidebar.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', closeDashboardNav);
		});
		window.addEventListener('resize', () => {
			if (window.innerWidth > 992) {
				closeDashboardNav();
			}
		});
		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') {
				closeDashboardNav();
			}
		});
	}

	if (topbar instanceof HTMLElement) {
		let lastScrollY = window.scrollY;
		let isHidden = false;
		const scrollThreshold = 50;

		const handleScroll = () => {
			const currentScrollY = window.scrollY;

			topbar.classList.toggle('dashboard-topbar--scrolled', currentScrollY > 20);

			if (currentScrollY > scrollThreshold) {
				if (currentScrollY > lastScrollY && !isHidden) {
					topbar.classList.add('dashboard-topbar--hidden');
					isHidden = true;
				} else if (currentScrollY < lastScrollY && isHidden) {
					topbar.classList.remove('dashboard-topbar--hidden');
					isHidden = false;
				}
			} else {
				topbar.classList.remove('dashboard-topbar--hidden');
				isHidden = false;
			}

			lastScrollY = currentScrollY;
		};

		window.addEventListener('scroll', handleScroll, { passive: true });
	}
</script>
