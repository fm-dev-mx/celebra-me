---
import '@/styles/global.scss';
import '@/styles/dashboard/_shell.scss';
import '@/styles/dashboard/_tables.scss';
import '@/styles/dashboard/_forms.scss';
import DashboardSidebar from '@/components/dashboard/shell/DashboardSidebar.astro';
import { getSessionContextFromRequest } from '@/lib/rsvp/auth';
import { toDisplayRole } from '@/lib/rsvp/roles';
import type { DashboardNavItem } from '@/lib/rsvp/types';

interface Props {
	title: string;
}

const { title } = Astro.props as Props;

// El middleware ya valida la sesión y hace redirect a /login si no hay sesión
// Aquí solo leemos la sesión para obtener datos del usuario
const session = await getSessionContextFromRequest(Astro.request);

// Verificación defensiva: si por alguna razón la sesión es null, redirect a login
// (El middleware debería manejar esto, pero es un fallback de seguridad)
if (!session) {
	return Astro.redirect(`/login?next=${encodeURIComponent(Astro.url.pathname)}`);
}

// El csrfToken se genera en el middleware y se pasa por locals
const { csrfToken } = Astro.locals;

const navItems: DashboardNavItem[] = [
	{ label: 'Invitados', href: '/dashboard/invitados' },
	{ label: 'Admin', href: '/dashboard/admin', adminOnly: true },
	{ label: 'Claim Codes', href: '/dashboard/claimcodes', adminOnly: true },
	{ label: 'Eventos', href: '/dashboard/eventos', adminOnly: true },
	{ label: 'Usuarios', href: '/dashboard/usuarios', adminOnly: true },
];
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="csrf-token" content={csrfToken} />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="alternate icon" href="/favicon.ico" />
		<title>{title}</title>
	</head>
	<body class="theme-preset--jewelry-box dashboard-shell-body">
		<div class="dashboard-shell">
			<DashboardSidebar
				items={navItems}
				currentPath={Astro.url.pathname}
				userEmail={session.email}
				roleLabel={toDisplayRole(session.role)}
				isAdmin={session.isSuperAdmin}
			/>
			<div class="dashboard-shell__content">
				<main class="dashboard-main">
					<slot />
				</main>
			</div>
		</div>

		<script is:inline>
			(() => {
				const topbar = document.querySelector('.dashboard-topbar');
				if (!topbar) return;

				let lastScrollY = window.scrollY;
				let isHidden = false;
				const SCROLL_THRESHOLD = 100;

				const handleScroll = () => {
					const currentScrollY = window.scrollY;

					// Scrolled shadow effect
					if (currentScrollY > 20) {
						topbar.classList.add('dashboard-topbar--scrolled');
					} else {
						topbar.classList.remove('dashboard-topbar--scrolled');
					}

					// Hide/Show logic
					if (currentScrollY > SCROLL_THRESHOLD) {
						if (currentScrollY > lastScrollY && !isHidden) {
							topbar.classList.add('dashboard-topbar--hidden');
							isHidden = true;
						} else if (currentScrollY < lastScrollY && isHidden) {
							topbar.classList.remove('dashboard-topbar--hidden');
							isHidden = false;
						}
					} else {
						topbar.classList.remove('dashboard-topbar--hidden');
						isHidden = false;
					}

					lastScrollY = currentScrollY;
				};

				window.addEventListener('scroll', handleScroll, { passive: true });
			})();
		</script>
	</body>
</html>
