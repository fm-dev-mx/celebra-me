# ==============================================================================
# Celebra-me Local Development Environment Template
# ==============================================================================
# Copy to .env or .env.local for local development only.
# Do not put production secrets, production URLs, or PROD_DB_URL in this file.
# See docs/env-workflow.md for the canonical environment workflow.
# ==============================================================================

# ------------------------------------------------------------------------------
# Runtime
# ------------------------------------------------------------------------------
NODE_ENV=development
BASE_URL=http://localhost:4321

# ------------------------------------------------------------------------------
# Supabase local development
# ------------------------------------------------------------------------------
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=local-anon-key-placeholder
SUPABASE_SERVICE_ROLE_KEY=local-service-role-key-placeholder

# Browser-safe Supabase values. Never expose SUPABASE_SERVICE_ROLE_KEY with PUBLIC_.
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=local-anon-key-placeholder

# ------------------------------------------------------------------------------
# RSVP and intake security
# ------------------------------------------------------------------------------
# Generate local placeholders with: openssl rand -hex 32
TRUST_DEVICE_SECRET=local-trust-device-secret-placeholder
TRUST_DEVICE_MAX_AGE_DAYS=30
RSVP_CLAIM_CODE_PEPPER=local-claim-code-pepper-placeholder
INTAKE_TOKEN_ENCRYPTION_KEY=local-intake-token-encryption-key-placeholder

# ------------------------------------------------------------------------------
# Local rate limiting
# ------------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://local-upstash-placeholder.invalid
UPSTASH_REDIS_REST_TOKEN=local-upstash-token-placeholder
RSVP_V2_DISTRIBUTED_RATELIMIT=false

# ------------------------------------------------------------------------------
# Local admin and auth behavior
# ------------------------------------------------------------------------------
SUPER_ADMIN_EMAILS=admin@example.com
RSVP_ADMIN_USER=admin
RSVP_ADMIN_PASSWORD=rsvp-password-placeholder
LOCAL_SUPER_ADMIN_PASSWORD=local-super-admin-password-placeholder
REQUIRE_FRESH_MFA_FOR_ADMIN=false
DEV_MFA_BYPASS=false

# ------------------------------------------------------------------------------
# Email and contact
# ------------------------------------------------------------------------------
GMAIL_USER=local-email@example.com
GMAIL_PASS=local-gmail-app-password-placeholder
CONTACT_FORM_RECIPIENT_EMAIL=contact@example.com
CONTACT_WHATSAPP=521000000000

# ------------------------------------------------------------------------------
# Public analytics placeholder
# ------------------------------------------------------------------------------
PUBLIC_GOOGLE_ANALYTICS_ID=G-LOCALPLACEHOLDER
