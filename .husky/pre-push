#!/bin/sh

set -e

# Main push guard blocks refs/heads/main unless ALLOW_MAIN_PUSH=true.
# (The commit validation and tests below still apply)

ZERO_SHA="0000000000000000000000000000000000000000"

if [ "$SKIP_BRANCH_PROTECTION" = "true" ]; then
  echo "⚠️  Bypassing commit validation and tests (SKIP_BRANCH_PROTECTION=true)..."
else
  echo "🧪 Running commit-range validation before push..."
  validated=0

  while read local_ref local_sha remote_ref remote_sha
  do
    # Block direct pushes to main unless ALLOW_MAIN_PUSH=true
    if [ "$remote_ref" = "refs/heads/main" ]; then
      if [ "$ALLOW_MAIN_PUSH" != "true" ]; then
        echo "❌ Error: Pushing directly to 'main' is not allowed."
        echo "💡 Use 'ALLOW_MAIN_PUSH=true git push origin main' if absolutely necessary."
        exit 1
      fi
    fi
    if [ -z "$local_sha" ] || [ "$local_sha" = "$ZERO_SHA" ]; then
      continue
    fi

    if [ -z "$remote_sha" ] || [ "$remote_sha" = "$ZERO_SHA" ]; then
      # New branch: try to find base against main or develop first
      BASE_SHA=$(git merge-base "$local_sha" origin/main 2>/dev/null || git merge-base "$local_sha" origin/develop 2>/dev/null || git rev-list --max-parents=0 "$local_sha" | tail -n 1)
    else
      BASE_SHA=$(git merge-base "$local_sha" "$remote_sha")
    fi

    if [ -n "$BASE_SHA" ]; then
      node scripts/validate-commits.mjs "$BASE_SHA" "$local_sha"
      validated=1
    fi
  done

  # Tests and type-checks stay in CI or manual runs to keep this hook lean.
  # pnpm test
fi
