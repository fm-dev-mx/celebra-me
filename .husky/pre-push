#!/bin/sh

set -e

# Branch protection check
current_branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$current_branch" = "main" ] || [ "$current_branch" = "develop" ]; then
  if [ "$SKIP_BRANCH_PROTECTION" = "true" ]; then
    echo "⚠️  Bypassing branch protection for '$current_branch'..."
  else
    echo "❌ Error: Pushing directly to '$current_branch' is not allowed."
    echo "💡 Please use a Pull Request or set 'SKIP_BRANCH_PROTECTION=true' if absolutely necessary."
    exit 1
  fi
fi

echo "🧪 Running commit-range validation before push..."
validated=0
ZERO_SHA="0000000000000000000000000000000000000000"

while read local_ref local_sha remote_ref remote_sha
do
  if [ -z "$local_sha" ] || [ "$local_sha" = "$ZERO_SHA" ]; then
    continue
  fi

  if [ -z "$remote_sha" ] || [ "$remote_sha" = "$ZERO_SHA" ]; then
    BASE_SHA=$(git rev-list --max-parents=0 "$local_sha" | tail -n 1)
  else
    BASE_SHA=$(git merge-base "$local_sha" "$remote_sha")
  fi

  if [ -n "$BASE_SHA" ]; then
    node scripts/validate-commits.mjs "$BASE_SHA" "$local_sha"
    validated=1
  fi
done

if [ "$validated" -eq 0 ]; then
  echo "ℹ️ No push range detected for commit validation."
fi

pnpm test
