#!/bin/sh

# ------------------------------------------------------------
# 1) Prevent direct commits to main
# ------------------------------------------------------------
if [ "$(git branch --show-current)" = "main" ]; then
  echo "❌ No puedes hacer commit directamente en la rama 'main'. Usa una rama de feature."
  exit 1
fi

# ------------------------------------------------------------
# 2) Secret scan (lightweight regex-based)
# ------------------------------------------------------------
echo "🔍 Verificando posibles secrets..."

FILES=$(git diff --cached --name-only --diff-filter=ACM)

PATTERNS="
api[_-]?key.*=.*['\"][a-zA-Z0-9]{20,}['\"]
secret.*=.*['\"][a-zA-Z0-9]{20,}['\"]
password.*=.*['\"][^'\"]{8,}['\"]
token.*=.*['\"][a-zA-Z0-9]{20,}['\"]
SG\.[a-zA-Z0-9]{20,}
eyJ[a-zA-Z0-9_-]{20,}
sk-[a-zA-Z0-9]{20,}
xox[baprs]-[a-zA-Z0-9]{10,}
"

FOUND=0

for file in $FILES; do
  case "$file" in
    *.md|*.example|*.sh)
      continue
      ;;
  esac

  if [ -f "$file" ]; then
    for pattern in $PATTERNS; do
      grep -iE "$pattern" "$file" >/dev/null 2>&1 && {
        echo "⚠️ Posible secret detectado en: $file"
        FOUND=1
      }
    done
  fi
done

if echo "$FILES" | grep -E "^\.env" >/dev/null; then
  echo "🚨 No puedes commitear archivos .env"
  exit 1
fi

if [ $FOUND -eq 1 ]; then
  echo "❌ Commit bloqueado por posible secret."
  exit 1
fi

# ------------------------------------------------------------
# 3) Gatekeeper workflow (S0 mode)
# ------------------------------------------------------------
if [ -f ".git/gatekeeper-s0.txt" ]; then
  echo "🔍 Gatekeeper mode detected"
  S0_FILES=$(cat .git/gatekeeper-s0.txt | sed '/^\s*$/d')

  if [ -n "$S0_FILES" ]; then
    echo "$S0_FILES" | tr '\n' '\0' | xargs -0 pnpm lint-staged --no-stash
  fi

  exit 0
fi

# ------------------------------------------------------------
# 4) Normal lint-staged
# ------------------------------------------------------------
echo "🔧 Running lint-staged..."
pnpm lint-staged
