#!/bin/sh

set -e

# Branch protection check
current_branch=$(git rev-parse --abbrev-ref HEAD)

if [ "$current_branch" = "main" ] || [ "$current_branch" = "develop" ]; then
  if [ "$SKIP_BRANCH_PROTECTION" = "true" ]; then
    echo "⚠️  Bypassing branch protection for '$current_branch'..."
  else
    echo "❌ Error: Committing directly to '$current_branch' is not allowed."
    echo "💡 Please create a feature branch or use 'SKIP_BRANCH_PROTECTION=true git commit' if absolutely necessary."
    exit 1
  fi
fi

echo "🛡️ Running pre-commit checks..."
pnpm lint
