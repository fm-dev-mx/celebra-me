{
    "domains": {
        "invitation": [
            "src/components/invitation/**",
            "src/pages/[eventType]/**",
            "src/layouts/Layout.astro",
            "src/styles/invitation/**"
        ],
        "auth": [
            "src/lib/rsvp/**",
            "src/pages/login.astro",
            "src/pages/api/auth/**",
            "src/pages/api/invitacion/**",
            "src/middleware.ts"
        ],
        "theme": [
            "src/styles/themes/**",
            "src/styles/tokens/**",
            "src/styles/global/**",
            "src/styles/ui/**",
            "src/styles/*.scss"
        ],
        "gov-agent-config": [
            ".agent/governance/bin/**",
            ".agent/governance/config/**",
            ".agent/GATEKEEPER_RULES.md",
            ".agent/README.md"
        ],
        "gov-skills": [".agent/skills/**"],
        "gov-plans-archive": [".agent/plans/README.md", ".agent/plans/archive/**"],
        "gov-plans-invitation": [
            ".agent/plans/real-xv-invitation/**",
            ".agent/plans/wedding-finalization/**",
            ".agent/plans/ximena-overhaul/**"
        ],
        "gov-tooling": [
            "scripts/**",
            "commitlint.config.cjs",
            "eslint.config.js",
            ".markdownlintignore",
            ".markdownlint.json",
            ".prettierrc.mjs",
            ".editorconfig",
            "docs/core/git-governance.md"
        ],
        "gov-plans-remediation": [".agent/plans/error-remediation-evolution/**"],
        "gov-plans-gatekeeper": [".agent/plans/gatekeeper-optimization/**"],
        "gov-workflows": [".agent/workflows/**", "docs/DOC_STATUS.md"],
        "gov-scripts": [".agent/scripts/**"],
        "gov-infra": [
            ".husky/**",
            ".github/**",
            ".vscode/**",
            "package.json",
            "pnpm-lock.yaml",
            ".gitignore",
            "astro.config.mjs",
            "tsconfig.json"
        ],
        "core": [
            "src/content/config.ts",
            "src/content/events/**",
            "src/content/event-demos/**",
            "src/content/event-templates/**",
            "src/lib/**",
            "src/data/**",
            "src/styles/events/**",
            "src/pages/api/*",
            "archive/**",
            "*.md"
        ],
        "ui": [
            "src/pages/index.astro",
            "src/pages/404.astro",
            "src/pages/under-construction.astro",
            "src/components/common/**",
            "src/components/ui/**",
            "src/components/home/**",
            "src/components/layout/**",
            "src/assets/**"
        ],
        "docs": ["docs/**", ".agent/docs/**"],
        "test": ["tests/**", "**/*.test.*", "**/*.spec.*", "jest.config.*", "playwright.config.*"],
        "admin": [
            "src/pages/admin/**",
            "src/layouts/DashboardLayout.astro",
            "src/components/admin/**",
            "src/components/dashboard/**",
            "src/pages/api/dashboard/**",
            "src/pages/dashboard/**",
            "src/styles/dashboard/**"
        ]
    },
    "defaultDomain": "core"
}
