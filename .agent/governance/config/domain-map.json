{
    "domains": {
        "core": [
            "README.md",
            "CONTRIBUTING.md",
            "src/content/config.ts",
            "src/content/events/**",
            "src/content/event-demos/**",
            "src/content/event-templates/**",
            "src/data/**",
            "src/hooks/**",
            "src/interfaces/**",
            "src/lib/**",
            "src/utils/**",
            "src/styles/events/**"
        ],
        "ui": [
            "src/pages/index.astro",
            "src/pages/404.astro",
            "src/pages/under-construction.astro",
            "src/components/behavior/**",
            "src/components/common/**",
            "src/components/home/**",
            "src/components/layout/**",
            "src/components/typography/**",
            "src/components/ui/**",
            "src/assets/**"
        ],
        "invitation": [
            "src/components/invitation/**",
            "src/pages/[eventType]/**",
            "src/layouts/Layout.astro",
            "src/lib/invitation/**",
            "src/styles/invitation/**"
        ],
        "auth": [
            "src/lib/rsvp/auth/**",
            "src/lib/rsvp/core/**",
            "src/lib/rsvp/repositories/**",
            "src/lib/rsvp/security/**",
            "src/lib/rsvp/services/**",
            "src/middleware.ts",
            "src/pages/login.astro",
            "src/pages/api/auth/**",
            "src/pages/api/invitacion/**"
        ],
        "admin": [
            "src/layouts/DashboardLayout.astro",
            "src/components/dashboard/**",
            "src/pages/dashboard/**",
            "src/pages/api/dashboard/**",
            "src/styles/dashboard/**"
        ],
        "theme": [
            "src/lib/theme/**",
            "src/lib/schemas/content/**",
            "src/styles/themes/**",
            "src/styles/tokens/**",
            "src/styles/tools/**",
            "src/styles/global/**",
            "src/styles/home/**",
            "src/styles/layout/**",
            "src/styles/common/**",
            "src/styles/components/**",
            "src/styles/ui/**",
            "src/styles/*.scss"
        ],
        "docs": ["docs/**"],
        "test": ["tests/**", "**/*.test.*", "**/*.spec.*", "jest.config.*", "playwright.config.*"],
        "gov-config": [
            ".agent/governance/config/**",
            ".agent/GATEKEEPER_RULES.md",
            ".agent/README.md",
            ".agent/index.md"
        ],
        "gov-skills": [".agent/skills/**"],
        "gov-workflows": [".agent/workflows/**"],
        "gov-plans": [".agent/plans/README.md", ".agent/plans/archive/**"],
        "gov-tooling": [
            "scripts/**",
            "commitlint.config.cjs",
            "eslint.config.js",
            ".markdownlint.json",
            ".markdownlintignore",
            ".prettierrc.mjs",
            ".stylelintrc.json",
            ".editorconfig",
            "docs/core/git-governance.md"
        ],
        "gov-infra": [
            ".github/**",
            ".husky/**",
            ".vscode/**",
            "astro.config.mjs",
            "package.json",
            "pnpm-lock.yaml",
            "tsconfig.json",
            "vercel.json",
            ".npmrc",
            ".gitignore"
        ]
    },
    "defaultDomain": "core"
}
