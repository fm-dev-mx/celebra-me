{
  "planId": "repo-hygiene-audit",
  "mode": "planned-commits",
  "defaultFallback": "none",
  "units": [
    {
      "id": "repo-hygiene-audit-record",
      "phaseId": "01-cleanup",
      "status": "planned",
      "domain": "governance",
      "type": "docs",
      "subject": {
        "verb": "establish",
        "target": "repo-hygiene-audit plan baseline"
      },
      "purpose": "initialize the plan for repository hygiene audit and restructuring",
      "include": [
        ".agent/plans/repo-hygiene-audit/**"
      ],
      "allowRelated": [],
      "correctionPolicy": "absorb-compatible"
    },
    {
      "id": "remove-root-logs",
      "phaseId": "01-cleanup",
      "status": "planned",
      "domain": "ops",
      "type": "chore",
      "subject": {
        "verb": "purge",
        "target": "root-level log and transient artifacts"
      },
      "purpose": "remove misplaced log files from git tracking and root directory",
      "include": ["full_test.log", "test.log", "test_output.txt", "tests_out.log", "tests_out_esm.log"],
      "allowRelated": [".gitignore"],
      "correctionPolicy": "absorb-compatible"
    },
    {
      "id": "retire-orphaned-dirs",
      "phaseId": "01-cleanup",
      "status": "planned",
      "domain": "ops",
      "type": "chore",
      "subject": {
        "verb": "retire",
        "target": "orphaned tracking and redundant archive dirs"
      },
      "purpose": "eliminate obsolete directories that contain no active project data",
      "include": ["tracking/**", "archive/**"],
      "allowRelated": [],
      "correctionPolicy": "absorb-compatible"
    },
    {
      "id": "sync-path-aliases",
      "phaseId": "02-config-alignment",
      "status": "planned",
      "domain": "core",
      "type": "refactor",
      "subject": {
        "verb": "synchronize",
        "target": "path aliases across astro and typescript"
      },
      "purpose": "align configuration and prune non-existent path references",
      "include": ["astro.config.mjs", "tsconfig.json"],
      "allowRelated": [],
      "correctionPolicy": "absorb-compatible"
    },
    {
      "id": "consolidate-utils",
      "phaseId": "03-simplification",
      "status": "planned",
      "domain": "core",
      "type": "refactor",
      "subject": {
        "verb": "merge",
        "target": "nested lib utils into root utils"
      },
      "purpose": "resolve the Russian Doll anti-pattern by centralizing standard utilities",
      "include": ["src/utils/**", "src/lib/utils/**"],
      "allowRelated": ["src/**"],
      "correctionPolicy": "absorb-compatible"
    },
    {
      "id": "modularize-rsvp",
      "phaseId": "03-simplification",
      "status": "planned",
      "domain": "core",
      "type": "refactor",
      "subject": {
        "verb": "modularize",
        "target": "rsvp monolithic domain"
      },
      "purpose": "break down src/lib/rsvp into clear domain sub-folders",
      "include": ["src/lib/rsvp/**"],
      "allowRelated": ["src/pages/api/invitacion/**", "tests/**"],
      "correctionPolicy": "absorb-compatible"
    },
    {
      "id": "verify-hygiene-audit",
      "phaseId": "04-validation",
      "status": "planned",
      "domain": "core",
      "type": "chore",
      "subject": {
        "verb": "validate",
        "target": "repository build and lint health"
      },
      "purpose": "final check of aliases, imports, and build stability following hygiene remediation",
      "include": ["package.json"],
      "allowRelated": ["*"],
      "correctionPolicy": "absorb-compatible"
    }
  ]
}
