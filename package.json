{
    "name": "celebra-me.com",
    "type": "module",
    "version": "0.6.0-beta.1",
    "engines": {
        "node": ">=22.12.0 <25"
    },
    "packageManager": "pnpm@11.5.0+sha512.dbfcc4f81cf48597afd4bc391ffdf12c11f1a9fb83a395bfa6b0a2d9cc2fd8ffebafdb1ccbd529632153f793904c2615b7f09fe1a345473fd1c35845172a8eb1",
    "scripts": {
        "dev": "astro dev",
        "build": "pnpm validate:event-parity && astro check && astro build",
        "preview": "astro preview",
        "astro": "astro",
        "test": "jest",
        "test:e2e": "playwright test",
        "test:e2e:landing": "playwright test tests/e2e/landing.page.regressions.spec.ts",
        "type-check": "astro check",
        "ci": "pnpm type-check && pnpm lint && pnpm lint:styles:changed && pnpm validate:ui-governance && pnpm validate:event-parity && pnpm validate:no-pii && pnpm test && pnpm test:e2e",
        "lint": "eslint .",
        "lint:styles": "stylelint \"src/**/*.scss\"",
        "lint:styles:changed": "node scripts/lint-styles-changed.mjs",
        "validate:ui-governance": "node scripts/validate-ui-governance.mjs",
        "validate:no-pii": "node scripts/validate-no-real-pii-in-content.mjs",
        "lint-staged": "lint-staged",
        "commitlint": "commitlint",
        "prepare": "husky",
        "db:migrate:new": "supabase migration new",
        "db:push": "supabase db push",
        "db:local:reset": "supabase db reset --local --yes",
        "db:start": "supabase start",
        "db:stop": "supabase stop",
        "db:local:refresh-from-prod": "tsx scripts/db/refresh-local-from-prod.ts",
        "db:local:backup-wip": "tsx scripts/db/backup-local-wip.ts",
        "db:local:bootstrap-admin": "tsx scripts/db/bootstrap-local-admin.ts",
        "db:local:reset-ready": "pnpm db:local:reset && pnpm db:local:bootstrap-admin",
        "db:local:validate": "tsx scripts/db/validate-local-db.ts",
        "db:prod:backup": "tsx scripts/db/backup-prod.ts",
        "db:prod:migrate": "tsx scripts/db/push-prod-migrations.ts",
        "ops": "node scripts/cli.mjs",
        "validate:event-parity": "tsx scripts/validate-event-parity.ts --allowMissingDb"
    },
    "dependencies": {
        "@astrojs/vercel": "10.0.7",
        "@fontsource-variable/bodoni-moda": "^5.2.7",
        "@fontsource-variable/cinzel": "^5.2.8",
        "@fontsource-variable/cormorant-garamond": "^5.2.6",
        "@fontsource-variable/eb-garamond": "^5.2.7",
        "@fontsource-variable/instrument-sans": "^5.2.8",
        "@fontsource-variable/montserrat": "^5.2.8",
        "@fontsource-variable/playfair-display": "^5.2.8",
        "@fontsource/pinyon-script": "^5.2.8",
        "@fontsource/special-elite": "^5.2.8",
        "@fontsource/the-nautigal": "^5.2.7",
        "@supabase/supabase-js": "^2.106.1",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^2.0.0",
        "framer-motion": "^12.38.0",
        "nodemailer": "^8.0.8",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.9",
        "@astrojs/react": "5.0.4",
        "@astrojs/sitemap": "^3.7.2",
        "@commitlint/cli": "^21.0.0",
        "@commitlint/config-conventional": "^21.0.2",
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.59.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/nodemailer": "8.0.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "^19.2.3",
        "astro": "6.3.1",
        "astro-eslint-parser": "^1.4.0",
        "astro-robots-txt": "^1.0.0",
        "eslint": "^10.4.1",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-astro": "^1.7.0",
        "eslint-plugin-boundaries": "^6.0.2",
        "eslint-plugin-import": "2.32.0",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^30.3.0",
        "jest-environment-jsdom": "^30.3.0",
        "lint-staged": "17.0.5",
        "prettier": "^3.8.3",
        "prettier-plugin-astro": "^0.14.1",
        "sass-embedded": "^1.100.0",
        "sharp": "^0.34.5",
        "stylelint": "17.11.1",
        "stylelint-config-standard-scss": "^17.0.0",
        "supabase": "2.105.0",
        "ts-jest": "^29.4.11",
        "tsx": "^4.22.4",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.4"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,cjs}": ["eslint --fix --cache", "prettier --write"],
        "*.astro": ["eslint --fix --cache", "prettier --write"],
        "*.{scss,css}": ["stylelint --fix", "prettier --write"],
        "*.{json,md,yml,yaml}": ["prettier --write"]
    }
}
