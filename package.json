{
    "name": "celebra-me.com",
    "type": "module",
    "version": "0.0.1",
    "engines": {
        "node": ">=22.12.0 <23"
    },
    "scripts": {
        "dev": "astro dev",
        "build": "pnpm validate:event-parity && astro check && astro build",
        "preview": "pnpm serve .vercel/output/static",
        "start": "astro preview",
        "astro": "astro",
        "test": "jest",
        "test:e2e": "playwright test",
        "test:e2e:landing": "playwright test tests/e2e/landing.page.regressions.spec.ts",
        "type-check": "astro check",
        "turbo-all": "pnpm lint && pnpm validate:ui-governance && pnpm validate:event-parity && pnpm type-check && pnpm test && pnpm test:e2e",
        "ci": "pnpm type-check && pnpm lint && pnpm validate:ui-governance && pnpm validate:event-parity && pnpm test && pnpm test:e2e",
        "lint": "eslint .",
        "validate:ui-governance": "node scripts/validate-ui-governance.mjs",
        "lint-staged": "lint-staged",
        "commitlint": "commitlint",
        "prepare": "husky",
        "db:migrate:new": "supabase migration new",
        "db:push": "supabase db push",
        "db:reset:local": "supabase db reset",
        "db:start": "supabase start",
        "db:stop": "supabase stop",
        "ops": "node scripts/cli.mjs",
        "validate:event-parity": "node scripts/validate-event-parity.mjs --allowMissingDb"
    },
    "dependencies": {
        "@astrojs/vercel": "10.0.4",
        "@fontsource-variable/bodoni-moda": "^5.2.7",
        "@fontsource-variable/cinzel": "^5.2.8",
        "@fontsource-variable/cormorant-garamond": "^5.2.6",
        "@fontsource-variable/eb-garamond": "^5.2.7",
        "@fontsource-variable/montserrat": "^5.2.8",
        "@fontsource-variable/playfair-display": "^5.2.8",
        "@fontsource/pinyon-script": "^5.2.8",
        "@fontsource/rye": "^5.2.7",
        "@fontsource/special-elite": "^5.2.8",
        "@fontsource/the-nautigal": "^5.2.7",
        "@supabase/supabase-js": "^2.101.1",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^2.0.0",
        "framer-motion": "^12.38.0",
        "nodemailer": "^8.0.4",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "sharp": "^0.34.5",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.8",
        "@astrojs/react": "5.0.2",
        "@astrojs/sitemap": "^3.7.2",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/js": "^9.39.4",
        "@jest/globals": "^30.3.0",
        "@playwright/test": "^1.59.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/jest": "^30.0.0",
        "@types/nodemailer": "7.0.11",
        "@types/react": "19.2.14",
        "@types/react-dom": "^19.2.3",
        "astro": "6.1.3",
        "astro-eslint-parser": "^1.4.0",
        "astro-robots-txt": "^1.0.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-astro": "^1.6.0",
        "eslint-plugin-boundaries": "^6.0.2",
        "eslint-plugin-import": "2.31.0",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^30.3.0",
        "jest-environment-jsdom": "^30.3.0",
        "lint-staged": "16.4.0",
        "prettier": "^3.8.1",
        "prettier-plugin-astro": "^0.14.1",
        "sass-embedded": "^1.99.0",
        "serve": "^14.2.6",
        "stylelint": "17.6.0",
        "stylelint-config-standard-scss": "^17.0.0",
        "stylelint-scss": "^7.0.0",
        "ts-jest": "^29.4.9",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.58.0"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,cjs}": ["eslint --fix --cache", "prettier --write"],
        "*.astro": ["eslint --fix --cache", "prettier --write"],
        "*.{scss,css}": ["stylelint --fix", "prettier --write"],
        "*.{json,md,yml}": ["prettier --write"]
    },
    "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
    "pnpm": {
        "overrides": {
            "tar": ">=7.5.8",
            "minimatch@<3.1.4": "3.1.4",
            "minimatch@>=7.0.0 <7.4.8": "7.4.8",
            "minimatch@>=9.0.0 <9.0.7": "9.0.7",
            "rollup": ">=4.59.0",
            "lodash": ">=4.17.23",
            "ajv-draft-04>ajv": "8.18.0",
            "ajv@^8.0.0": "8.18.0"
        },
        "ignoredBuiltDependencies": ["@parcel/watcher", "esbuild", "sharp", "unrs-resolver"]
    }
}
